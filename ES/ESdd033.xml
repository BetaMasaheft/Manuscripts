               <history>
                  <origin>
                     <origPlace>
                        <placeName ref="INS0105DD"/>
                     </origPlace>
                     <origDate notBefore="1400" notAfter="1800" evidence="lettering" cert="medium">The manuscript consists of two codicological units. 
                        The fragment referred to as <ref target="#p1"/> originates from a different, older, and larger manuscript dating to the 15th century on paleographic grounds. 
                        Because of the large size of the folium, it was inserted sideways on the right, so the text appears perpendicular to the main writing surface.
                        The folium has been used as a guard leaf (<ref target="#q1"/>). 
                        The unit referred to as <ref target="#p2"/> can be dated to the 18th century on paleographic grounds. 
                        </origDate>
                  </origin>
                  </history>
