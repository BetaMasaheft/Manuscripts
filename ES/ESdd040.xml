                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <desc>Fine and careful.</desc>
                        <seg type="rubrication">Two groups of lines (alternating with black lines) on the opening page of <ref target="#ms_i1"/>; a few lines (alternating with black a
                           line) on the opening page of <ref target="#ms_i2.1"/> and <ref target="#ms_i5"/>; two lines (alternating
                           with black a line) of the incipit of <ref target="#ms_i2.2"/>, <ref target="#ms_i3"/> and <ref target="#ms_i4"/>; two initial
                           lines of the sections of <ref target="#ms_i1"/> and <ref target="#ms_i5"/>; words <foreign xml:lang="gez">kǝfl</foreign> and <foreign xml:lang="gez">mǝʿrāf</foreign>; 
                           part and chapter numbers; elements of punctuation marks; Ethiopic numerals or their elements.</seg>
                     </handNote>
