                        <note>The text is divided into parts (<foreign xml:lang="gez">kǝfl</foreign>), but only at the beginning
                          they are followed by a number.</note>
                     </msItem>
                     <msItem xml:id="ms_i2.2">
                        <locus from="77vb" to="82vb"></locus>
                        <title ref="LIT2396Tagsas">Tagśāṣa  Salomon ‘Admonition of Solomon’</title>
                        <note>Text is divided into parts (<foreign xml:lang="gez">kǝfl</foreign>), unnumbered.</note>
                     </msItem>
                     
