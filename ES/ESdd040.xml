                  <msItem xml:id="ms_i1">
                     <locus from="2ra" to="56vb"></locus>
                     <title ref="LIT1672Isaiah">Maṣḥafa ʾIsāyǝyyās ‘Book of Isaiah’</title>
                     <note>The text is divided into parts (<foreign xml:lang="gez">kǝfl</foreign>) which are followed by a number. The
                        numeration is not reliable and stops after <locus target="#34ra"/>. Up to <locus target="#56ra"/>, the scribe left
                        blank spaces for rubricated numerals.</note>
                  </msItem>

                  <msItem xml:id="ms_i2">
