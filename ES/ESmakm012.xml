                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Script from the second half of the nineteenth century.</seg>
                        <seg type="ink">Black, red.</seg>
                        <desc>Careful and regular hand. Broadly spaced letters.</desc>
                        
                        <seg type="rubrication">Divine names; titles of the homilies, epistles, letters, prayers and the petition; first three lines of the
                           colophon; elements of punctuation marks and Ethiopic numerals. Two lines (alternating with a black line) on the opening page of the texts.</seg>
                     </handNote>
                     
