                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Most likely, a second half of the nineteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <desc>Fine, regular. The name of the scribe, now unreadable, was mentioned in the subscriptio under <ref target="#ms_i1.5.4"/>.</desc> 
                        
                        <seg type="rubrication">Headings and incipits of the texts; a few lines on the incipit page of each Gospel (alternating with black
                           lines); numbers of the ‘tituli’; chapter numbers and the word <foreign xml:lang="gez">‘mǝʿrāf’</foreign>;
                           parts of the canon tables; elements of punctuation marks; elements of Ethiopic numerals.</seg>
                     </handNote>
                     
                     <handNote xml:id="h2" script="Ethiopic">
                        <note>The hand that wrote the text on <ref target="#q1"/> is likely the same as <ref target="#h1"/>.</note>
                        <seg type="script" cert="high">Most likely, a second half of the nineteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <desc>Fine, regular.</desc> 
                        <seg type="rubrication">Four lines on the incipit page, alternating with two black lines; headings of sections; grid lines of the canon tables; headings and postscripts of the canons;
                          elements of punctuation marks; elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#63r"/>
                           <desc type="LandGrant">Note on land and services granted to the <placeName ref="INS0174MAKM">Māy ʾAnbasā monastery</placeName> 
                              by King <persName ref="PRS10378Yohanne">Yoḥannǝs IV</persName> (r. <date notBefore="1872" notAfter="1889">1872–89</date>).
                              The note contains a brief history of privileges that were granted to the monastery and their guarantors. It is likely that the note was written by <ref target="#h1"/>.</desc>
                           <q xml:lang="am"/>
                        </item>
                        
                        <item xml:id="e1">
                           <locus target="#1v"/>
                           <desc type="Inventory">Incomplete list of the items owned by the monastery, crudely written in blue pen.</desc>
                        </item>
                        
                        <item xml:id="e2">
