                  <handDesc>
                     <!--ACHTUNG! first HandNote comes from writing system in Ethiospare. the others are one for each CHANGE OF HAND-->
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Fine, regular.</seg>
                        <seg type="ink">Black; red.</seg>The name of the scribe, now unreadable, was
                        mentioned in Additio 2.<date>Second half of the 19th century (?)</date>
                        <seg type="rubrication">Headings and incipits of the texts; on the incipit
                           page of each Gospel a few lines are rubricated (alternating with black
                           lines); numbers of the “tituli”; chapter numbers and the word mǝʿrāf;
                           parts of the Canon tables; elements of the punctuation signs; elements of
                           Ethiopic numerals.</seg>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">Quire I is possibly written in a
                        different hand (belonging to the same period of
                        time).<!--The names of this hands need to be replaced by appropriate refs.--></handNote>
                  </handDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#63r">f. 63r</locus>
                           <desc>: Note on the land charter issued by King Yoḥannǝs IV (r. 1872-89)
                              to May ʾAnbäsa. </desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> In Amharic; the note concerns the gʷǝlt to May ʾAnbäsa donated by
                              King Yoḥannǝs IV (r. 1872-89). </note>
                        </item>
                        <item xml:id="a2">
                           <locus target="#131rc">f. 131rc</locus>
                           <desc>: Donation note (?)  </desc>
                           <quote xml:lang="gez"/>
                           <quote xml:lang="en"/>
                           <note> The note is effaced. The name of the donor Takla Wängel and the
                              name of his wife are still readable; the note contained also the name
                              of the scribe, written in red ink, now unreadable. </note>
                        </item>
                        <item xml:id="e1">- Incomplete list of the items owned by the monastery,
                           crudely written in blue pen: <locus target="#1v">1v</locus>. &#xD; - The
                           title ብስራተ፡ አብ፡ ትሩፍ፡ is carefully written in red ink on <locus target="#1v">1v</locus>. &#xD; - A strip of parchment is inserted (?):
                              <locus target="#7r">7r</locus>.&#xD; - Small cross on the left margin
                           of the first column of <locus target="#94r">94r</locus>.</item>
                        <item xml:id="e2"><!--2019-04-02+02:00 Updated MAKM-044 
            from DomLib -->
                           <desc type="findingAid">- A thread is inserted in the upper corner of <locus target="#46r">fol. 46r</locus>.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="false">
                        <decoNote xml:id="b1">Two wooden boards covered with brown tooled
                           leather.&#xD; Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b2" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="leather"/>
                        </decoNote>
                        <decoNote xml:id="b3" type="Endbands"/>
                        <decoNote xml:id="b4" type="Other">Small holes are visible on the spine fold
                           and in the centre fold of the quires, close to the head and tail of the
                           codex.</decoNote>
                        <decoNote xml:id="b5">Blind tooled ornament on the remains of the brown
                           leather cover is visible on the front board and on the turn-ins (at least
                           9 tools were used: double sine wave, cross hatching, triple line fillet,
                           single circle, criss-cross, triple dot fillet, double crescent,
                           corni-form, small x).</decoNote>
                     </binding>
                  </bindingDesc>
