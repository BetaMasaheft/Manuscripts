                        <additions>
                           <list>
                              <item xml:id="a1"> 
                                 <locus from="1va" to="1vb19"/>
                                 <desc type="CalendaricNote">Note on computation of the feasts. The note is written in Amharic and Gǝʿǝz. It contains instructions
                                    for calculating the mobile feasts of the year.</desc> 
                                 <q xml:lang="gez">አልቦ፡ አበቅቴ፡ ወአልቦ፡ መጥቅዕ፡ በሆነ፡ ጊዜ፡ ፩ መጥቅዕ፡ ማድረግ፡ አይገባም፡
                                    ዘይገብር፡ ፩ደ፡ መጥቅዐ፡ ውጉዝ፡ ለይኩን፡ ብሎ፡ ሊቁ፡ አውግዞታል። <gap reason="ellipsis" resp="MV"/></q>
                              </item>
                              
                              <item xml:id="a2"> 
                                 <locus from="1vb12" to="1vb20"/>
                                 <desc type="CalendaricNote">Chronological note, indicating the number of years between the preaching of the Apostles and the reign of Diocletian (277 years), between the
                                    reign of Diocletian and the Council of Nicaea (59 years), between the reign of Diocletian and the Council of Constantinople (117 years).</desc> 
                                    <q xml:lang="gez">እምስብካት፡ ሐዋርያት፡ እስከ፡ መንግሥተ፡ ድዮቅልጥያኖስ፡ ፪፻፸ወ፯ዓመት፡ እመንግሥተ፡ ድዮቅልጥያኖስ፡ ፶፱ዓመት፡ ኮነ፡ ጉባዒ፡ ኒቅያ፡ በመዋዕለ፡
                                       ቈስጠንጢኖስ፡ <gap reason="ellipsis" resp="MV"/></q>
                              </item>
                              
                              <item xml:id="a3"> 
                                 <locus from="1vb21" to="1vb26"/>
                                 <desc type="CalendaricNote">Chronological note, crudely written. It indicates the years in which Jesus Christ was conceived, born, baptized and crucified.</desc> 
                                    <q xml:lang="gez">በዮሐንስ፡ ተፀነሰ፡ በማቴዎስ፡ ተወለደ፡ በሉቃስ፡ ተጠመቀ፡ በማርቆስ፡ ተሰቀለ፡ <gap reason="ellipsis" resp="MV"/></q>
                              </item>
                              
                              <item xml:id="a4"> 
                                 <locus target="#8ra"/>
                                 <desc type="OwnershipNote">Ownership note written in red ink and encircled in a frame
                                    in black ink. It states that <persName role="owner" ref="PRS15365HaylaMika"><roleName type="title">ʾAbbā</roleName> Ḥayla Mikāʾel</persName> is the owner of the manuscript.</desc>
                                 <q xml:lang="gez">ዘመጽሐፍ፡ ዘአበሐይለ፡ ሚካኤል።</q> 
                              </item>
                              
                              <item xml:id="a5"> 
                                 <locus from="17ra" to="17rb"/>
                                 <desc type="Unclear">An unclear note, most of which has been effaced. The only two legible lines have been encircled in a frame in black ink.</desc>
                                 <q xml:lang="gez">በስመ፡ እግዚአብሔር፡ ሕያው፡ መሐር፡ ወመስተሣህል፡ ንዌጥን፡ ጽ <gap reason="lost" resp="MV"/></q>
                                </item>
                              
                              <item xml:id="a6"> 
                                 <locus from="17rb" to="17vb"/>
                                 <desc type="CalendaricNote"><title ref="LIT7857HassabeML"/>; note on the length of daylight and night of the months. The note indicates the number of the long and short days and
                                    nights for each month. Further computation notes are followed.</desc>
                                 <q xml:lang="gez">ሐሳብ፡ ዘመዓልት፡ ወሌሊት፡ ዘይነውህ፡ ወየሐጽር፡ በወርኃ፡ መስከርም፡<sic/>  ፲ወ፪፡ መዓልት፡ ወ፲፡ ወ፪፡ ሌሊት፡ ክልኤሙ፡ እሩይ፡ ለወርኃ፡ ጥቅምት፡ ፲፡
                                    ወ፩፡ መዓልት፡ ፲፡ ወ፫፡ ሌሊት፡ <gap reason="ellipsis" resp="MV"/></q>
                              </item>
                              
                              <item xml:id="e2"> 
                             <locus target="#18rv"/>
                                 <desc>Two tables are drawn in red ink and left unfilled.</desc>
                              </item>
                              
                              <item xml:id="e3"> 
                                 <locus target="#8rab #9rab #11ra #11vb #14rb #15r"/>
                                 <desc type="Correction">Omitted letters or words inserted interlineally. The folia listed above are a few examples.</desc> 
                              </item>
                              
                              <item xml:id="e4">
                                 <locus target="#11va"/>
                                <desc type="Correction">Omitted numeral added at the beginning of the line.</desc>
                              </item>
                              
                              <item xml:id="e5">
                                 <locus target="#13ra"/>
                                 <desc type="Correction">Omitted numeral added at the end of the line.</desc>
                              </item>
                              
                              <item xml:id="e6">
                                 <locus target="#8va #9rb #10rb #11vb"/>
                                 <desc type="Correction">Erasures.</desc>
                              </item>
                              
                              <item xml:id="e7">
                                 <locus target="#8vb #9vb #10rb #14va"/>
                                 <desc type="Correction">Immediate corrections indicated by thin lines above and below the word.</desc>
                              </item>
                              
                              <item xml:id="e8">
                                 <locus target="#12v"/>
                                 <desc>Scribbles.</desc>
                              </item>
                           </list>
