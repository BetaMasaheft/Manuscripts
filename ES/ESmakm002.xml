                        </item>
                           <item xml:id="e10">
                              <locus target="#27r #44r #96r #223r, 239r "/>
                              <desc type="Correction">Erasures. The folia listed above are a few examples.</desc>
                           </item>
                        <item xml:id="e11">
                           <locus target="#68v #111v #192v #246r #250v"/>
                           <desc type="Correction">Erasures marked with one or two thin parallel lines. The folia listed above are a few examples.</desc>
                        </item>
                        <item xml:id="e12">
                           <locus target="#37v #113r #179r #242v #250v"/>
                           <desc>Words encircled or partly encircled with a thin line. The folia listed above are a few examples.</desc> 
                        </item>
