                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Nineteenth century-script (?).</seg>
                        <seg type="ink">Black, red (vivid vermillion).</seg>
                        <desc>Fine; the handwriting is characterized by rounded and regular letters, but it slightly changes in some parts of the text (e.g. <locus target="#75r #78v"/>).</desc>
                      
                        <list type="abbreviations">
                           <item><ref target="#ms_i1.4"/>
                           <list>
                           <item>Words or their abbreviations stand for the whole refrain:</item>
                           <item>
                              <abbr>ሠረቀ፡</abbr> for <expan>ሠረቀ፡ በሥጋ፡ እምድንግል፡ ዘእንበለ፡ ዘርአ፡ ብእሲ፡ ወአድኅነነ፡</expan> (<locus from="232v" to="234ra"/>)</item>
                           <item>
                              <abbr>እስመ፡</abbr> for <expan>እስመ፡ በፈቃዱ፡ ወበሥምረቱ፡ አቡሁ፡ ወመንፈስ፡ ቅዱስ፡ መጽአ፡ ወአድኅነነ፡</expan> (<locus from="235rb" to="239ra"/>)</item>
                           <item>
                              <abbr>ኵሉ፡</abbr> for <expan>ኵሉ፡ ትውልድ፡ ያስተበፅዑኪ፡ ለኪ፡ ለበሕቲትኪ፡ ኦእግዝእትነ፡ ወላዲተ፡ አምላክ፡</expan> (<locus from="239rb" to="242rb"/>)</item>
                           <item>
                              <abbr>ናዓብ፡/ናዓብየኪ፡</abbr> for <expan>ናዓብየኪ፡ ኵልነ፡ ኦእግዝእትነ፡ ወላዲተ፡ አምላክ። እስመ፡ ሣህልኪ፡ ይኵን፡ ላዕለ፡ ኵልነ፡</expan> (<locus from="234ra" to="246vb"/>)</item>
