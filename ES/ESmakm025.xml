                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script">Script from the first half of the twentieth century.</seg>
                        <seg type="ink">Black, red (strong red).</seg>
                        <desc>Fine and regular. <persName role="scribe" ref="PRS15437TaklaHayma">Takla Hāymānot</persName> is mentioned as the scribe on <locus target="#16rb #54rb"/>.
                           Most likely, he is the same scribe as the one of <ref type="mss" corresp="ESmakm060"/>. He has a peculiar way of shaping the loop of the character <foreign xml:lang="gez">ግ</foreign>.</desc>
                        
                        <list type="abbreviations">
                           <item>
                              <abbr>ብ፡</abbr> for <expan>ብሂል፡</expan> (<locus from="10rb" to="11ra"/>)</item>
                           <item>
                              <abbr>ሀበ፡ እግ፡ በኃ፡ ዝ(ን)፡ አስ፡ ሃይ፡ ርት፡</abbr> for <expan>ሀበነ፡ እግዚኦ፡ በኃይለ፡ ዝንቱ፡ አስማቲከ፡ ሃይማኖተ፡ ርትዕተ፡ </expan> 
                              (<locus from="18vb" to="23vb"/>)</item>
                           <item>
                              <abbr>አድ፡ እግ፡ አም፡ በኃ፡ ዝ(ን)፡ አስ፡</abbr> for <expan>አድኀነነ፡ እግዚኦ፡
                                 አምላክነ፡ በኃይለ፡ ዝንቱ፡ አስማቲከ፡</expan> (<locus from="37va" to="40ra"/>)</item>
                           <item>
                              <abbr>እግዚኦ፡ አሜ፡</abbr> for <expan>እግዚአብሔር፡ አሜን፡</expan> (<locus from="43ra" to="44ra"/>)</item>
                           <item>
                              <abbr>ለዓለ፡ ዓለ፡ አ፡</abbr> for <expan>ለዓለመ፡ ዓለም፡ አሜን፡</expan> (<locus target="#54rb"/>)</item>
                           <item>
                              <abbr>ሰ(ላ)፡</abbr> for <expan>ሰላም፡</expan> (<locus from="54vb" to="57va"/>)</item>
                           <item>
                              <abbr>(ገብ)፡ መን(ፈ)፡ ቅ(ዱ)፡</abbr> for <expan>ገብረ፡ መንፈስ፡ ቅዱስ፡</expan>
                                 (<locus from="54vb" to="57va"/>)</item>
                        </list>
                        
                        <seg type="rubrication">Divine names; the name of the donor and the supplicants; the word
                           <foreign xml:lang="gez">‘salām’</foreign>; several lines on the incipit page of <ref target="#ms_i1"/> (<locus target="#4r"/>); the incipit
                           of the daily readings; the word <foreign xml:lang="gez">‘Bǝrsābāḥel’</foreign> on <locus target="#48va"/>; elements of punctuation marks; 
                           elements of Ethiopic numerals.</seg>
                     </handNote>
                  </handDesc>
                  
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#3r"/>
                           <desc type="DonationNote">A crude donation note, written in pencil, which states that <persName role="donor" ref="PRS15436GabraHeywat"><roleName type="title">ʾAbbā</roleName> Gabra Ḥǝywat</persName> donated the manuscript to the monastery
                              of <placeName ref="INS0174MAKM">Māy ʾAnbasā</placeName>.</desc>
                           <q xml:lang="gez">ዝመጽሓፍ፡ ዘአባ፡ ገብረ፡ ሕይወት፡ ዘወሀባ፡ ለታቦተ፡ ኪዳነ፡ ምሕረት፡ ማየ፡<sic/> አንበሳ፡ ድብር፡ ገነት፡</q>
                        </item>
                       
                        <item xml:id="e1">
                           <desc>The title <foreign xml:lang="gez">መጽሐፈ፡ አርድእት፡</foreign> has been written in blue paint on the front board.</desc>
                        </item>
                        
                        <item xml:id="e2">
                           <desc type="findingAid">Daily readings of <ref target="#ms_i1"/> are indicated by the days of the week written in the upper margin, in the main hand:
                              <foreign xml:lang="gez">ዘሠሉስ፡</foreign> <locus target="#11v"/>;
                              <foreign xml:lang="gez">ዘረቡዕ፡</foreign> <locus target="#16r"/>; 
                              <foreign xml:lang="gez">ዘሐሙስ፡</foreign> <locus target="#24r"/>;
                              <foreign xml:lang="gez">ዘዓርብ፡</foreign> <locus target="#34v"/>;
                              <foreign xml:lang="gez">ዘቀዳም፡</foreign> <locus target="#44r"/>; 
                                 <foreign xml:lang="gez">ዘእኁድ፡</foreign> <locus target="#51v"/>.</desc>
                        </item>
                     </list>
                  </additions>
