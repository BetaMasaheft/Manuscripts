                  <decoDesc>
                     <decoNote xml:id="d1" type="miniature">
                        <locus target="#1r"/>
                        <desc>Sermon on the Mount.</desc></decoNote>
                     <decoNote xml:id="d2" type="miniature">
                        <locus target="#2r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> heals a
                           leper.</desc></decoNote>
                     <decoNote xml:id="d3" type="miniature">
                        <locus target="#3v"/>
                        <desc>The centurion asks <ref type="authFile" corresp="AT1084JesusChrist"/>
                           to heal his boy.</desc></decoNote>
                     <decoNote xml:id="d4" type="miniature">
                        <locus target="#4r"/>
                        <desc><ref type="authFile" corresp="T1021MiraclesOfJesus">The healing of the
                              boy.</ref></desc></decoNote>
                     <decoNote xml:id="d5" type="miniature">
                        <locus target="#5r"/>
                        <desc><ref type="authFile" corresp="T1021MiraclesOfJesus">Jesus heals
                                 <persName ref="PRS7805Peter">St. Peter´s</persName>
                              mother-in-law.</ref></desc></decoNote>
                     <decoNote xml:id="d6" type="miniature">
                        <locus target="#6v"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> casts out a <term
                              key="demon"/>.</desc></decoNote>
                     <decoNote xml:id="d7" type="miniature">
                        <locus target="#7r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> says to the scribe
                           and the disciple to follow Him.</desc></decoNote>
                     <decoNote xml:id="d8" type="miniature">
                        <locus target="#8v"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> in the
                        boat.</desc></decoNote>
                     <decoNote xml:id="d9" type="miniature">
                        <locus target="#9v"/>
                        <desc><ref type="authFile" corresp="T1021MiraclesOfJesus">Jesus heals a
                              leper in Gergesa.</ref></desc></decoNote>
                     <decoNote xml:id="d10" type="miniature">
                        <locus target="#10r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> sends <term
                              key="demon">demons</term> into <term key="animal"
                        >pigs</term>.</desc></decoNote>
                     <decoNote xml:id="d11" type="miniature">
                        <locus target="#11r"/>
                        <desc><ref type="authFile" corresp="AT1074JesusHealsParalytic"
                        /></desc></decoNote>
                     <decoNote xml:id="d12" type="miniature">
                        <locus target="#12v"/>
                        <desc>The supper in <persName ref="PRS8854Simeon">Simeon´s</persName>
                           house.</desc></decoNote>
                     <decoNote xml:id="d13" type="miniature">
                        <locus target="#13r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> is asked to visit a
                           dead girl.</desc></decoNote>
                     <decoNote xml:id="d14" type="miniature">
                        <locus target="#13v"/>
                        <desc><ref type="authFile" corresp="T1021MiraclesOfJesus">The woman with the
                              hemorrhage.</ref></desc></decoNote>
                     <decoNote xml:id="d15" type="miniature">
                        <locus target="#14v"/>
                        <desc><ref type="authFile" corresp="T1021MiraclesOfJesus">The resurrection
                              of the girl.</ref></desc></decoNote>
                     <decoNote xml:id="d16" type="miniature">
                        <locus target="#15v"/>
                        <desc><ref type="authFile" corresp="AT1070JesushealstheBlind"
                        /></desc></decoNote>
                     <decoNote xml:id="d17" type="miniature">
                        <locus target="#16v"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> heals the mute and
                           possessed man.</desc></decoNote>
                     <decoNote xml:id="d18" type="miniature">
                        <locus target="#17r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> confers power on
                           the Apostles.</desc></decoNote>
                     <decoNote xml:id="d19" type="miniature">
                        <locus target="#20r"/>
                        <desc>The Disciples gather grain during Sabbath.</desc></decoNote>
                     <decoNote xml:id="d20" type="miniature">
                        <locus target="#21v"/>
                        <desc><ref type="authFile" corresp="T1021MiraclesOfJesus">The miracle of a
                              withered hand.</ref></desc></decoNote>
                     <decoNote xml:id="d21" type="miniature">
                        <locus target="#22r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> disputes with the
                           Pharisees.</desc></decoNote>
                     <decoNote xml:id="d22" type="miniature">
                        <locus target="#23r"/>
                        <desc><ref type="authFile" corresp="AT1084JesusChrist"/> before
                           Caiaphas.</desc></decoNote>
                     <decoNote xml:id="d23" type="miniature">
                        <locus target="#24r"/>
                        <desc><ref type="authFile" corresp="AT1023Mocking"/></desc></decoNote>
                     <decoNote xml:id="d24" type="miniature">
                        <locus target="#25r"/>
                        <desc>Flagellation.</desc></decoNote>
                     <decoNote xml:id="d25" type="miniature">
                        <locus target="#26r"/>
                        <desc><ref type="authFile" corresp="AT1018JBefPilate"><ref type="authFile"
                                 corresp="AT1084JesusChrist"> takes the <term key="cross"/> on his
                                 shoulders. </ref>
                              <persName ref="PRS7928Pontius"/> washes his
                        hands.</ref></desc></decoNote>
                     <decoNote xml:id="d26" type="miniature">
                        <locus target="#27r"/>
                        <desc>The Cyrenean helps <ref type="authFile" corresp="AT1084JesusChrist"
                           />.</desc></decoNote>
                     <decoNote xml:id="d27" type="miniature">
                        <locus target="#28r"/>
                        <desc/>Longinus wounds <ref type="authFile" corresp="AT1084JesusChrist"
                        /> on the <term key="cross"/>.</decoNote>
                     <decoNote xml:id="d28" type="miniature">
                        <locus target="#28v"/>
                        <desc><persName ref="PRS13687JosephArim"/> asks <ref type="authFile" corresp="AT1018JBefPilate"/> for the <term key="deadjesus">corpse of Jesus</term>.</desc></decoNote>
                     <decoNote xml:id="d29" type="miniature">
                        <locus target="#29r"/>
                        <desc><ref type="authFile" corresp="AT1007Deposition"/> and <ref type="authFile" corresp="AT1010Entombment"/>.</desc></decoNote>
                     <decoNote xml:id="d30" type="miniature">
                        <locus target="#30r"/>
                        <desc><ref type="authFile" corresp="AT1049Resurrection"/></desc></decoNote>
                     <decoNote xml:id="d31" type="miniature">
                        <locus target="#31r"/>
                        <desc><ref type="authFile" corresp="AT1106HolyWomen"><term key="angel"/> announces the Resurrection to holy women.</ref> <ref
                              type="authFile" corresp="AT1084JesusChrist"/> appears to the Disciples.</desc></decoNote>
