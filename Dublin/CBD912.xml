                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script" cert="medium">Late eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Chapter numbers, incipits, asterisks, a few other
                           punctuation marks and numerals and the name of Jesus.</seg>
                        <desc>Regular, neat, careful.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1" type="miniature">
                        <locus target="#1r"/>
                        <desc>Sermon on the Mount. <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ተናገሮሙ፡
                                 እግዚእነ፡ በመሳሌ፡ ለሕዝብ፡</hi></q></desc></decoNote>
                     <decoNote xml:id="d2" type="miniature">
                        <locus target="#2r"/>
                        <desc><persName ref="PRS5684JesusCh"/> heals a leper. <q xml:lang="gez"><hi
                                 rend="rubric">ዘከመ፡ ፈወሰ፡ እግዚእነ፡ እምለምጹ፡</hi></q></desc></decoNote>
                     <decoNote xml:id="d3" type="miniature">
                        <locus target="#3v"/>
                        <desc>The centurion asks <persName ref="PRS5684JesusCh"/> to heal his
                           servant. <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ሰአሎ፡ መስፍን፡ በእንተ፡ ደዌሁ፡
                                 ለገብር፡</hi></q></desc></decoNote>
                     <decoNote xml:id="d4" type="miniature">
                        <locus target="#4r"/>
                        <desc><ref type="authFile" corresp="AT1021MiraclesOfJesus">The healing of
                              the boy.</ref>
                           <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ረከቦ፡ መስፍን፡ ለቁልዔሁ፡
                           ሕያዎ፡</hi></q></desc></decoNote>
                     <decoNote xml:id="d5" type="miniature">
                        <locus target="#5r"/>
                        <desc><ref type="authFile" corresp="AT1021MiraclesOfJesus">Jesus heals
                                 <persName ref="PRS7805Peter">St. Peter´s</persName>
                              mother-in-law.</ref>
                           <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ፈወሳ፡ ለሐማት፡ ጴጥሮስ፡
                              እምፈታጸንታ፡</hi></q></desc></decoNote>
                     <decoNote xml:id="d6" type="miniature">
                        <locus target="#6v"/>
                        <desc><persName ref="PRS5684JesusCh"/> casts out a <term key="demon"/>. <q
                              xml:lang="gez"><hi rend="rubric">ዘከመ፡ አዉፅአሙ፡ እግዚእነ፡ ለአጋንንት፡ እምላዕለ፡
                                 ሰብእ።</hi></q></desc></decoNote>
                     <decoNote xml:id="d7" type="miniature">
                        <locus target="#7r"/>
                        <desc><persName ref="PRS5684JesusCh"/> tells to the scribe and the Disciple
                           to follow Him. <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ይቤሎሙ፡ እግዚእነ፡
                                 ለጸሐፊ፡ ወለረድእ፡ ንዑ፡ ትልዉኒ።</hi></q></desc></decoNote>
                     <decoNote xml:id="d8" type="miniature">
                        <locus target="#8v"/>
                        <desc><persName ref="PRS5684JesusCh"/> in the boat. <q xml:lang="gez"><hi
                                 rend="rubric">ዘከመ፡ ኖመ፡ እግዚእነ፡ መልዕልተ፡ ሐመር፡ ወዘከመ፡ አንቅሕዎ፡ ሐዋርያት፡
                                 አምፍርሃት፡ ማዕበል።</hi></q></desc></decoNote>
                     <decoNote xml:id="d9" type="miniature">
                        <locus target="#9v"/>
                        <desc><ref type="authFile" corresp="AT1021MiraclesOfJesus">Jesus heals a
                              leper in Gergesa who were possessed by demons.</ref>
                           <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ፈወሰ፡ ድዉያነ፡ እለ፡ ቦሙ፡ አ<supplied
                                    reason="lost">ጋ</supplied>ንንት፤</hi></q>
                        </desc></decoNote>
                     <decoNote xml:id="d10" type="miniature">
                        <locus target="#10r"/>
                        <desc><persName ref="PRS5684JesusCh"/> sends <term key="demon">demons</term>
                           into <term key="animal">pigs</term>. <q xml:lang="gez"><hi rend="rubric"
                                 >ዘከመ፡ አብሐሙ፡ ለአጋንንት፡ ይባኡ፡ ዉስተ፡ አኀርዉ።</hi>
                           </q></desc></decoNote>
                     <decoNote xml:id="d11" type="miniature">
                        <locus target="#11r"/>
                        <desc><ref type="authFile" corresp="AT1074JesusHealsParalytic"/></desc>
                        <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ነስቱ፡ ጠፈረ፡ ወዘከመ፡ ፈወሶ፡
                           ለመፃጉዕ፡</hi></q></decoNote>
                     <decoNote xml:id="d12" type="miniature">
                        <locus target="#12v"/>
                        <desc>The supper in <persName ref="PRS8854Simeon">Simeon´s</persName>
                           house.</desc>
                        <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ገብረ፡ መሳሐ፡ ፡ በቤተ፡
                        ስምዖን፤</hi></q></decoNote>
                     <decoNote xml:id="d13" type="miniature">
                        <locus target="#13r"/>
                        <desc><persName ref="PRS5684JesusCh"/> is asked to visit a dead girl.</desc>
                        <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ሰአሎ፡ <choice>
                                 <sic>መኮንን፡</sic>
                                 <corr>መኮነን፡</corr>
                              </choice> በእንተ፡ ደዌሃ፡ ወለቱ።</hi></q></decoNote>
                     <decoNote xml:id="d14" type="miniature">
                        <locus target="#13v"/>
                        <desc><ref type="authFile" corresp="AT1021MiraclesOfJesus">The woman with
                              the hemorrhage.</ref> The centurion asks <persName
                              ref="PRS5684JesusCh"/> to heal his daughter. <q xml:lang="gez"><hi
                                 rend="rubric">ዘከመ፡ ገሰሰት፡ ጽንፈ፡ ልብሱ፡ እንተ፡ ደም፡ ይዉኅዘ። ወዘከመ፡ ነገሮ፡ መስፍን፡
                                 ጽንዓ፡ ደዌሃ፡ ለወለቱ</hi></q></desc></decoNote>
                     <decoNote xml:id="d15" type="miniature">
                        <locus target="#14v"/>
                        <desc><ref type="authFile" corresp="AT1021MiraclesOfJesus">The resurrection
                              of the daughter of the centurion.</ref>
                           <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ ፈወሳ፡ እግዚእነ፡ ለወለተ፡
                           መስፍን፡</hi></q></desc></decoNote>
                     <decoNote xml:id="d16" type="miniature">
                        <locus target="#15v"/>
                        <desc><ref type="authFile" corresp="AT1070JesushealstheBlind"/></desc>
                        <q xml:lang="gez"><hi rend="rubric">ዘከመ፡ አብርሃ፡ አዕይንቲሆሙ፡ ለዕዉራን፡
                           እግዚእነ፡</hi></q></decoNote>
                     <decoNote xml:id="d17" type="miniature">
                        <locus target="#16v"/>
                        <desc><persName ref="PRS5684JesusCh"/> heals the mute and possessed man. <q
                              xml:lang="gez"><hi rend="rubric">ዘከመ፡ ፈወሳ፡ ለጽሙም፡ ወዘከመ፡ ገሠጸ፡
                              ለጋኔን፤</hi></q></desc></decoNote>
                     <decoNote xml:id="d18" type="miniature">
                        <locus target="#17r"/>
                        <desc><persName ref="PRS5684JesusCh"/> confers power on the Apostles. <q
                              xml:lang="gez"><hi rend="rubric">ዘከመ፡ ወሀቦሙ፡ እግዚእነ፡ ለሐዋርያት፡
                              ሥልጣነ፤</hi></q></desc></decoNote>
                     <decoNote xml:id="d19" type="miniature">
                        <locus target="#20r"/>
                        <desc>The Disciples gather grain during Sabbath.</desc></decoNote>
                     <decoNote xml:id="d20" type="miniature">
                        <locus target="#21v"/>
                        <desc><ref type="authFile" corresp="AT1021MiraclesOfJesus">The miracle of a
                              withered hand.</ref></desc></decoNote>
                     <decoNote xml:id="d21" type="miniature">
                        <locus target="#22r"/>
                        <desc><persName ref="PRS5684JesusCh"/> disputes with the
                        Pharisees.</desc></decoNote>
                     <decoNote xml:id="d22" type="miniature">
                        <locus target="#23r"/>
                        <desc><persName ref="PRS5684JesusCh"/> before Caiaphas.</desc></decoNote>
                     <decoNote xml:id="d23" type="miniature">
                        <locus target="#24r"/>
                        <desc><ref type="authFile" corresp="AT1023Mocking"/></desc></decoNote>
                     <decoNote xml:id="d24" type="miniature">
                        <locus target="#25r"/>
                        <desc>Flagellation.</desc></decoNote>
                     <decoNote xml:id="d25" type="miniature">
                        <locus target="#26r"/>
                        <desc><persName ref="PRS5684JesusCh"/> takes the <term key="cross"/> on his
                           shoulders. <persName ref="PRS7928Pontius"/> washes his
                        hands.</desc></decoNote>
                     <decoNote xml:id="d26" type="miniature">
                        <locus target="#27r"/>
                        <desc>The Cyrenean helps <persName ref="PRS5684JesusCh"/>.</desc></decoNote>
                     <decoNote xml:id="d27" type="miniature">
                        <locus target="#28r"/>
                        <desc/>Longinus wounds <persName ref="PRS5684JesusCh"/> while He is on the
                           <term key="cross"/>.</decoNote>
                     <decoNote xml:id="d28" type="miniature">
                        <locus target="#28v"/>
                        <desc><persName ref="PRS13687JosephArim"/> asks <persName
                              ref="PRS7928Pontius"/> for the <term key="deadjesus">corpse of
                              Jesus</term>.</desc></decoNote>
                     <decoNote xml:id="d29" type="miniature">
                        <locus target="#29r"/>
                        <desc><ref type="authFile" corresp="AT1007Deposition"/> and <ref
                              type="authFile" corresp="AT1010Entombment"/>.</desc></decoNote>
                     <decoNote xml:id="d30" type="miniature">
                        <locus target="#30r"/>
                        <desc><ref type="authFile" corresp="AT1049Resurrection"/>.</desc></decoNote>
                     <decoNote xml:id="d31" type="miniature">
                        <locus target="#31r"/>
                        <desc>An <term key="angel"/> announces the Resurrection to holy women.
                              <persName ref="PRS5684JesusCh"/> appears to the
                        Disciples.</desc></decoNote>
                     <decoNote type="frame" xml:id="d32">
                        <locus target="#3v #6r #10vb #15rb #16rb #18v #22r #21r #27rb"/>
                        <desc>Narrow ornamental bands of black and red dots.</desc>
                     </decoNote>
