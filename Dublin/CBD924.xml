                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus target="#1v"/>
                           <desc type="GuestText"><title ref="LIT7713FeastsApostles"/></desc>
                        </item>
                        <item xml:id="a2">
                           <locus target="#1vb"/>
                           <desc type="OwnershipNote">A short ownership note mentioning <persName
                                 ref="PRS15416AbtaGabr"/>, <persName ref="PRS15414WaldaM"/>,
                                 <persName ref="PRS15424WalattaTsion"/>, <persName
                                 ref="PRS15425WalattaYoh"/>, and <persName
                                 ref="PRS15426WalattaKidan"/>. The note was added later and is
                              written in rough-and-ready fashion, probably by the same hand as <ref
                                 target="#a3"/>. </desc>
                        </item>
                        <item xml:id="a3">
                           <locus target="#51v #136r"/>
                           <desc>Two supplications written in the gaps of <ref target="#ms_i2"/> in
                              rough-and-ready fashion, probably by the same hand as <ref
                                 target="#a2"/>. The first one mentions <persName
                                 ref="PRS15413GabraHeywet"/>, <persName ref="PRS15415WalattaIya"/>,
                                 <persName ref="PRS15416AbtaGabr"/> and <persName
                                 ref="PRS15417WalattaWanas"/>. The second one mentions <persName
                                 ref="PRS15413GabraHeywet"/> and his kins. </desc>
                        </item>
                        <item xml:id="a4">
                           <locus target="#148rb"/>
                           <desc type="ProtectivePrayer">Protective prayer mentioning names of <persName
                                 ref="PRS6819Mary"/> in different languages including Arabic, Hebrew
                              and Coptic. </desc>
                           <q xml:lang="gez">ስማ፡ ለእዝእትነ፡ ማርያም፡ በዓረቢ፡ ዕድራ፡ በዕብራይስጢ፡ ማሪሃም፡ በቅብጢ፡ ሶልያና፡
                              በሱርስት፡ ሳይዳ፡ በዕብራዉያን፡ በጊሮማ፡ በሮም፡ በር<gap reason="illegible"/>ማር፡ በዝንቱ፡
                              ስምኪ፡ ተማኀፀንኩ፡</q>
                        </item>
                        <item xml:id="a5">
                           <locus from="150ra8" to="151rb"/>
                           <desc type="MagicText">Magic prayer against bad weather, containing <term key="Asmat">ʾasmāt</term>.</desc>
                           <q xml:lang="gez">በስመ፡ <gap reason="ellipsis" resp="ESh"/> አርሞጽን፡ መላከ፡
                              በረድ፡ ዘእንበላ፡ ጹሩ፡ ማይ። ውስተ፡ ሰብከትየ፡ እግሌ። ዘያስተጋብአ፡ ዝቅ፡ ለማየ፡ ባሕር፡ <gap
                                 reason="ellipsis" resp="ESh"/></q>
                        </item>
                        <item xml:id="a6">
                           <locus target="#151v"/>
                           <desc type="MagicText">Magic prayer containing <term key="Asmat"
                              />.</desc>
                           <q xml:lang="gez">በስመ፡ አብ፡ በል፡ ወሶበ፡ <gap reason="illegible"/> ይዝልእ፡ ውስተ፡
                              ልብየ፡ ቃል፡ እግዚአብሔር፡ ሥላሴ፡ ዋህድ፡ አፍአኪር፡ <gap reason="illegible"/> አዳታኤል፡
                              በዝንቱ፡ አስማት፡</q>
                        </item>
                        <item xml:id="e1">
                           <locus target="#1r #1v #151rb"/>
                           <desc>Pen trial.</desc>
                        </item>
                     </list>
