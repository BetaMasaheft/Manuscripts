                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script" cert="medium">Late eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, chapter numbers, incipits, some
                           punctuation marks, some Ethiopic numerals as well as supplicants’
                           names.</seg>
                        <desc>Regular, neat, careful.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1" type="miniature">
                        <locus target="#1r"/>
                        <desc>The Lord appears to <persName ref="PRS7181MosesM"/>.</desc></decoNote>
                     <decoNote xml:id="d2" type="miniature">
                        <locus target="#2v"/>
                        <desc>The <term key="angel">Angel</term> expels Adam and Eve from
                           Eden.</desc></decoNote>
                     <decoNote xml:id="d3" type="miniature">
                        <locus target="#3v"/>
                        <desc>The Magi adore <persName ref="PRS5684JesusCh">Infant
                           Jesus</persName>.</desc></decoNote>
                     <decoNote xml:id="d4" type="miniature">
                        <locus target="#4v"/>
                        <desc>A miniature of Lord revealing to <persName ref="PRS3417David"/> the
                           Nativity of <persName ref="PRS6819Mary"/> at the top. A miniature of <ref
                              type="authFile" corresp="AT1031VirginAndChild"/> and <ref
                              type="authFile" corresp="AT1020Massacre"/> at the bottom. Traces of
                              <term key="protectiveCurtain"/>.</desc></decoNote>
                     <decoNote xml:id="d5" type="miniature">
                        <locus target="#5r"/>
                        <desc>A miniature of <persName ref="PRS6819Mary"/> and two <term key="angel"
                              >angels</term>. Traces of <term key="protectiveCurtain"
                        />.</desc></decoNote>
                     <decoNote xml:id="d6" type="miniature">
                        <locus target="#7r"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"/>,
                           adored by people.</desc></decoNote>
                     <decoNote xml:id="d7" type="miniature">
                        <locus target="#7v"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1002Annunciation"
                           />.</desc></decoNote>
                     <decoNote xml:id="d8" type="miniature">
                        <locus target="#8r"/>
                        <desc>A miniature of the <ref type="authFile" corresp="AT1031VirginAndChild"
                           /> and an <term key="angel"/>.</desc></decoNote>
                     <decoNote xml:id="d9" type="miniature">
                        <locus target="#8va"/>
                        <desc>A miniature of the <ref type="authFile" corresp="AT1031VirginAndChild"
                           />. Infant Jesus is portrayed as a <term key="animal"
                        >lamb</term>.</desc></decoNote>
                     <decoNote xml:id="d10" type="miniature">
                        <locus target="#8vb"/>
                        <desc>A miniature of the Sacred Family.</desc></decoNote>
                     <decoNote xml:id="d11" type="miniature">
                        <locus target="#9r"/>
                        <desc>A miniature of Jacob's ladder at the top and <persName
                              ref="PRS6819Mary"/> at the bottom.</desc></decoNote>
                     <decoNote xml:id="d12" type="miniature">
                        <locus target="#9vb"/>
                        <desc> A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"
                           />.</desc></decoNote>
                     <decoNote xml:id="d13" type="miniature">
                        <locus target="#9va"/>
                        <desc> A miniature of a Tabernacle.</desc></decoNote>
                     <decoNote xml:id="d14" type="miniature">
                        <locus target="#10r"/>
                        <desc>A miniature of <persName ref="PRS6819Mary"/> and Syrian
                        Potter.</desc></decoNote>
                     <decoNote xml:id="d15" type="miniature">
                        <locus target="#10v"/>
                        <desc>The Syrian Potter sings to <persName ref="PRS6819Mary"
                        /></desc></decoNote>
                     <decoNote xml:id="d16" type="miniature">
                        <locus target="#11r"/>
                        <desc>A miniature of the Syrian Potter, <ref type="authFile"
                              corresp="AT1030Trinity"/> and <persName ref="PRS6819Mary"/>.
                        </desc></decoNote>
                     <decoNote xml:id="d17" type="miniature">
                        <locus target="#11v"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"/>,
                           adored by people.</desc></decoNote>
                     <decoNote xml:id="d18" type="miniature">
                        <locus target="#12r"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"/>
                           and the Temple Lampstand.</desc></decoNote>
                     <decoNote xml:id="d19" type="miniature">
                        <locus target="#12v"/>
                        <desc>Two miniatures of <ref type="authFile" corresp="AT1031VirginAndChild"
                           /> and a miniature of <persName ref="PRS3417David"/> burning
                           incense.</desc></decoNote>
                     <decoNote xml:id="d20" type="miniature">
                        <locus target="#14r"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"/>,
                           adored by <term key="angel">angels</term>. </desc></decoNote>
                     <decoNote xml:id="d21" type="miniature">
                        <locus target="#13v"/>
                        <desc>A miniature of <persName ref="PRS1002Aaron"/> and his
                        rod.</desc></decoNote>
                     <decoNote xml:id="d22" type="miniature">
                        <locus target="#13r"/>
                        <desc>A miniatures of a blooming tree and of <ref type="authFile"
                           corresp="AT1041HolyMen">two Holy Men, one of whom is <persName
                              ref="PRS3417David"/></ref> on the left. A miniature of <ref
                              type="authFile" corresp="AT1031VirginAndChild"/> on the
                        right.</desc></decoNote>
                     <decoNote xml:id="d23" type="miniature">
                        <locus target="#15r"/>
                        <desc>The Syrian Potter dies and <persName ref="PRS6819Mary"/> carries his
                           soul to Paradise.</desc></decoNote>
                     <decoNote xml:id="d24" type="miniature">
                        <locus target="#15v"/>
                        <desc>Three <term key="bird">birds</term> announce to a <persName
                              ref="PRS3417David">young boy</persName> that he will become
                           king.</desc></decoNote>
                     <decoNote xml:id="d25" type="miniature">
                        <locus target="#16r"/>
                        <desc>f. 16 r: Un Angelo appare al Re sul trono. Cavalli condotti innanzi al
                           Re</desc></decoNote>
                     <decoNote xml:id="d26" type="miniature">
                        <locus target="#16v"/>
                        <desc>The Syrian Potter sings to <persName ref="PRS6819Mary"/>. Traces of
                              <term key="protectiveCurtain"/>. </desc></decoNote>
                     <decoNote xml:id="d27" type="miniature">
                        <locus target="#18r"/>
                        <desc>A miniature of the <ref type="authFile" corresp="AT1025NativityJesus"
                           /> at the top. A miniature of an <term key="angel"/> announcing the birth
                           of Jesus to the shepherds and their <term key="animal">cattle</term> at
                           the bottom.</desc></decoNote>
                     <decoNote xml:id="d28" type="miniature">
                        <locus target="#19r"/>
                        <desc>A miniature of <persName ref="PRS6819Mary"/> and two <term key="angel"
                              >Angels</term> at the top. A miniature of <ref type="authFile"
                              corresp="AT1066DavidHarp"/> at the bottom.</desc></decoNote>
                     <decoNote xml:id="d29" type="miniature">
                        <locus target="#19v"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"/>
                           and an <term key="angel"/> at the top. A miniature of <persName
                              ref="PRS3417David"/> at the bottom. The white cotton <term
                              key="protectiveCurtain"/> is sewn on the top with green and blue
                           threads.</desc></decoNote>
                     <decoNote xml:id="d30" type="miniature">
                        <locus target="#21v"/>
                        <desc>A miniature of the <ref type="authFile" corresp="AT1025NativityJesus"
                           /> and the defeat of the Devil.</desc></decoNote>
                  </decoDesc>
