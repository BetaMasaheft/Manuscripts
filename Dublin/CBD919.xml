                  <additions>
                     <list>

                        <item xml:id="a1"><locus target="#21vb"/>
                           <desc type="MagicText">Magic prayer against various diseases including
                              stomach ache and bleeding, mentioning <term key="demon">Bāryā</term>
                              and containing a supplication for <persName ref="PRS15402TasfaM"
                              />.</desc>
                           <q xml:lang="gez">በሰመ፡<gap reason="ellipsis" resp="ESh"/> አብ፡ እሳት፡ በአካሉ፡
                              ወልድ፡ እሳት፡ በአካሉ፡ መንፈስ፡ ቅዱስ፡ እሳት፡ በአካሉ፡ በዝንቱ፡ አስማት፡ ዘአድራዕከ፡ ግብር፡ ለዲያብሎስ፡
                              ከማሁ፡ አጽረዕ፡ ሕማመ፡ ባርያ፡  ዓይነት፡ ወውግዓት፡ ቁርፀት፡ <gap
                                 reason="ellipsis" resp="ESh"/></q>
                        </item>
                        <item xml:id="a2"><locus target="#44va"/>
                           <desc type="MagicText">Magic prayer against stomach ache, mentioning
                                 <term key="demon">Dask</term>. The prayer is interrupted in the middle
                              of a sentence.</desc>
                           <q xml:lang="gez">ጸሎተ፡ <choice>
                                 <sic>ውግዳት፡</sic>
                                 <corr>ውግአት፡</corr>
                              </choice> በለምለም፡ ዘፈቃ፡ በደምደም፡ ዘፈቅ<gap reason="illegible"/>፡ በሚን፡ ዕፅ፡
                              አመ፡ <gap reason="ellipsis" resp="ESh"/></q>
                        </item>
                        <item xml:id="a3"><locus target="#57v"/>
                           <desc type="GuestText">A fragment of a prayer. Its text is mostly
                              illegible due to a parchment tear and ink fading.</desc>
                           <q xml:lang="gez">በሰመ፡<gap reason="ellipsis" resp="ESh"/> አናንያ፡ ወአዛርያ፡
                              ወ<choice><sic>ሚካኤል፡</sic><corr>ሚሳኤል፡</corr></choice> አምላከ፡ ስድራቅ፡ ወሚሳቅ፡ ወአብድናጎ፡ አምላኩ፡ ለቅዱስ፡ ጊዮርጊስ፡ ወለአቡነ፡ ገብረ፡ መንፈስ፡
                              ቅዱስ፡ ዘወሀበከ፡ እግዚአብሔር፡ <gap reason="ellipsis" resp="ESh"/></q>
                        </item>
                        <item xml:id="e1">
                           <locus target="#2r"/>
                           <desc type="StampExlibris">An Arabic stamp; its text is not readable due
                              to a poor quality of the images and its fading.</desc>
                        </item>
                        <item xml:id="e2">
                           <locus target="#51v"/>
                           <desc>Spaces left for a male name are left blanc.</desc>
                        </item>

                     </list>
                  </additions>
