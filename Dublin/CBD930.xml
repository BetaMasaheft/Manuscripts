                  <handDesc>

                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="3r" to="37r"/>
                        <seg type="script">Early eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, incipits, punctuation marks, Ethiopic
                           numerals and the supplicants’ names.</seg>
                        <desc>Regular, neat, careful, small square letters; copied by the <persName role="scribe"
                              ref="PRS15460GabraHeywat"/>.</desc></handNote>
                     <handNote xml:id="h2" script="Ethiopic">
                        <locus from="37v" to="104v"/>
                        <seg type="script">Eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, incipits, punctuation marks, Ethiopic
                           numerals and the supplicants’ names.</seg>
                        <desc>Regular, neat, careful, larger round letters with more space between
                           them; copied by the <persName role="scribe" ref="PRS15462WaldaGabr"/>. Despite clear
                           differences in style between <ref target="#h1"/> and <ref target="#h2"/>,
                           the transition is smooth and, therefore, precisely not
                           identifiable.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1" type="drawing">
                        <locus target="#1v"/>
                        <desc>A drawing of a warrior with a long spear, in pencil. Based on its
                           highly realistic anatomical features and the use of pencil, the drawing
                           was probably added later to the manuscript and was made not by the
                           same artist(s) who painted miniatures.</desc>
                     </decoNote>
                     <decoNote xml:id="d2" type="drawing">
                        <locus target="#2r"/>
                        <desc>An unfinished pencil drawing of several warriors with <term key="sword"
                              >swords</term>, made by the same artist as <ref
                              target="#d1"/>.</desc>
                     </decoNote>
                     <decoNote xml:id="d3" type="headpieceBand">
                        <locus target="#3r"/>
                        <desc>An elaborate black outline for a horizontal ornamental band (ḥarag)
                           over columns a–b, featuring interlaces, cross-shaped flowers, with three
                           lateral extensions and an eye in the middle of the band.</desc>
                     </decoNote>
                     <decoNote xml:id="d4" type="drawing">
                        <locus target="#69r"/>
                        <desc>A simple unfinished pencil drawing of a face.</desc>
                     </decoNote>
                     <decoNote xml:id="d5" type="drawing">
                        <locus target="#77v"/>
                        <desc>A sketch drawing of <ref target="#d20"/>, in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d6" type="headpieceBand">
                        <locus target="#103r"/>
                        <desc>An outline for two horizontal ornamental bands (ḥarags), over each
                           column one, featuring interlaces, with four lateral extensions
                           each.</desc>
                     </decoNote>
                     <decoNote xml:id="d7" type="drawing">
                        <locus target="#105r"/>
                        <desc>A drawing of three <term key="animal">lions</term>, one in ink and two
                           in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d8" type="drawing">
                        <locus target="#105v"/>
                        <desc>An outline of three horizontal ornamental bands (ḥarags), featuring
                           interlaces, with shadows, along with an outline of an elaborate <term
                              key="cross">cross</term>; a few doodlings, all in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d9" type="miniature">
                        <locus target="#12v"/>
                        <desc>Two miniatures belonging to the <term key="FirstGondarineStyle"/> in a
                           double red frame. In the first one, <persName ref="PRS7049Michael"/> on a
                              <term key="animal">horse</term> with soldiers appears to Joshua. In
                           the second one, <persName ref="PRS7049Michael"/> appears to a shepherd. 
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d10" type="miniature">
                        <locus target="#18v"/>
                        <desc>A miniature in a double red frame depicting <persName ref="PRS15488Longinus"/> wounding
                              the crucified <persName ref="PRS5684JesusCh"/>
                           in the presence of <persName ref="PRS6819Mary"/> and <persName
                              ref="PRS5741Johnthe"/>. The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d11" type="miniature">
                        <locus target="#27v"/>
                        <desc>A miniature in a double red frame depicting the miracle of
                           the jewel found in the <term key="animal">fish</term>.
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d12" type="miniature">
                        <locus target="#31v"/>
                        <desc>Two miniatures in a single double red frame depicting the miracle of the
                           boat and the miracle of Qison at the door of the church of <persName
                              ref="PRS7049Michael">Saint Michael</persName>, respectively.
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d13" type="miniature">
                        <locus target="#45v"/>
                        <desc>A miniature in a double red frame depicting <persName ref="PRS4585Georgeo"/> killing the <term
                              key="dragon"/>. Traces of the <term key="protectiveCurtain"/>.</desc>
                     </decoNote>
                     <decoNote xml:id="d14" type="miniature">
                        <locus target="#46v"/>
                        <desc>A miniature in a double red frame depicting <ref type="authFile" corresp="AT1031VirginAndChild"/>
                           with two <term key="angel">angels</term>, <persName ref="PRS7049Michael"
                           /> and <persName ref="PRS4377Gabriel"/> as well as  <persName role="patron"
                              ref="PRS15461ZawaldaMaryam"/>
                           prostrating before Them. 
                        <q xml:lang="gez">ቅዱስ፡ ሚካኤል። ቅዱስ፡ ገብርኤል። ዘከመ፡ ተማኀጸኑ፡ መምህር፡ ዘወልደ፡ ማርያም።</q>
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d15" type="miniature">
                        <locus target="#52v"/>
                        <desc>A miniature in a double red frame depicting <persName ref="PRS5720JohnChr"/> before a group of people.</desc>
                     </decoNote>
                     <decoNote xml:id="d16" type="miniature">
                        <locus target="#55v"/>
                        <desc>A miniature in a double red frame depicting <persName ref="PRS7049Michael"
                        /> spearing the <term key="demon">devil</term> who was trying to throttle <persName ref="PRS14019Euphemia"/>.
                        <q xml:lang="gez">ቅዱስ፡ ሚካኤል። አፎምያ፡ ሰይጣን።</q>
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d17" type="miniature">
                        <locus target="#63v"/>
                        <desc>A miniature in a double red frame depicting a rich man and his two poor neighbors.
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia. </desc>
                     </decoNote>
                     <decoNote xml:id="d18" type="miniature">
                        <locus target="#69v"/>
                        <desc>A miniature in a double red frame depicting <persName ref="PRS7049Michael"
                        /> bringing souls to judgement before <persName ref="PRS5684JesusCh"
                        />.
                           <q xml:lang="gez">እግዚእነ፡ ኢየሲስ። ቅዱስ፡ ሚካኤል።</q>
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d19" type="miniature">
                        <locus target="#73v"/>
                        <desc>A miniature in a double red frame depicting the small chest filled with money that was sent to the poor man by <persName ref="PRS7049Michael"/>.
                        <q xml:lang="gez">እግዚእነ። ሰይጣን። ሣፅን፤ አሣ፤ ጉማራ።</q>
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d20" type="miniature">
                        <locus target="#77r"/>
                        <desc>A miniature in a double red frame depicting <persName ref="PRS5584Isaiah"/> healing <persName ref="PRS5680Jeremiah"/> by pouring water on his head.
                        <q xml:lang="gez">ቅዱስ፡ ሚካኤል። ኢሳያስ። ሕዝያስ።</q>
                           The white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia. </desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        
                        <item xml:id="a1">
                           <locus target="#2r"/>
                           <desc>Sale note mentioning <persName ref="PRS15463AmataWald"/> and
                                 <persName ref="PRS15464AbbaWaldaAr"/>. It is not fully clear what
                                 <foreign xml:lang="am">ጨበር፡</foreign> means in this context.</desc>
                           <q xml:id="am">ለአመተ፡ ወልደ፡ አረጋዊ፡ ፩ቀን፡ ለአባ፡ ወልደ፡ አረጋዊ፡ ፩ጨበር፡ ማላሻ፡ ፪ጨበር፡</q>
                        </item>
                        <item xml:id="a2">
                           <locus target="#73ra"/>
                           <desc>Sale note written in pencil. Its text is faded and hardly
