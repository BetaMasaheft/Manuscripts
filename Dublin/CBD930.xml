                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards.</decoNote>
                        <decoNote xml:id="b2" type="Cover">Reddish brown tooled leather cover with
                           bright pink <term key="inlay">textile inlays</term> with a geometrical
                           green-and-yellow pattern. The <term key="tooling">blind tooled
                              ornament</term> includes <term key="cross">crosses</term>, <term
                              key="doubleStraightLine">double line fillets</term>, <term
                              key="doubleCircle">double circles</term>, <term key="interlace"
                              >interlaces</term>, and other ornamental elements.</decoNote>
                        <decoNote xml:id="b3" type="Sewing">Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b4" type="SewingStations">4</decoNote>
                        <decoNote xml:id="b5" type="Endbands">Endbands are present, the tailband is
