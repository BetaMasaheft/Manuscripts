                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                           <note>The holes in <locus
                                 target="#1 #33 #39 #42 #43 #50 #52 #64 #67 #68 #69 #77 #79"/> have
                              been sewn up, while the ones in <locus
                                 target="#11 #17 #61 #94 #98 #99 #100"/> have been carefully
                              amended.</note>
                        </support>
                        <extent>
                           <measure unit="leaf" quantity="105">105</measure>
                           <measure unit="page" type="blank">4</measure>
                           <locus target="#1r #2v #27r #46r"/>
                           <dimensions type="outer" unit="mm">
                              <height unit="mm">360</height>
                              <width unit="mm">269</width>
                           </dimensions>
                        </extent>
                        <foliation>Foliation is provided by the library and is marked in pencil on
                           the upper right edge of the recto of each folium.</foliation>
                        <condition key="good">Despite some fungus stains (e.g., on <locus
                              target="#17v #18r #68v"/>) and the general dirtiness of several folia,
                           the text is fully readable and all iluminations are well preserved. The
                           tailband is slightly damaged. The leather cover is slightly worn at the
                           corners.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="19">
                           <ab type="ruling">Ruling is visible.</ab>
