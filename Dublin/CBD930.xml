                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                           <note>The holes in <locus
                                 target="#1 #33 #39 #42 #43 #50 #52 #64 #67 #68 #69 #77 #79"/> have
                              been sewn up, while the ones in <locus
                                 target="#11 #17 #61 #94 #98 #99 #100"/> have been carefully
                              amended.</note>
                        </support>
                        <extent>
                           <measure unit="leaf" quantity="105">105</measure>
                           <measure unit="page" type="blank">4</measure>
                           <locus target="#1r #2v #27r #46r"/>
                           <dimensions type="outer" unit="mm">
                              <height unit="mm">360</height>
                              <width unit="mm">269</width>
                           </dimensions>
                        </extent>
                        <foliation>Foliation is provided by the library and is marked in pencil on
                           the upper right edge of the recto of each folium.</foliation>
                        <condition key="good">Despite some fungus stains (e.g., on <locus
                              target="#17v #18r #68v"/>) and the general dirtiness of several folia,
                           the text is fully readable and all complete iluminations including their
                           protective curtains are well preserved. The tailband is slightly damaged.
                           The leather cover is slightly worn at the corners.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="2" writtenLines="19">
                           <ab type="ruling">Ruling is visible.</ab>
                           <ab type="ruling" subtype="pattern">1A-1A-1A1A/0-0/0-0/C</ab>
                           <ab type="pricking">Pricking is visible.</ab>
                           <ab type="pricking">Primary pricks are partly visible.</ab>
                           <ab type="pricking">Ruling pricks are partly visible.</ab>
                           <ab type="ruling">The upper line is written above the ruling.</ab>
                           <ab type="ruling">The bottom line is written above the ruling.</ab>
                        </layout>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>

                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="3r" to="37r"/>
                        <seg type="script">Early eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, incipits, punctuation marks, Ethiopic
                           numerals and the supplicant’s names.</seg>
                        <desc>Regular, neat, careful, small square letters; copied by <persName
                              ref="PRS15460GabraHeywat"/>.</desc>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">
                        <locus from="37v" to="104v"/>
                        <seg type="script">Eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, incipits, punctuation marks, Ethiopic
                           numerals and the supplicant’s names.</seg>
                        <desc>Regular, neat, careful, larger round letters with more space between
                           them; copied by <persName ref="PRS15462WaldaGabr"/>. Despite clear
                           differences in style between <ref target="#h1"/> and <ref target="#h2"/>,
                           the transition is smooth and, therefore, precisely not
                           identifiable.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1" type="drawing">
                        <locus target="#1v"/>
                        <desc>A drawing of a warrior with a long spear, in pencil. According to its
                           highly realistic anatomical features and the pencil usage, the drawing
                           has been probably added later to the manuscript and was made not by the
                           same artist(s) who painted finished illuminations.</desc>
                     </decoNote>
                     <decoNote xml:id="d2" type="drawing">
                        <locus target="#2r"/>
                        <desc>An uncompleted drawing of several warriors with <term key="sword"
                              >swords</term>, in pencil, made by the same artist as <ref
                              target="#d1"/>.</desc>
                     </decoNote>
                     <decoNote xml:id="d3" type="headpieceBand">
                        <locus target="#3r"/>
                        <desc>An elaborate black outline for a horizontal ornamental band (ḥarag)
                           over columns a–b, featuring interlaces, cross-shaped flowers, with three
                           lateral extensions and an eye in the middle of the band.</desc>
                     </decoNote>
                     <decoNote xml:id="d4" type="drawing">
                        <locus target="#69r"/>
                        <desc>A simple uncompleted drawing of a face, in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d5" type="drawing">
                        <locus target="#77v"/>
                        <desc>A sketch drawing of <ref target="#d20"/>, in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d6" type="headpieceBand">
                        <locus target="#103r"/>
                        <desc>An outline for two horizontal ornamental bands (ḥarags), over each
                           column one, featuring interlaces, with four lateral extensions
                           each.</desc>
                     </decoNote>
                     <decoNote xml:id="d7" type="drawing">
                        <locus target="#105r"/>
                        <desc>A drawing of three <term key="animal">lions</term>, one in ink, two
                           others in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d8" type="drawing">
                        <locus target="#105v"/>
                        <desc>An outline of three horizontal ornamental bands (ḥarags), featuring
                           interlaces, with shadows, along with an outline of an elaborate <term
                              key="cross">cross</term> and some doodlings, all in pencil.</desc>
                     </decoNote>
                     <decoNote xml:id="d9" type="miniature">
                        <locus target="#12v"/>
                        <desc>Two miniatures belonging to the <term key="FirstGondarineStyle"/> in a
                           double red frame. In the first one, <persName ref="PRS7049Michael"/> on a
                              <term key="animal">horse</term> with soldiers appears to Joshua. In
                           the second one, <persName ref="PRS7049Michael"/> to a shepherd. Here and
                           everywhere below, the white cotton <term key="protectiveCurtain"/> is
                           sewn to the top of the folia.</desc>
                     </decoNote>
                     <decoNote xml:id="d10" type="miniature">
                        <locus target="#18v"/>
                        <desc>A miniature, portraying Longinus wounding
                              <persName ref="PRS5684JesusCh"/>, while He is on the <term key="cross"
                           />, in the presence of <persName ref="PRS6819Mary"/> and <persName
                              ref="PRS5741Johnthe"/>. Here and everywhere below, miniatures have a double red frame.</desc>
                     </decoNote>
                     <decoNote xml:id="d11" type="miniature">
                        <locus target="#27v"/>
                        <desc>A miniature, illustrating the miracle of
                           the jewel found in the <term key="animal">fish</term>.</desc>
                     </decoNote>
                     <decoNote xml:id="d12" type="miniature">
                        <locus target="#31v"/>
                        <desc>Two miniatures that illustrate the miracle of the
                           boat and the miracle of Qison at the door of the Church of <persName
                              ref="PRS7049Michael"/>, respectively.</desc>
                     </decoNote>
                     <decoNote xml:id="d13" type="miniature">
                        <locus target="#45v"/>
                        <desc>A miniature of <persName ref="PRS4585Georgeo"/> killing the <term
                              key="dragon"/>. Traces of the <term key="protectiveCurtain"/>.</desc>
                     </decoNote>
                     <decoNote xml:id="d14" type="miniature">
                        <locus target="#46v"/>
                        <desc>A miniature of <ref type="authFile" corresp="AT1031VirginAndChild"/>
                           with two <term key="angel">angels</term>, <persName ref="PRS7049Michael"
                           /> and <persName ref="PRS4377Gabriel"/>, and <persName
                              ref="PRS15461ZawaldaMaryam"/>, the owner of the manuscript,
                           prostrating before Them.</desc>
                        <q xml:lang="gez">ቅዱስ፡ ሚካኤል። ቅዱስ፡ ገብርኤል። ዘከመ፡ ተማኀጸኑ፡ መምህር፡ ዘወልደ፡ ማርያም።</q>
                     </decoNote>
                     <decoNote xml:id="d15" type="miniature">
                        <locus target="#52v"/>
                        <desc>A miniature of <persName ref="PRS5720JohnChr"/> before people.</desc>
                     </decoNote>
                     <decoNote xml:id="d16" type="miniature">
                        <locus target="#55v"/>
                        <desc>A miniature, portraying <persName ref="PRS7049Michael"
                        /> spearing the <term key="demon">devil</term> who was trying to throttle <persName ref="PRS14019Euphemia"/>.</desc>
                        <q xml:lang="gez">ቅዱስ፡ ሚካኤል። አፎምያ፡ ሰይጣን።</q>
                     </decoNote>
                     <decoNote xml:id="d17" type="miniature">
                        <locus target="#63v"/>
                        <desc>A miniature, portraying a rich man and his two poor neighbors.</desc>
                     </decoNote>
                     <decoNote xml:id="d18" type="miniature">
                        <locus target="#69v"/>
                        <desc>A miniature, showing <persName ref="PRS7049Michael"
                        /> bringing souls to judgment before <persName ref="PRS5684JesusCh"
                        />.</desc>
                        <q xml:lang="gez">እግዚእነ፡ ኢየሲስ። ቅዱስ፡ ሚካኤል።</q>
                     </decoNote>
                     <decoNote xml:id="d19" type="miniature">
                        <locus target="#73v"/>
                        <desc>A miniature, portraying the small chest filled with money that was sent to the poor man by <persName ref="PRS7049Michael"/>.</desc>
                        <q xml:lang="gez">እግዚእነ። ሰይጣን። ሣፅን፤ አሣ፤ ጉማራ።</q>
                     </decoNote>
                     <decoNote xml:id="d20" type="miniature">
                        <locus target="#77r"/>
                        <desc>A miniature, showing <persName ref="PRS5584Isaiah"/> healing <persName ref="PRS5680Jeremiah"/> by pouring water on his head.</desc>
                        <q xml:lang="gez">ቅዱስ፡ ሚካኤል። ኢሳያስ። ሕዝያስ።</q>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="e1">
                           <locus target="#3r"/>
                           <desc type="StampExlibris">A blue Ethiopian stamp with a cross in the
                              middle, which is impossible to read due to its fading.</desc>
                        </item>
                        <item xml:id="e2">
                           <locus target="#2r"/>
                           <desc>Sale note, mentioning <persName ref="PRS15463AmataWald"/> and
                                 <persName ref="PRS15464AbbaWaldaAr"/>. It is not fully clear what
                                 <foreign xml:lang="am">ጨበር፡</foreign> means in this context.</desc>
                           <q xml:id="am">ለአመተ፡ ወልደ፡ አረጋዊ፡ ፩ቀን፡ ለአባ፡ ወልደ፡ አረጋዊ፡ ፩ጨበር፡ ማላሻ፡ ፪ጨበር፡</q>
                        </item>
                        <item xml:id="e3">
                           <locus target="#73ra"/>
                           <desc>Sale note, written in pencil. Its text is faded and hardly
                              readable.</desc>
                           <q xml:lang="am">በ፲፻፱፻፮ ዓመተ፡ ምሕረት፡ በዘ <gap reason="illegible"/> ፡ ማርቆስ፡
                              በ፲፪ ቀን፡ ፊታውራሪ፡ <gap reason="illegible"/> ፺ብር፡ ለ <gap
                                 reason="illegible"/> ልብሱ፡ አባቶችም፡ ትላቀ፡ <gap reason="illegible"/>
                              መጋቢ፡ ወልደ፡ ገብርኤል። ጊዜ፡ <gap reason="illegible"/></q>
                        </item>
                        <item xml:id="e4">
                           <locus target="#99v"/>
                           <desc type="ScribalSignature">A scribal note, mentioning himself,
                                 <persName ref="PRS15462WaldaGabr"/> and <persName
                                 ref="PRS15461ZawaldaMaryam"/>, the owner of the manuscript.</desc>
                           <q xml:lang="gez"><hi rend="rubric">ዘሰረቆ፡ ወዘፈሐቆ፡ በ ፲ወ፪ ሐዋርያት፡ አጽሐፊሁ፡
