                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <desc>Untrained.</desc>
                        <note>The manuscript is most likely written by a beginner scribe.</note>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote xml:id="d1">
                        <locus target="#2r #5r #19v #26v"/>
                        <desc>Horizontal ornamental bands (ḥarags), featuring interlaces and floral
                           motifs.</desc>
                     </decoNote>
                     <decoNote xml:id="d2">
                        <locus target="#19r"/>
                        <desc>A drawing of a scribe, holding a manuscript in his left hand and a pen
                           in his right hand and sitting in front of a desc with two ink horns on
                           it. There are two indistinct tailed, four-legged <term key="animal"
                              >animals</term>, probably horses. The caption states as follows: <q
                              xml:lang="am">ደነገጡ፡ ጸሐፊ፡</q>.</desc>
                     </decoNote>
                     <decoNote xml:id="d3">
                        <locus target="#19v"/>
                        <desc>A drawing of an <ref type="authFile" corresp="AT1012Equestrian"
                              >equestrian saint</ref>, depicting him with a <term key="sword"/> and
                           a <term key="animal">horse</term>. <q xml:lang="am"><sic>ሰወስት፡</sic> አቦች፡
                              መክፈልት፡ የከለከሉት፡ ነው። ዋዋ፡ ወየዉ፡ ጉድ፡ መንድን፡ ናችዉ፡ ሰዎች፡
                                 <unclear>ዩ</unclear><gap reason="omitted"/></q>
                        </desc>
                     </decoNote>
                  </decoDesc>
                  <additions>
                     <list>
                        <item xml:id="a1">
                           <locus from="3v" to="4v"/>
                           <desc type="MagicText">A fragment of a magic prayer against cataract that
                              cuts off in the middle of the sentence The prayer starts with a supplication for
                                 <persName ref="PRS15356WaldaIy"/>. <q xml:lang="gez">በሰመ፡ አብ፡<choice>
                                    <sic>ወወልድ፡</sic>
                                    <corr>ወወለድ፡</corr>
                                 </choice> ወመንፈስ፡ ቅዱስ፡ አምላክ፡ ጻሎት፡ በእንተ፡ አይነ፡ ጥላ፡ ሕማመ፡ አይነ፡ ጥላ፡ ወአይነ፡
                                 ወርቅ፡ <gap reason="illegible"/> ወአላድን፡ <unclear>መፉቀጄን፡</unclear>
                                 <gap reason="illegible"/>
                                 <unclear>ኤናላዚዑን፡</unclear>
                                 <gap reason="ellipsis" resp="ESh"/></q></desc>
                        </item>
                        <item xml:id="a2">
                           <locus from="30r" to="30v"/>
                           <desc type="MagicText"><title ref="LIT7853Alfael"/>. The prayer starts
                              and ends with supplications for <persName ref="PRS15356WaldaIy"/> and
                              is written by the same hand as <ref target="#a1"/>.</desc>
                        </item>
                        <item xml:id="e1">
                           <locus target="#3r #32r"/>
                           <desc>Pen trials.</desc>
                        </item>
                     </list>
                  </additions>
