                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script" cert="medium">Eighteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, names of saints, most
                           incipits, elements of punctuation marks and Ethiopic numerals as well as
                      the word <foreign xml:lang="gez">ሰላም፡</foreign>.</seg>
                        <desc>Regular, neat, careful; loops are generally not closed.</desc>
                     </handNote>
                                 </handDesc>
