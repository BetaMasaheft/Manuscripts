               <msContents>
                  <summary/>
                  <msItem xml:id="ms_i1">
                     <locus from="3r" to="48v4"/>
                     <title ref="LIT1961Mashaf"/>
                     <note>There are numerous supplications for a man throughout the whole text, but
                        the name of a supplicant has been erased. The name of at least one of
                        possible supplicants starts with <foreign xml:lang="gez"
                        >ወልደ፡</foreign>.</note>
                     <msItem xml:id="ms_i1.1">
                        <locus from="3r" to="10v5"/>
                        <title>Ṣalot za-nagh</title>
                        <incipit><q xml:lang="gez"><hi rend="rubric">በስመ፡</hi><gap reason="ellipsis"
                                 resp="ESh"/> ስቆቃወ፡ ልብ፡ ኅበ፡ ቅዱስ፡ አብ፡ ዘገብሮ፡ ለአዳም፡ ኅበ፡ ቅዱስ፡ መንፈስ፡ ቅዱስ፡
                              ዘቦአ፡ ውስተ፡ ልብ፡ ነቢያት፡ ወጻድቃን፡ እንዘ፡ አብ፡ ዘገብሮ፡ ዘአዳም፡ ኅበ፡
                           ቅዱሳን።</q></incipit>

                     </msItem>
                     <msItem xml:id="ms_i1.2">
                        <locus from="10v5" to="14r5"/>
                        <title type="complete" xml:lang="gez">Ṣalot ba-3 saʿāt</title>
                        <incipit><q xml:lang="gez">ተዘከረኒ፡ እግዚኦ፡ በምሕረት፡ ኪያየ፡ <sic>ኅዙነ፡</sic> ኪያየ፡
                              ምኑነ፡ ኪያየ፡ ማዕከለ፡ ኃጢአት፡ ድፉነ፡ ወኪላሉ። ምስኪነ።</q></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.3">
                        <locus from="14r5" to="21v3"/>
                        <title type="complete" xml:lang="gez">Ṣalot ba-6 saʿāt</title>
                        <incipit><q xml:lang="gez">ተማኅፀንኩ፡ ወአማኅፀንኩ፡ ንፍስየ፡ ወሥጋየ፡ ወኩሎ፡ ስበዓ፡
                              ቤት፡በ፳ወ፬ካህናተ፡ ሰማይ፡ እለ፡ የአጥኑ፡ መንበር፡ ለአብ፡ ተማኅፀንኩ፡<gap reason="ellipsis"
                                 resp="ESh"/></q></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.4">
                        <locus from="21v3" to="26r9"/>
                        <title type="complete" xml:lang="gez">Ṣalot ba-9 saʿāt</title>
                        <incipit><q xml:lang="gez">ኅበ፡ ክርስቶስ፡ ኦባሕረ፡ ምሕረት፡ ግድፋ፡ ወአኅልፋ፡ ለኃጢአትየ፡ አመ፡
                              ፍቀረ፡ ምሕረት፡ ኅድጋ፡ ወተዓደዋ፡ ለዕበድየ፡ ኦፈልፈለ፡ ምሕረት፡ ተወከፋ፡ ለነፍስየ፡<gap
                                 reason="ellipsis" resp="ESh"/></q></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.5">
                        <locus from="26r9" to="39r10"/>
                        <title type="complete" xml:lang="gez">Ṣalot ba-12 saʿāt</title>
                        <incipit><q xml:lang="gez">ስቆቃወ፡ ኅበ፡ እግዜትነ፡ ማርያም፡ እብል፡ እንከ፡ ኦእግዜትነ፡ ተማኅፀንኩ፡
                              በኪ፡ ተማኅፀንኩ፡ በኪ፡ ወአማኅፀንኩ፡ ነፍስየ፡ ወሥጋየ፡ ኀቤከ፡ እስመ፡ ፈራኅኩ፡ ወጸዋእኩ፡ ስምኪ፡<gap
                                 reason="ellipsis" resp="ESh"/></q></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.6">
                        <locus from="39r10" to="40v7"/>
                        <title type="complete" xml:lang="gez">Ṣalot za-nǝwām</title>
                        <incipit><q xml:lang="gez">ወአልቦ፡ ዘይስአሎ፡ በከመ፡ አዳም፡ እብል፡ እንከ፡ ኦእግዚኦ፡ ተመልሕ፡
                              ዘተተክለ፡ ለእመ፡ ኢሠመርከ፡ ቲየብስ፡ ዘሠርፀ፡ ለእመ፡ ኢፈቀድከ፡ ወታሠርፅ፡ ዘየብስ፡ ኅበ፡ ዘሠመርከ፡<gap
                                 reason="ellipsis" resp="ESh"/></q></incipit>
                     </msItem>
                     <msItem xml:id="ms_i1.7">
                        <locus from="40v8" to="48v4"/>
                        <title type="complete" xml:lang="gez">Ṣalot za-manfaqa lelit</title>
                        <incipit><q xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ አብ፡ ወወልድ፡<gap reason="ellipsis"
                                 resp="ESh"/>ብሁት፡ ህሉና፡ ወክሂል፡ ወሥሉጥ፡ ላዕለ፡ ሉ፡ ኅበ፡ ምሕረትከ፡ አስምክ፡ ወእት፡
                              መኃፀን፡ ለዓለም፡ ዓለም፡ አሜን፡<gap reason="ellipsis" resp="ESh"/></q></incipit>
                     </msItem>
                  </msItem>
                  <msItem xml:id="ms_i2">
                     <locus from="48v5" to="56v"/>
                     <title ref="LIT2999RepCh279"/>
                  </msItem>
               </msContents>
               <physDesc>
                  <objectDesc form="Codex">
                     <supportDesc>
                        <support>
                           <material key="parchment"/>
                           <note>The hole in <locus target="#17"/> is carefully amended. The tear in
                                 <locus target="#55"/> is sewn up. There are also holes in the
                              margins of <locus target="#43 #54"/>.</note>
                        </support>
                        <extent>
                           <measure unit="leaf" quantity="60">60</measure>
                           <measure unit="leaf" type="blank">6</measure>
                           <dimensions type="outer" unit="mm">
                              <height unit="mm">92</height>
                              <width unit="mm">82</width>
                           </dimensions>
                        </extent>
                        <foliation>Foliation is provided by the library and is marked on the right
                           upper edge of the recto of each folium in pencil.</foliation>
                        <condition key="good">Despite a few stains (e.g., <locus
                              target="#42r #42v #53r #53v #54r"/>) and traces of humidity and fungus
                           on some folia, the condition is good and the text is almost fully
                           readable.</condition>
                     </supportDesc>
                     <layoutDesc>
                        <layout columns="1" writtenLines="11"/>
                     </layoutDesc>
                  </objectDesc>
                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="3r" to="48v4"/>
                        <seg type="script" cert="medium">Nineteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names, some punctuation marks, some Ethiopic
                           numerals as well as the name of the original supplicant and occasionally
                           the word <foreign xml:lang="gez">ጸሎት፡</foreign>.</seg>
                        <desc>Regular, careful, square letters with horizontal serifs, ligature of <foreign xml:lang="gez"
                              >ግ</foreign> and <foreign xml:lang="gez">ዚ</foreign>, some two dots are missing.</desc>
                        <abbr>ገ፡</abbr> for <expan>ገብርከ፡</expan> (e.g., <locus target="#43r #44v #47v"/>)
                     </handNote>
                  
                  <handNote xml:id="h2" script="Ethiopic">
                     <locus from="48v5" to="56v"/>
                     <seg type="script" cert="medium">Nineteenth-century script.</seg>
                     <seg type="ink">Black, red.</seg>
                     <seg type="rubrication">Divine names or their parts, some punctuation marks, some Ethiopic
                        numerals as well as the letter <foreign xml:lang="gez">ሰ</foreign> in the abbreviation of the word <foreign xml:lang="gez">ሰላም፡</foreign>.</seg>
                     <desc>Not very careful, some two dots and letters are missing, horizontal serifs.
                        Possibly, the same hand as <ref target="#h1"/>; the dissimilarities are conditioned by the use of different tools and inks.</desc>
                     <list type="abbreviations">
                        <item>
                           <abbr>ሰ፡</abbr> for <expan>ሰላም፡</expan> (e.g., <locus target="#51r #51v #52r"/>)
                        </item> 
                     </list>
                  </handNote>
                  </handDesc>
                  <additions>
                     <list>
                        
                        <item xml:id="e1">
                           <locus target="#30r #30v #32v #35r #35v"/>
                           <desc>The final letter <foreign xml:lang="gez">ም</foreign> in the word
                                 <foreign xml:lang="gez"><hi rend="rubric">ማርያም፡</hi></foreign> is
                              missing.</desc>
                        </item>
                     </list>
                  </additions>
                  <bindingDesc>
                     <binding contemporary="true">
                        <decoNote xml:id="b1">Two wooden boards.</decoNote>
                        <decoNote xml:id="b2" type="Cover">Red <term key="overCover">textile
                              secondary cover</term> with floral and geometrical pattern of beige
                           and black colours. The fabric is sewn up with a thick white
                           thread.</decoNote>
                        <decoNote xml:id="b3" type="Sewing">Two pairs of sewing stations.</decoNote>
                        <decoNote xml:id="b4" type="SewingStations">4</decoNote>
                        <decoNote xml:id="b5" type="bindingMaterial">
                           <material key="wood"/>
                           <material key="textile"/>
                        </decoNote>
                        <decoNote xml:id="b6" type="Endbands">Both endbands are present. The
                           tailband is slightly damaged.</decoNote>

                     </binding>
                  </bindingDesc>
