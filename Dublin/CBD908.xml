                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <locus from="1r" to="140v"/>
                        <seg type="script" cert="medium">Nineteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names (e.g., those of Jesus, Mary and
                           Gabriel), chapter titles and numbers, some incipits and explicits,
                           punctuation marks and some Ethiopic numerals.</seg>
                        <desc>Regular, careful, but letters are often missing.</desc>
                     </handNote>
                     <handNote xml:id="h2" script="Ethiopic">
                        <locus from="141r" to="141vb4"/>
                        <seg type="script" cert="medium">Nineteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">The incipit and elements of punctuation marks.</seg>
                        <desc>Mediocre, no dots between words.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="ornamentation" xml:id="d1"><desc>Narrow ornamental bands of
                           black and red dots at the end of almost each text part, e.g., on <locus
                              target="#7r #13v #21r #51r #100r #111v"/>.</desc></decoNote>
                     <decoNote type="headpieceBand" xml:id="d2"><desc>Decorative headings (ḥarag) at
                           the beginnig of every chapter, e.g., on <locus
                              target="#31v #39r #51v #61v 86v #123v"/>.</desc></decoNote>
                  </decoDesc>
