                  <handDesc>
                     <handNote xml:id="h1" script="Ethiopic">
                        <seg type="script" cert="medium">Nineteenth-century script.</seg>
                        <seg type="ink">Black, red.</seg>
                        <seg type="rubrication">Divine names (e.g., those of
                           Jesus, Mary and Gabriel), chapter titles and numbers, some incipits and
                           explicits, asterisks and some Ethiopic numerals.</seg>
                        <desc>Regular, careful.</desc>
                     </handNote>
                  </handDesc>
                  <decoDesc>
                     <decoNote type="ornamentation" xml:id="d1"><desc>Narrow ornamental bands of
                           black and red dots at the end of almost each text part, e.g., on <locus
                              target="#7r #13v #21r #51r #100r #111v"/>.</desc></decoNote>
                     <decoNote type="headpieceBand" xml:id="d2">Decorative headings (ḥareg) at the
                        beginnig of every chapter, e.g., on <locus
                           target="#31v #39r #51v #61v 86v #123v"/>.</decoNote>
                  </decoDesc>
