                        <msItem xml:id="ms_i1">
                            <locus target="#1r"/>
                            <title type="complete" xml:lang="gez" ref="LIT2885RepCh166"/>                           
                            <textLang mainLang="gez"/>                           
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus target="#1r"/>
                            <title type="complete" xml:lang="gez" ref="LIT2444Temher"/>
                            <textLang mainLang="gez"/>                              
                        </msItem>
                        <msItem xml:id="ms_i3"> 
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref=""/> <!-- Prayer against the suffering caused by ʿĀyna Ṭǝllā, some of these asmat are found elsewhere, e.g. ሙራኤል in LIT7121PrayerChildbirth-->
                            <textLang mainLang="gez"/> 
                            <note>The text is written in smaller letters and is almost erased. The name of the owner <persName role="owner" ref="PRS15336WaldaKi">Yǝmanu Walda 
                                Kidān</persName> is written at the end of the prayer.</note>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ፡ ዓይነ<supplied reason="omitted">፡</supplied> ጥላ፡
                                በኢጋኤል፡ አፍራኤል፡ ሙራኤል፡ ኪድናኤል፡ ዝራኤል፡ ዘመድኤል፡ ሰድቃኤል፡ 
                            </incipit>
                            <explicit xml:lang="gez">
                                <sic>አመሓልኵክሙ፡</sic> ወአውገዝኩክሙ፡ መናፍስተ፡ ር<choice><corr resp="bm:GrebTiss1935Codices">ኩ</corr><sic>ኵ</sic></choice>ሳን፡
                                በኃይ<choice><corr resp="bm:GrebTiss1935Codices">ለ</corr><sic>ል</sic></choice>፡ መለኮቱ፡ ለእግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ኢትቅረቡ፡ ኃበ፡ ነፍሱ፡
                                ወሥጋሁ፡ <sic>ለገብርከ።</sic> <persName role="owner" ref="PRS15336WaldaKi">ይመኑ፡ ወልደ፡ ኪዳን።</persName>
                            </explicit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref=""/> <!-- Prayer against the charms  -->
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> <del rend="erasure">ጸሎት፡ </del> በእንተ፡ ማዕሠሩ፡ 
                                <del rend="effaced" extent="unknown"/> ዘንተ<supplied reason="omitted">፡</supplied> <del rend="effaced" extent="unknown"/> ዘምስለ፡ 
                                <del rend="effaced" extent="unknown"/> ዘይፃረረኒ፡ ተመኪሖ፡ ቃለ፡ እግዚአብሔር፡ <del rend="effaced" extent="unknown"/> በሰይፈ፡ መለኮት፡ በሊህ፡
                            </incipit>
                            <explicit xml:lang="gez">
                                ይቀጠቅጦ፡ በሰይፈ፡ መለኮቱ፡ በሊ<del extent="unknown"/> <del>አድኅ</del>ኖ፡ ለገብርከ፡ 
                                <persName role="owner" ref="PRS15336WaldaKi">ይመኑ።</persName>
                            </explicit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref=""/>  <!-- Prayer against stomach ache  -->
                            <textLang mainLang="gez"/>
                            <note>The following is the entire text.</note>
                            <incipit xml:lang="gez">
                                በስመ<supplied reason="omitted">፡</supplied> አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ቁርቁር፡ ቁርቁር፡ ቁርቁር፡ ቁርቁር፡ 
                                <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> በኃይለ፡ ዝንቱ<supplied reason="omitted">፡</supplied> አስማቲከ፡ አድኅኖ፡ እምሕማመ፡
                                <choice><corr resp="bm:GrebTiss1935Codices">ቍ</corr><sic>ቁ</sic></choice>ርፀት፡ ለገብር<del>ከ</del>፡ 
                                <persName role="owner" ref="PRS15336WaldaKi">ይመኑ፡</persName> <surplus>በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/>
                                    ጸሎት<supplied reason="omitted">፡</supplied> በእንተ፡ ሕማመ፡ 
                                    <choice><corr resp="bm:GrebTiss1935Codices">ቍ</corr><sic>ቁ</sic></choice>ርፀት<supplied reason="omitted">፡</supplied></surplus>
                            </incipit>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref="LIT7271PrayerCharms"/> 
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ መፍትሔ፡ ሥራ<supplied reason="omitted">ይ</supplied>፡ ወጽላ<supplied reason="omitted">፡</supplied> <sic><del rend="effaced">ዋ</del>ጊ፡</sic> ወዘቀማ<surplus>ም</surplus>ንት፡ ወዘአምሐራ፡ ወእጀ፡ <supplied reason="omitted">ሰብእ፡</supplied> ከናንህ፡ ከን<add place="interlinear">ን</add>ህ<supplied reason="omitted">፡</supplied> ከን<add place="interlinear">ን</add>ህ፡ ከናንህ፡
                            </incipit>
                            <explicit xml:lang="gez">
                                መክን፡ መክን፡ መክን፡ አውክክ፡ አውክክ፡ አውክክ፡ ውሹሕ፡ ውሹሕ፡ ውሹሕ፡ ውሹሕ፡ ፍታሕ፡ ተፈታሕ<supplied reason="omitted">፡</supplied> ለገብርከ፡ <del><persName role="owner" ref="PRS15336WaldaKi">ይመኑ፡</persName></del>
                            </explicit>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref=""/> <!-- Prayer for undoing the charms  -->
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ <supplied reason="omitted">በእንተ፡</supplied> መፍትሔ፡ ሥራይ፡ በ፲ወ፪ወርኅ፡ በዘ<supplied reason="omitted">፡</supplied> ደገመ፡ በ፯ዕለታት፡ በ፲ወ፪ሐዋርያት፡ በ፸ወ፪አርድዕት፡ ፍታሕ፡ በጻድቃን፡ ወሰማዕት፡ ደናግል፡ ወመነኮሳት፡ አእሩግ፡ ወሕፃናት፡ ፍታሕ፡
                            </incipit>
                            <explicit xml:lang="gez">
                                በሰኑይ፡ ወበሰሉስ፡ በረቡዕ፡ ወበሐሙስ፡ በዓርብ<supplied reason="omitted">፡</supplied> በ<choice><corr resp="bm:GrebTiss1935Codices">ቀ</corr><sic>ቅ</sic></choice>ዳሚት፡ በሰንበተ፡ ክርስቲያን፡ ፍታሕ፡ ለገብርከ፡ <persName role="owner" ref="PRS15336WaldaKi">ወልደ<supplied reason="omitted">፡</supplied> ኪዳን፡</persName>
                            </explicit>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref=""/> <!-- Prayer against nose bleed and rhinitis -->
                            <textLang mainLang="gez"/>
                            <note>The following is the entire text.</note>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ደመ፡ <supplied reason="lost">ን</supplied>ስር፡ ወንዛዝ፡ ፋሎክ፡ አፍስሎክ፡ ኢታውርድ፡ ዘደመ፡ ንስ<choice><corr resp="bm:GrebTiss1935Codices">ር</corr><sic>ብ</sic></choice>፡ እምላእለ፡ ገብርከ፡ <persName role="owner" ref="PRS15336WaldaKi">ይመኑ፡</persName>
                            </incipit>                       
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <locus target="#1v"/>
                            <title type="complete" xml:lang="gez" ref=""/> <!-- Prayer against rhinitis -->
                            <textLang mainLang="gez"/>
                            <note>The following is the entire text.</note>
                            <incipit xml:lang="gez">
                                በስመ፡ አብ፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ጸሎት፡ በእንተ፡ ሕማመ<supplied reason="omitted">፡</supplied> ንዛዝ፡ ኃ<gap reason="illegible" unit="chars" quantity="1"/>ው፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> ወሙሴ፡ ወአዳም፡ <gap reason="ellipsis" resp="bm:GrebTiss1935Codices"/> አድኅኖ፡ እግዚእነ፡ ኢየሱስ፡ ክርስቶስ፡ ለገብርከ፡ <persName role="owner" ref="PRS15336WaldaKi">ይመኑ፡</persName>
                            </incipit>                            
                        </msItem>
                    </msContents>
                    
                    <physDesc>
                        <objectDesc form="Scroll">
                            <supportDesc>
                                <support>
                                    <material key="parchment"/>
