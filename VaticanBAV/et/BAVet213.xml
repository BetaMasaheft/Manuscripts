                                </support>
                                <extent>
                                    <dimensions type="outer" unit="mm">
                                        <width>95</width>
                                        <height>1325</height>
                                    </dimensions>
                                    <note>It consists of <measure unit="strips">2</measure> strips sewn together.</note>
