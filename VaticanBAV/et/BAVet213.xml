                        <handDesc>
                            <handNote script="Ethiopic" xml:id="h1">
                                <seg type="script">19th-century script</seg>
                                <date notBefore="1800" notAfter="1899"/>                            
                                <seg type="ink">Black, red.</seg>
                                <seg type="rubrication">Titles and holy names on the verso side; <ref target="#ms_i4"/>.</seg>
                            </handNote>
                        </handDesc>
                        
                        <decoDesc>
                            <decoNote type="ornamentation" xml:id="d1">
                                <desc>
                                    At the beginning and at the end of the scroll there are bands outlined in black and red ink.
                                </desc>
                            </decoNote>             
                            <decoNote type="diagram" xml:id="d2">
                                <desc>
                                   A diagram containing a human figure in a eight-pointed star at the end of the recto side is depicted in black and red ink.
                                   <q xml:lang="gez">ብርዕ፡ ሠና<lb/>ይ፡ ዘፈተነ፡</q>
                                </desc>
                            </decoNote>           
                        </decoDesc>                        
                        
                        <additions>
                            <list>
                                <item xml:id="e1">
                                    <desc>On the verso side are found minor writings and the following pen trial: <q xml:lang="gez">ብርዕ፡ ሠናይ፡ ዘፈተነ፡</q>.</desc>
                                </item>
                            </list>
                        </additions>
                    </physDesc>
                    
                    <history>
                        <origin>
                            <origDate>
                                <date notBefore="1800" notAfter="1899"/>
                            </origDate>
                        </origin>
                        <provenance>     
                            <persName role="owner" ref="PRS15336WaldaKi">Walda Kidān Yǝmanu</persName> is mentioned in several supplication formulas throughout the manuscript: 
                            he possibly was the original owner of the book.
                            According to the account on the manuscripts’ provenance given by Tisserant, this manuscript is among those acquired by 
                            <persName ref="PRS4805Grebaut" role="owner"/> in <placeName ref="LOC1216AddisA">ʾAddis ʾAbabā</placeName> in <date when="1925"/> with funds of
                            <persName ref="PRS14055SaintJ">Jean Saint</persName>. 
                            The manuscripts originated from Šawā (ʾAddis ʾAbabā, Dabra Libānos, Dabra Bǝrhān), Goǧǧām (Dimā Giyorgis, Marṭula Māryām, Dabra Warq) and Bagemdǝr
                            (Gondar, ʾAzazo Takla Hāymānot) and very few from Tǝgrāy.
                        </provenance>
                        <acquisition when="1928">The manuscript entered the library on <date when="1928-04-18">18 April 1928</date>.</acquisition>
                    </history>
                    
