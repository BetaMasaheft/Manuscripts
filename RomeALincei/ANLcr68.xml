                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus from="26va" to="27vb"/><locus target="#27r"/>
                                    <desc>Prayer, which was written on an empty page (<locus target="#26v"/>) and on the upper margin of the
                                        following page (<locus target="#27r"/>). Probably <ref type="work" corresp="LIT1917Mashaf"/> as it is attested
                                        in <ref type="mss" corresp="MALZ024"/>.</desc>
                                    <q xml:lang="gez">ኵሎ፡ ዘኢያፈቅሮ፡ ለእግዚእነ፡ ወመድኃኒነ፡ 
                                        <choice resp="PRS8999Strelcyn"><sic>አያ</sic><corr>ኢየ</corr></choice>ሱስ፡ ክርስቶስ፡ ዘኢየአምር፡ ልደቶ፡ 
                                        እማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied></q>
                                </item>
                                <item xml:id="a2">
                                    <locus from="91vb" to="92"/>
                                    <desc>A prayer on the last line of <locus target="#91vb"/> and on <locus target="#92"/>, possibly with a lacuna
                                        between <locus target="#91vb"/> and <locus target="#92"/>.</desc>
                                </item>
                                <item xml:id="a3">
                                    <desc>Note on the inner side of the front board stating the provenance of the manuscript from a church in ‘Arbambà’ 
                                        in <placeName ref="LOC5597Sawa"/>, possibly corresponding to <placeName ref="LOC1516ArbaAm"/>.</desc>
                                    <q xml:lang="it">Chiesa di Arbambà</q>
                                </item>
                                <item xml:id="e1">
                                    <desc type="StampExlibris">Ex Libris of <persName ref="PRS3182ContiRo" role="owner"/>.</desc>
                                </item>
                            </list>
                        </additions>
