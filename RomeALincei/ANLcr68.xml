                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i1.1">
                                <locus from="1ra" to="7ra"/>
                                <title ref="LIT1960Mashaf#Kidan1"/>
                                <incipit xml:lang="gez">ኪዳን፡ ዘነግህ። ቅዱስ፡ እግዚአብሔር፡ ኃይል፡ ቅዱስ፡ ሕያው፡ ዘኢይመውት፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="7ra" to="11rb"/>
                                <title ref="LIT1960Mashaf#LitonZasarq"/>
                                <incipit xml:lang="gez">ሊጦን፡ ዘሠርክ፡ አምላክነ፡ ዘዲበ፡ ኪሩቤል፡ ትነብር፡ እምኀበ፡ መላእክት፡ ትትአኰት፡ ወትሴባሕ፡ አንተ፡ ውእቱ፡ ዘከፈልከነ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="11va" to="21rb"/>
                                <title ref="LIT1960Mashaf#Intercessions"/>
                                <incipit xml:lang="gez">መስተብቍ<supplied reason="omitted" resp="PRS8999Strelcyn">ዕ</supplied>፡ ዘተአምር።
                                    እግዚአብሔር፡ እግዚኦ፡ ኢየሱስ፡ ክርስቶስ፡ አምላክነ፡ ዘትቤሎ፡ ለፍቁርከ፡ ዮሐንስ፡ እንዘ፡ ሀሎከ፡ በዲበ፡ ዕፀ፡ መስቀል፡ ቅዱስ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.4">
                                <locus from="21va" to="26va"/>
                                <title ref="LIT1960Mashaf#Zayenagges"/>
                                <incipit xml:lang="gez">ጸሐፍነ፡ በዘንዜከር፡ ዘይነግሥ፡ ዘአቡነ፡ <surplus>ዘአቡነ፡</surplus> ያሬድ፡ ካህን፡ ነአኵቶ። ወንሴብሖ፡ ለእግዚአ፡ ኵሉ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.5">
                                <locus from="27ra" to="60va"/>
                                <title ref="LIT1960Mashaf#SerataQeddase"/>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ሥርዓተ፡ ቅዳሴ፡ ዘይደሉ፡ ከመ፡ ይበሉ፡ ቀሲስ፡ ወዲያቆን፡ ወሕዝብ፡ ወኵሉ፡ 
                                    ዘመፍትው፡ በበዘመፍትው፡ በበጊ<supplied reason="omitted">ዜ</supplied>ሁ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.6">
                                <locus from="60va" to="77va"/>
                                <title ref="LIT1960Mashaf#AnaphoraApostles"/>
                                <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘሐዋርያት፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.7">
                                <locus from="77va" to="81ra"/>
                                <title ref="LIT1960Mashaf#AnaphoraLord"/>
                                <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘእግዚእነ፡ ኢየሱስ፡ <supplied reason="omitted">ክርስ</supplied>ቶስ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.8">
                                <locus from="81ra" to="91vb"/>
                                <title ref="LIT1960Mashaf#AnaphoraDioscorus"/>
                                <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘዲዮ<supplied reason="omitted">ስ</supplied>ቆሮስ፡ ጳጳስ።</incipit>
                            </msItem>
                        </msItem>
