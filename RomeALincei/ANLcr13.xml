                                <msItem xml:id="ms_i1.2.7">
                                    <locus from="99va" to="100ra"/>
                                    <title ref="" type="complete"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> ወበ፩
