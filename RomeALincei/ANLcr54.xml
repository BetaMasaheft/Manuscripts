                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <locus target="#67v"/>
                                    <desc type="GuestText">A text of nine lines, which has been effaced.</desc>
                                </item>
                                <item xml:id="a2">
                                    <locus target="#68r"/>
                                    <desc type="GuestText">Act of inheritance in Amharic, written by an untrained hand. On the left  a name
                                        (<persName ref="PRS15393Saraw"><roleName type="title">ʾato</roleName> Sarāw</persName>) has been
                                        added.</desc>
                                    <q xml:lang="am">
                                        <persName ref="PRS15387GabraTadeq"><roleName type="title">አቶ፡</roleName> ገብረ፡ ጣዴቅ፡</persName>
                                        በጃቸው፡ የጨበጡትን፡ በግራቸው፡ የረገጡትን፡ 
                                        ለ<persName ref="PRS15406TafYalash"><roleName type="title">ወይዘሮ፡</roleName> ጠፍ፡ የለሽ፡</persName> 
                                        <choice resp="PRS8999Strelcyn"><sic>ሼወርሱ፡</sic><corr>ሲያወርሱ፡</corr></choice> ዳኛው፡ 
                                        <persName ref="PRS15388Rasam"><roleName type="title">አቶ፡</roleName> ረሰም፡</persName>
                                        ዋሱ፡<persName ref="PRS15389WaldaSanb"><roleName type="title">መምሬ፡</roleName> ወልደ፡ ሰንበት፡</persName>
                                        <sic>ዕማኛቾ፡</sic> <persName ref="PRS15390WaldaMikael"><roleName type="title">አቶ፡</roleName>  
                                            ውልደ፡ ሚካኤል፡ <roleName type="title">መምሬ፡</roleName></persName> ደርሰህ፡ የወይዘሮ፡ ጠፍየለሽ፡ ዕማኝ፡ 
                                        <persName ref="PRS15389WaldaSanb"><roleName type="title">መምሬ፡</roleName> ወልደ፡ ሰንበት፡</persName>
                                        <persName ref="PRS15391WaldaSell"><roleName type="title">ልጅ፡</roleName> ወልደ፡ ስላሴ፡</persName> 
                                        ዋሱ፡ <persName ref="PRS15392Bulo"><roleName type="title">አቶ፡</roleName> ቡሎ፡</persName> በሀምሌ፡
                                        በዘመነ፡ ሉቃስ፡</q>
                                </item>
                                <item xml:id="e1">
                                    <desc type="findingAid">The manuscript is divided according to the days of the week. The reading for Monday starts 
                                        on <locus from="30ra"/>; the reading for Tuesday starts on <locus from="15ra"/>; the reading for Wednesday starts
                                        on <locus from="28vb"/>; the reading for Thursday starts on <locus from="39vb"/>; the reading for Friday starts
                                        on <locus from="46va"/>; the reading for Saturday starts <locus from="54va"/>; the reading for Sunday starts
                                        on <locus from="61ra"/>.</desc>
                                </item>  
                                <item xml:id="e2">
                                    <locus target="#1v"/>
                                    <desc type="OwnershipNote">Note in pencil with the name of an owner of the manuscript:
                                        <persName ref="PRS15394AmataYoh" role="owner">ʾAmata Yoḥannǝs</persName></desc>
                                </item>
                                <item xml:id="e3">
                                    <locus target="#2v"/>
                                    <desc type="Unclear">A handwritten note, difficult to read, in which the name 
                                        <persName ref="PRS15395Warqo">Warqo</persName> can be made out.</desc>
                                </item>
                                <item xml:id="e4">
                                    <locus target="#66rb"/>
                                    <desc>Note in pencil with a name: <persName ref="PRS15396WaldaMikae">Walda Mikāʾel</persName></desc>
                                </item>
                                <item xml:id="e5">
