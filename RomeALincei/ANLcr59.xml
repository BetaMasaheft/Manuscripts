                            <textLang mainLang="gez"/>
                            
                            <msItem xml:id="ms_i1.1">
                                <locus from="5ra" to="14rb"/>
                                <title ref="LIT1295Dersan#Hedar"/>
                                
                                <msItem xml:id="ms_i1.1.1">
                                    <locus from="5ra" to="12ra"/>
                                    <title ref="LIT1295Dersan#HomilyTimothy"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ድርሳን፡ ዘደረሰ፡ አባ፡ ደማቴዎስ፡ ሊቀ፡ ጳጳሳት፡ ዘለእስክንድርያ፡ ዘይትነበብ፡ በበዓለ፡
                                        ሊቀ፡ መላእክት፡ ሚካኤል፡ አመ፡ ፲ወ፪፡ ለወርኃ፡ ኅዳር፡ ያርእየነ፡ ኃይለ፡ ወክብረ። ዘወሀቦ፡ እግዚአብሔር፡ እምኵሎሙ፡ ቅዱሳን፡ መላእክት፡ በረከቱ፡ ወኃይለ፡
                                        ረድኤቱ፡ የኃሉ፡ ምስለ፡ ፍቁሩ፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.1.2">
                                    <locus from="12ra" to="12va"/>
                                    <title ref="LIT1295Dersan#IntroductionMiracles"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ንዌጥን፡ በረድኤተ፡ እግዚአብሔር፡ <sic>በጽሒፈ፡</sic> 
                                        ተአ<surplus>አ</surplus>ምሪሁ፡ ለመልአክ፡ ክቡር፡ ሚካኤል፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.1.3">
                                    <locus from="12va" to="13va"/>
                                    <title ref="LIT1295Dersan#MiracleSailors"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> እከሥት፡ በምሳሌ፡ አፉየ፡ ወአነብ<cb n="12vb"/>ብ፡ ወኀቡአት፡
                                        እመሰረት። ወይፌክር፡ ለክሙ፡ ውሉደ፡ ኀይሎ፡ ለዝንቱ፡ መልአክ፡ ክቡር፡ ሚካኤል፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.1.4">
                                    <locus from="13va" to="14ra"/>
                                    <title ref="LIT1295Dersan#CommemorativeJoshua"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> አመ፡ ፲ወ፪ ለኅዳር፡ እስመ፡ በዛቲ፡ ዕለት፡ ተዝካረ፡ በዓሉ፡ 
                                        <gap reason="ellipsis"/><cb n="13vb"/><gap reason="ellipsis"/>  ዝንቱ፡ ዘርእዮ፡ ኢያሱ፡ ወልደ፡ ነዌ፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.1.5">
                                    <locus from="14ra" to="14rb"/>
                                    <title ref="LIT1295Dersan#SalamCompassionate"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለከ፡ ኪያከ፡ መልአከ።</incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.2">
                                <locus from="14va" to="22ra"/>
                                <title ref="LIT1295Dersan#Tahsas"/>
                                
                                <msItem xml:id="ms_i1.2.1">
                                    <locus from="14va" to="20va"/>
                                    <title>Anonymous Homily</title>
                                    <note>The incipit, which was provided in <bibl><ptr target="bm:Strelcyn1976Catalogue"/>
                                        <citedRange unit="item">59</citedRange><citedRange unit="page">164</citedRange></bibl>, is too short
                                        for any safe identification. However, according to the conventional order of the readings in Tāḥśāś, it is likely to be
                                        <ref type="work" corresp="LIT1295Dersan#HomilyDeratewos"/>.</note>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ድርሳን፡ ዘቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡ ዘይትነበብ፡ በወርኃ፡ ታኅሣሥ፡ 
                                        ወበረከቱ፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.2.2">
                                    <locus from="20va" to="21rb"/>
                                    <title ref="LIT1295Dersan#MiracleTreasure"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> ወሀሎ፡ ፩ ብእሲ፡ መሃይምን፡ ዘይሴፎ፡ ምሕረተ፡ እግዚአብሔር፡ 
                                        ወትንብልናሁ፡ ለቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.2.3">
                                    <locus from="21rb" to="22ra"/>
                                    <title ref="LIT1295Dersan#CommemorativeTahsas"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="ellipsis"/> አመ፡ ፲ወ፪ ለወርኃ፡ ታኅ<pb n="21va"/>ሣሥ፡ እለተ፡ በዓሉ፡ 
                                        ለመል<supplied reason="omitted" resp="PRS8999Strelcyn">አ</supplied>ክ፡ ክቡር፡ ሚካኤል፡ ሊቀ፡ መላእክት፡ እስመ፡ በዛቲ፡ 
                                        እለት፡ ፈነ<add place="below">ዎ</add>፡ እግዚአብሔር፡ ኀበ፡ ሀገረ፡ ባቢሎን፡ ወኮነ፡ ራብአየ፡ ገጸ፡ ላዕለ፡ ፫ ደቂቅ፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.2.4">
                                    <locus from="21rb" to="22ra"/>
                                    <title ref="LIT1295Dersan#SalamTahsas"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለከ፡ ዓቃቤ፡ ቅዱሳን፡ እምተሀውኮ።</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.3">
                                    <locus from="22ra" to="33rb"/>
                                    <title ref="LIT1295Dersan#Terr"/>
                                    
                                <msItem xml:id="ms_i1.3.1">
                                    <locus from="22ra" to="32rb"/>
                                    <title ref="LIT1295Dersan#HomilyTalafinos">Homily of John, bishop of Aksum</title>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ሥሉስ፡ ዘኢይት<cb n="22rb"/>ሌለይ፡ <sic>ዕበይ፡</sic> 
                                        ዘኢይሴ<add place="below">ደ</add>ቅ፡ <gap reason="ellipsis"/> መፍትው፡ ይስምዕዎ፡ በለብዎ፡ ከመ፡ ታእምሩ፡ 
                                        <pb n="22va"/> ዕበዮ፡ ለቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.3.2">
                                    <locus from="32rb" to="33v"/>
                                    <title ref="LIT1295Dersan#MiracleRichPoor"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="omitted"/><pb n="32va"/><gap reason="omitted"/> ተብህለ፡ ከመ፡
                                        ፩ብእሲ፡ ክርስቲያናዊ፡ በውስተ፡ አሐቲ፡ ሀገር፡ ዘይፈርሆ፡ ለእግዚአብሔር፡ ወይገብር፡ ትእዛዞ፡ ወይጽሕቅ፡ ለገቢረ፡ ሠናይ፡ ወአፈቅሮ፡ ለቅዱስ፡ ሚካኤል፡ ሊቀ፡
                                        መላእክት፡ ወገብረ፡ ግብረ፡ ማሕረስ፡ ከመ፡ ይኩኖ፡ ለሲሳዩ፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.3.3">
                                    <locus from="33v" to="34rb"/>
                                    <title ref="LIT1295Dersan#CommemorativeTerr">How Michael helped Jacob</title>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> አመ፡ ፲ወ፪ ለወርኃ፡ ጥር፡ <gap reason="omitted"/> እስመ፡ በዛቲ፡ ዕለት፡
                                        ፈነዎ፡ እግዚአብሔር፡ ለሚ<pb n="34ra"/>ካኤል፡ ሊቀ፡ መላእክት፡ ኃበ፡ ያዕቆብ፡ እስራኤል፤</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.3.4">
                                    <locus target="#34rb"/>
                                    <title ref="LIT1295Dersan#SalamEldest" cert="low"/>
                                    <incipit xml:lang="gez">ሰላም፡ ለከ፡ ሚካኤል<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ፩፡
                                            </incipit>
                                </msItem>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.4">
                                <locus from="34va" to="40vb"/>
                                <title ref="LIT1295Dersan#Yakkatit"/>
                                
                                <msItem xml:id="ms_i1.4.1">
                                    <locus from="34va" to="38rb"/>
                                    <title ref="LIT1295Dersan#HomilyPoor"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> ዘይትነበብ፡ በወርኃ፡ የካቲት፡ ጸሎቱ፡ <gap reason="omitted"/> ወሀሎ፡
                                        ፩ ብእሲ፡ ነዳይ፡ ወዓቢይ፡ ሃይማኖቱ፡ ዘይነብር፡ በውእቱ፡ ብሄር፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.2">
                                    <locus from="38rb" to="39vb"/>
                                    <title ref="LIT1295Dersan#MiracleParalytic"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="omitted"/> ተብሕለ፡ ከመ፡ ሀሎ፡ ፩ ብእሲ፡ ኄር፡ ፈራኄ፡ እግዚአብሔር፡ ወይገብር፡ 
                                        ምሕረተ፡ ለነዳየን፡ ወለምስኪናን፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.3">
                                    <locus from="40ra" to="40va"/>
                                    <title ref="LIT1295Dersan#CommemorativeYakkatit"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> አመ፡ ፲ወ፪ ለወርኃ፡ የካቲት፡ <gap reason="omitted"/> በዛቲ፡ ዕለት፡
                                        ፈነዎ፡ እግዚአብሔር፡ <gap reason="omitted"/> ኀበ፡ ሶምሶን፡</incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.4.4">
                                    <locus from="40va" to="40vb"/>
                                    <title ref="LIT1295Dersan#SalamBeauties"/>
                                    <incipit xml:lang="gez">ሰላም፡ ዕብል፡ ሠና<supplied reason="omitted" resp="PRS8999Strelcyn">ይ</supplied>ቲከ
                                        <surplus resp="PRS8999Strelcyn">ተ</surplus>፡ ተአዛዜ፡ ።</incipit>
                                </msItem>
                            </msItem>
                                
                                <msItem xml:id="ms_i1.5">
                                    <locus from="41ra" to="61rb"/>
                                    <title ref="LIT1295Dersan#Maggabit"/>
                                    
                                <msItem xml:id="ms_i1.5.1">
                                    <locus from="41ra" to="58ra"/>
                                    <title ref="LIT1295Dersan#HomilyPsalm"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> ድርሳን፡ ዘደረሰ፡ በዕለተ፡ <sic>ቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት፡</sic> ዘአንጾኪያ፡ 
                                        <gap reason="omitted"/>  ወአፍቅሮቱ፡ ሰብአ፡ ተናገረ፡ በእለተ፡ ሰንበት፡ ቅድስት፡ እስመ፡ ኃብረ፡ ምስለ፡ ሰንበት፡ በዓሉ፡ ለቅዱስ፡ ሚከኤል፡ ሊቀ፡ መላእክት፡
                                            </incipit>
                                </msItem>
                                
                                <msItem xml:id="ms_i1.5.2">
                                    <locus from="58ra" to="60vb"/>
                                    <title ref="LIT1295Dersan#MiracleElephantiasis"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ <gap reason="omitted"/><cb n="58rb"/><gap reason="omitted"/> ተብህለ፡ ከመ፡ 
                                        ሀለወት፡ አሐቲ፡ ብእሲት፡ በአሐቲ፡ ሀገር። ክብርት፡ ወልዕልት፡ ጥቀ፡ ወብዙኃ፡ ንዋያ፡ ወታፈቅሮ፡ ለሚካኤል፡ <gap reason="omitted"/> አኃዛ፡ ሕማመ፡ 
                                        ዝል<add place="below">ጋ</add>ሴ፡ ወአተወት፡ ደዌ፡ እኵይ፡</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.5.3">
                                    <locus from="61ra" to="61rb"/>
                                    <title ref="LIT1295Dersan#CommemorativeMaggabit"/>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> አመ፡ ፲ወ፪ ለመጋቢት፡ እስመ፡ በዛቲ፡ ዕለት፡ ፈነዎ፡ እግዚአብሔር፡ ኀበ፡ በለዓም፡
                                        መሰግል፡</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.5.4">
                                    <locus target="#61rb"/>
                                    <title ref="LIT1295Dersan#SalamMaggabit"/>
                                    <incipit xml:lang="gez">ሰላም፡ ዕብል፡ ለዘይቀድም፡ ፆታሁ።</incipit>
                                </msItem>
                            </msItem>
                            
                            <msItem xml:id="ms_i1.6">
                                <locus from="61va" to="70rb"/>
                                <title ref="LIT1295Dersan#Miyazya"/>
                                
                                <msItem xml:id="ms_i1.6.1">
                                    <locus from="61va" to="66vb"/>
                                    <title ref="LIT1295Dersan#HomilyOrthodox"/>
                                    <note>The author of the homily, Rǝtuʿa Hāymānot, is not mentioned here.</note>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> ድርሳን፡ ዘደረሰ፡ በእንተ፡ ብፁዕ፡ ወቅዱስ፡ ሚካኤል፡ ሊቀ፡ መላእክት። ጸሎቱ፡
