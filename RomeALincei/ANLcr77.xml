                        <msIdentifier/>
                        <msContents><summary>Priestly Prayers and Order of Mass</summary>
                            <msItem xml:id="p1_i1">
                                <locus from="1r" to="6v"/>
                                <title ref="LIT1938Mashaf"/>              
                                <incipit xml:lang="gez">በስመ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ፩ አምላክ። አሜን፡ ንቅድም፡ በረድኤተ፡ እግዚአብሔር፡ ንጽሕፍ፡ መጽሐፈ፡ ኪዳን፡
                                    ዘነገሮሙ፡ እግዚእነ፡ ለሐዋርያቲሁ፡ እምቅድመ፡ ዕርገቱ፡ ወትንሣኤሁ፡ እሙታን፡ ሀብተ፡ ጸጋሁ፡ ተሀሉ፡ ምስለ፡ ገብሩ፡ <sic>ለዓለም፡</sic> ዓለም፡ አሜን።
                                    በከመ፡ ኮነ፡ ሰንበት። ተሣሃልከ፡ እግዚኦ፡ ምድርከ፡ ሃሌ፡ ሉያ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ሃሌ፡
                                    ሉያ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሉያ። በ፮፡ ይእቲ፡ ማርያም፡ እምነ፡ ወእሙ፡ ለእግዚእነ፡ ሰአሊ፡ በእንቲአነ። ከመ፡ ይምሐረነ፡ ወይሣሃለነ፡ ያስተርኢ፡ ኂሩቱ፡ በላዕሌነ። ሠርዐ፡ 
                                    ለነ፡ ሰንበተ፡ ለዕረፍተ፡ ዚአነ፡ ፍስሐ፡ ወሰላም፡ ላዕለ፡ አመነ። በሰሙንሂ፡ በ፩፡ ሃሌ፡ ሉያ፤ ይትፌሣሕ፡ ልብኪ፡ ኦድንግል፡ ወይትሌዓል፡ ቀርንኪ፡ በክብር፡ ሰማይ፡ ዳግሚት።
                                    ብኪ፡ ድ<pb n="1v"/>ኅነ፡ ዓለም፡ ወበወልድኪ፡ ኮነ፡ ሰላም። በዝየ፡ ሰላም፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ወፍቅረ፡ እግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ።
                                    ኢይርሐቅ፡ ማዕከሌየ፡ ወማዕከሌክሙ፡ እግዚኦ፡ መሐረነ፡ ክርስቶስ። 
                                    በበዜ<choice resp="PRS8999Strelcyn"><sic>ሜ</sic><corr>ማ</corr></choice>ሁ፡ በ፲፪ ጊዜ፡ በል። ይብ፡ ካ፡ ቅዱስ፡ 
                                    እግዚአብሔር፡ ቅዱስ፡ ኃያል፡ ቅዱስ፡</incipit>
                                <textLang xml:lang="gez"/>
                            </msItem>
                            <msItem xml:id="p1_i2">
                                <locus from="6v" to="48v"/>
                                <title ref="LIT1960Mashaf"/>                        
                                <textLang xml:lang="gez"/>
                                <msItem xml:id="p1_i2.1">
                                    <locus from="6v" to="7r"/>
                                    <title ref="LIT1960Mashaf#LitonZasarq"/>   <!-- Issue #3367 -->                     
                                    <incipit xml:lang="gez">አምላክነ፡ ዘዲ<pb n="7r"/>በ፡ ኪሩቤል፡ 
                                        ትነብር<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> እም፡ ኀበ፡ መላእክት፡ <sic>ትትዔኰት፡</sic>
                                        ወትሴባሕ፡ አንተ፡ ውእቱ፡ ዘከፈልከነ፡ ንባእ፡ ውስተ፡ ፅርሐ፡ ቅዱስ፡ ማኅፈድከ።</incipit>
                                    <textLang xml:lang="gez"/>
                                </msItem>
                                <msItem xml:id="p1_i2.2">
                                    <locus from="7r" to="22r"/>
                                    <title ref="LIT1807Litonz"/>              
                                    <incipit xml:lang="gez">ወካእበ፡ ናስተበቍዕ፡ ዘኵሉ፡ ይእኅዝ፡ እግዚአብሔር፡ አብ፡ ለእግዚእ፡ ወመድኀኒነ፡ ኢየሱስ፡ ክርስቶስ፤ እንዘ፡ ነአኵቶ፡ እስመ፡
                                        አቀበነ፡ በኑኃ፡ ሌሊት፤</incipit>
                                    <textLang xml:lang="gez"/>
                                </msItem>
                                <msItem xml:id="p1_i2.3">
                                    <locus from="22r" to="30r"/>
                                    <title ref="LIT1960Mashaf#Zayenagges"/>                        
                                    <incipit xml:lang="gez">ዘያሬድ፡ ዘይነግሥ፡ ወካዕበ፡ ነአኵቶ፡ ወንሴብሖ፡ ለእግዚአ፡ ኵሉ፡ አምላክነ፡ አኀዜ፡ ኵሉ፡ ዓለም፡ ዘይነግሥ፡ ለኵሉ፡</incipit>
                                    <textLang xml:lang="gez"/>
                                </msItem>
                                <msItem xml:id="p1_i2.4">
                                    <locus from="30r" to="48v"/>
                                    <title ref="LIT1960Mashaf#SerataQeddase"/>  
                                    <note>The texts ends abruptly.</note>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ሥርአተ፡ ቅዳሴ፡ ዘይደሉ፡ ከመ፡ ይበሉ፡ ቀሲስ፡ ወዲያቆን፡ ወኵሉ፡ ዘመፍትው፡ 
                                        በበጊዜሁ። በከመ፡ ሥርአተ፡ አበዊነ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ግብጻውያን። መቅድመ፡ ኵሉ፡ 
                                        ይጸሊ፡ ቀሲስ፡ ጸሎተ፡ ንስሐ፤</incipit>
                                    <textLang xml:lang="gez"/>
                                </msItem>
                            </msItem>  
                        </msContents>
