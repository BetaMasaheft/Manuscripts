                    <msContents>
                        <summary/>           
                        <msItem xml:id="ms_i1">
                            <locus from="3ra" to="55vc"/>
                            <title ref="LIT3178Deggwa">Dǝggʷā-type antiphonary</title>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i1.1">
                                <locus from="3ra" to="34rc"/>
                                <title ref="LIT3178Deggwa#part1">First part from the beginning of Maskaram up to Lent.</title>
                                <incipit xml:lang="gez">በስመ፡ ሥሉስ፡ ቅዱስ፡ አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ጸሐፍነ፡ ድጓ፡ ዘውእቱ፡ 
                                    መሥ<supplied reason="omitted" resp="PRS8999Strelcyn">ዋ</supplied>ዕት፡ ለእግዚአብሔር፡ ምድር፡ በምልዓ፡ ወእግዚአብሔር፡
                                    ነግሠ፡ ወይትባረክ፡ አርያም፡ ወመዝሙር፡ ዘአምላኪየ፡ ወአርባዕት፡ ዕዝል፡ ወይእዜ፡ ወማኅሌት፡ ወስብሐተ፡ ነግህ፡ ፫፡ ወሰላም፡ ዘበዓላት፡ ወዘሰናብት፡ ዘጾም፡ 
                                    ወዘጸደይ፡ ዘክረምት፡ ወዘሀጋይ፡ ዘይፌጽም፡ ጥንቁቀ፡ ለለወርኁ፡ ወለለሰንበቱ፡ ወለለኵሉ፡ ብዓላት፡ ዘተሠርዓ፡ በም<add place="below">ድርነ፡</add>
                                    ዝመጽሐፍ፡ <gap reason="lost"/> አቡሁ፡ <gap reason="lost"/> በ<gap reason="illegible"/>በሥረቱ። 
                                    <gap reason="ellipsis"/> ብፁዕ፡ አንተ፡ ዮሐንስ፡ ዘሀለወከ፡ ታእምር፡ ወተሐውር፡ ቅድመ። እግዚአብሔር፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="34va" to="35v"/>
                                <title ref="LIT3178Deggwa#Haleta"/>
                                <note>Written in two columns.</note>
                                <incipit xml:lang="gez">አንቀጸ፡ ሃሌታ፡ እምዮሐንስ፡ እስከ፡ 
                                    ዮ<supplied reason="omitted" resp="PRS8999Strelcyn">ሐንስ፡</supplied></incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="36ra" to="55vc"/>
                                <title ref="LIT3178Deggwa#part2">Second part from Easter until the end of the liturgical year.</title>
                                <note>The first words of each chant are rubricated.</note>
                                <incipit xml:lang="gez">
                                    ምልጣን፡ ዘፋሲካ፡ <pb n="36va"/> ዋዜማ፡ ዘማዕደት፡ <cb n="36vc"/> 
                                    ዕዝል፡ ዘረቡ<supplied reason="omitted" resp="PRS8999Strelcyn">ዕ፡</supplied> ንዑ፡ ንትፌሣሕ፡ <pb n="37rb"/>
                                    ዕዝል፡ ዘሐሙስ፡ <pb n="37va"/> ዋዜማ፡ ዘሰንበት፡ <pb n="38ra"/> ዋዜማ፡ ዘሰንበት፡ <cb n="38rc"/> ዋዜማ፡ ዘጊዮርጊስ፡ <pb/> 
                                    ዋዜማ፡ ዘልደ<supplied reason="omitted" resp="PRS8999Strelcyn">ት፡</supplied> <pb n="40rb"/>
                                    ህ<supplied reason="omitted" resp="PRS8999Strelcyn">የ</supplied>ንተ፡ ዋዜማ፡ ዘጰራቅሊጦስ፡</incipit>
                            </msItem>
                        </msItem>    
                        <msItem xml:id="ms_i2">
                            <locus from="56ra" to="77va"/>
                            <title type="incomplete" ref="LIT3186Meeraf">Fragments of Mǝʿrāf</title>
                            <note>With readings for the entire year.</note>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i2.1">
                                <locus from="56ra" to="65vc"/>
                                <title>First section</title>
                                <note>With readings for the feast of St John the Baptist, for the Feast of Nativity, for the feasts of the year, etc.</note>
                                <incipit xml:lang="gez">ምዕራፍ፡ ዘዮሐንስ፡ ወጌና፡</incipit><!-- Cp. Grébaut (Griaule) III, ms. 370, p. 49 et suiv. -->
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i2.2">
                                <locus from="66ra" to="77va"/>
                                <title>Fourth section (readings for the night)</title>
                                <note>With readings for the entire year.</note><!-- Cp. Grébaut (Griaule) III, ms. 370, p. 57 et suiv. -->
                                <incipit xml:lang="gez">ምዕራፍ፡ ዘመወድስ፡</incipit>
                                <textLang mainLang="gez"/>
                            </msItem>
                        </msItem>
                    </msContents>
