                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic">
                                <desc>Very small and careful handwriting of circa 2 mm in height, with even smaller script on <locus target="#23v"/>
                                    and immediately after with a height of just only 1 mm. Very small signs of musical notation.</desc>
                                <seg type="ink">Black, red.</seg>
                                <date notBefore="1900" notAfter="1949" resp="PRS8999Strelcyn">First half of the 20th century</date>
                                <persName ref="PRS15177YohannesT" role="scribe"/>
                            </handNote>                            
                        </handDesc>
                        <additions>
                            <list>
                                <item xml:id="a1">
                                    <desc type="GuestText">Fragments of prayers.</desc>
                                </item>
                                <item xml:id="a2">
                                    <locus from="77vb" to="78r"/>
                                    <desc type="GuestText">Fragments of New Testament texts, written in a larger handwriting.</desc>
                                    <q xml:lang="gez">ዘኤፌሶን፡ ወእምይእዜሰ፡ ኢኮነ፡ ነግደ፡ ወፈላሴ፡ ሀገሪቶሙ፡ ለቅዱሳን፡ ንሕነ፡ ወሰብአ፡ ቤቱ፡ ለእግዚአብሔር፡ ተሐነጽክሙ፡ ዲበ፡
                                        መሠረተ፡ ነቢያት፡</q>
                                </item>
                                <item xml:id="a3">
                                    <locus target="#1r"/>
                                    <desc>Note written by <persName ref="PRS3182ContiRo"/> stating the provenance of the
                                        manuscript from a church in ‘Arbambà’ in <placeName ref="LOC5597Sawa"/>, maybe
                                        corresponding to <placeName ref="LOC1516ArbaAm"/>.</desc>
                                    <q xml:lang="it">proviene dalla chiesa di Arbambà (Scioa)</q>
                                </item>
                                <item xml:id="e1">
                                    <locus target="#1 #2 #35v #55va #78v #79 #80"/>
                                    <desc>Numerous graffiti and pen trials in ink, black or violet pencil.</desc>
                                </item>
                                <item xml:id="e2">
                                    <locus target="#1r"/>
                                    <desc type="StampExlibris">Ex libris of <persName ref="PRS3182ContiRo"/>.</desc>
                                </item>
                                <item xml:id="e3">
                                    <locus target="#80r"/>
                                    <desc>Note in pencil by the scribe, who was probably the scribe of the manuscript.</desc>
                                    <q xml:lang="gez">ጸሐፊሁ፡ 
                                        <persName role="scribe" ref="PRS15421HabtaGabr">ሃ<supplied reason="omitted" resp="PRS8999Strelcyn">ብ</supplied>ተገብርኤል፡</persName></q>
                                </item>
                            </list>
                        </additions>
                        <bindingDesc>
                            <binding>
                                <decoNote xml:id="b1">Wooden boards, the backboard is broken in two parts</decoNote>
                                <decoNote xml:id="b2" type="Boards">Wooden boards</decoNote>
                                <decoNote xml:id="b3" type="Cover">Back board is covered in leather</decoNote>
                                <decoNote xml:id="b4" type="bindingMaterial"><material key="wood"/><material key="leather"/></decoNote>
                            </binding>
                        </bindingDesc>
                    </physDesc>
                    <history>
                        <origin><persName ref="PRS5712JohnXVI"><roleName type="office">Patriarch</roleName> Yoḥannǝs</persName>,
                            who held office from 1727 to 1745 and 
                            <persName ref="PRS6072Krestodo"><roleName type="title">Metropolitan</roleName> Krǝstodolu III</persName>
                            (<foreign xml:lang="gez">ክርስተዶሉ፡</foreign>), who held office from 1720 to 1735, are mentioned on 
                            <locus target="#62v"/>, which allows to assume that the manuscript was produced 
                            <origDate notBefore="1727" notAfter="1735">between 1727 and 1735 A.D.</origDate>
                        </origin>
                        <provenance>The manuscript came from a church in ‘Arbambà’ in <placeName ref="LOC5597Sawa"/>, possibly
                            corresponding to <placeName ref="LOC1516ArbaAm"/> (see <ref target="#e1"/>). 
                            It was either acquired by <persName ref="PRS3182ContiRo" role="owner">Carlo Conti Rossini</persName> 
                            during his stay in <placeName ref="LOC2991Eritre">Eritrea</placeName>
                            (<date notBefore="1899" notAfter="1903">1899–1903</date>) or sent to him after his return to Europe.
                        </provenance>
                    </history>
