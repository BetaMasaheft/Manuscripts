                            <additions>
                                <list>
                                    <item xml:id="a1">
                                        <locus target="#5v"/>
                                        <desc type="GuestText">Fragment of a <ref type="work" corresp="LIT5888AsmatPrayer">magic prayer</ref>,
                                            containing <term key="Asmat">ʾasmāt</term> similar to those in <ref type="work" corresp="LIT7112Asmat"/>, 
                                            <ref type="work" corresp="LIT7761PPrayer"/>, <ref type="work" corresp="LIT5876AsmatPrayer"/>,
                                            <ref type="work" corresp="LIT1637Homily"/> and <ref type="work" corresp="LIT4967Salotanadara"/>.
                                            on a leaf, which was taken from another manuscript and bound in as a guard leaf.</desc>
                                        <q xml:lang="gez">እክስ፡ እስኪ፡ ኤፓ፡ ኤፓስ፡ ኤንክም፡ ካምዕ፡ ኤቦክ፡ ኪኖም፡ <gap reason="ellipsis"/> በእሉ፡ አስማቲከ፡</q>
