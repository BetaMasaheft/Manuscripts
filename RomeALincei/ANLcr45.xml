                    <msPart xml:id="p1"><msIdentifier/>
                        <msContents>   <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="7ra" to="27ra"/>
                            <title ref="LIT3186Meeraf" type="incomplete">Texts from the Mǝʿǝrāf</title>
                            <!-- Same as in BnF éth 309 (= Griaule 5), f. 61ra-66rb) Cp. Grébaut (Griaule) I, pp. 24-26; Velat II, pp. 118-126. (HLZ 9:28162/M:Vel)-->
                            <msItem xml:id="ms_i1.1">
                                <locus from="7ra" to="14ra"/>
                                <title ref="LIT1716Kidanz"/>
                                <incipit xml:lang="gez">ቅዱስ፡ እግዚአብሔር፡ ቅዱስ፡ ኃያል፡ ቅዱስ፡ ሕያው፡ ዘኢይመውት፡ ዘተወልደ፡ እማርያም፡ እምቅድስት፡ ድንግል፡ ተሣሃለነ፡
                                    እግዚኦ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="14rb" to="20ra"/>
                                <title ref="LIT2444Temher"/>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="20ra" to="23va"/>
                                <title ref="LIT1190Baenta"/>
                                <incipit xml:lang="gez">በእንተ፡ ቅድስት፡ ሰላማዊት፡ ሰላም፡ ናስተበቍዕ፡ ከመ፡ እግዚአብሔር፡ ያስተሣልመነ፡ በሣህለ፡ ዚአሁ፡ አሜን፤ ኪርያላይሶን፤
                                    እግዚኦ፡ ተሣሃለ<cb n="20rb"/>ነ፡ በእንተ፡ ሃይማኖትነ፡ ናስተበቍዕ፡ <gap reason="ellipsis"/> በእንተ፡ ማኅበርነ፤ ና፤ ከ፤ እግዚ፡ 
                                    <gap reason="ellipsis"/> በእንተ፡ ትዕግሥታተ፡ ነፍሳት፤ ናስ፤ ከ፤ እግ፤</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.4">
                                <locus from="23va" to="27ra"/>
                                <title ref="LIT3083RepCh363"/>
                                <incipit xml:lang="gez">እግዚአብሔር፡ ዘብርሃናት፡ እግዚአብሔር፡ ዘሥልጣናት። አግዚአብሔር፡ ዘአርእስተ፡ መላእክት፤</incipit>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="27ra" to="53va"/>
                            <title ref="LIT1960Mashaf">Compositions from the Maṣḥafa qǝddāse</title>
                            <note>With fragments from <ref type="work" corresp="LIT3186Meeraf"/>, which was described above.</note>
                            <!-- Compositions faisant partie du Maṣḥafa qǝddase. I faut pourtant noter qu'il est assez courant de trouver des fragments du
                            missel avec les prieres de la partie I  -->
                            <!-- Cp. BnF éth 309 (= Griaule 5), f. 61ra-66rb) Cp. Grébaut (Griaule) I, pp. 24-26; Velat II, pp. 118-126.-->
                            <msItem xml:id="ms_i2.1">
                                <locus from="27ra" to="28rb"/>
                                <title ref="LIT4327Basamay"/>
                                <incipit xml:lang="gez">በሰማይ፡ የሃሉ፡ ልብክሙ፡ ይ፡ ሕ፡ እወ፡ የሃሉ፡ በሰማይ፡ ልብነ፡ በእንተ፡ ስምከ፡ አድንዓነ፡ ወረስየነ፡ ድልዋነ፡ ኢየሱስ፡ ክርስቶስ፡
                                    እግዚአነ፡ ወአምላክነ። ወለእመቦ፡ በተሐየሰ፡ ምስለ፡ ቢጹ፡ ይኀድግ፡ ሎቱ፡ እመቦ፡ ዘሐለየ፡ በልቡ፡ ኑፋቄ፡ ይትጋነይ።</incipit>  
                            </msItem>
                            <msItem xml:id="ms_i2.2">
                                <locus from="28va" to="34rb"/>
                                <title ref="LIT1100Anapho"/>
                                <!--Cp. Hammerschmidt, pp. 15, 41-42 and bibliography 167-170. - Probably: bm:Hammerschmidt1987Anaphoras-->
                                <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘእግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ በረከቱ፡ የሀሉ፡ ምስለ፡ ገብሩ፡ አቡነ፡ ወልደ፡ አረጋዊ።
                                    ለዓለመ፡ ዓለም፡ አሜን። ነአኵተከ፡ አምላክ፡ ቅዱስ፡ ፍጻሜ፡ ነፍስነ፡</incipit>  
                            </msItem>
                            <msItem xml:id="ms_i2.3">
                                <locus from="34va" to="53va"/>
                                <title ref="LIT1099Anapho"/>
                                <!-- Hammerschmidt, pp. 16-18 46, 78-80 and bibliography 167-170 - Probably: bm:Hammerschmidt1987Anaphoras-->
                                <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘእግዝእትነ፡ ማርያም፡ ዘደረሰ፡ አባ፡ ህርያቆስ፡ ጳጳስ፡ ጸሎታ፡ ወበረከታ፡ <gap reason="ellipsis"/>
                                    ጐሣዓ፡ ልብየ፡ ጐሥዓ፡ ልብየ፡ ቃለ፡ ሠናየ፡ ቃለ፡ ሠናየ፡ <gap reason="ellipsis"/> ወአነ፡ አየድዕ፡ ቅዳሴሃ፡ ለማርያም፡</incipit>  
                            </msItem>
                        </msItem>
