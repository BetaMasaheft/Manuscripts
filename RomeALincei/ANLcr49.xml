                    <msContents>
                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="1r" to="74r"/>
                            <title>Kunama language materials by Leon Hanriot</title>
                            <note>Collection of materials concerning the <persName ref="ETH1792Kunama"/>, collected and edited by 
                                <persName ref="PRS15334Henriot"/> in <date when="1894"/>, presented by
                                <persName ref="PRS15335Bonomi"><roleName type="title">R. P.</roleName>Luigi Bonomi</persName> to 
                                <persName ref="PRS3182ContiRo"/>, cf. <bibl><ptr target="bm:ContiRossini1903Cunama"/></bibl>.</note>
                            <textLang mainLang="it" otherLangs="kun"/><!-- cf. Issue #3289-->
                            <msItem xml:id="ms_i1.1">
                                <locus from="1v" to="21r"/>
                                <title>Vocabulary Italian — Kunama</title>
                                <note>A list of Italian-Kunama words arranged by topic: <foreign xml:lang="it">Iddio</foreign> ‘Goodness me’; 
                                    <foreign xml:lang="it">Spirito Santo</foreign> ‘Holy Spirit’; <foreign xml:lang="it">Uomo</foreign> ‘Man’; 
                                    <foreign xml:lang="it">Corpo umano</foreign> ‘The human body’; <foreign xml:lang="it">Vestito</foreign>
                                    ‘Dress’; <foreign xml:lang="it">Parentado</foreign> ‘Relatives’. The Italian lexeme always occupies the verso side,
                                    while the translation into Kunama occupies the recto side opposite it.</note>
                                <incipit xml:lang="it">Iddio. Dio (O Dio!) — <foreign xml:lang="kun">Anna (Anna hè!)</foreign>;
                                    Dio grande — <foreign xml:lang="kun">Anna anda</foreign>; 
                                    Dio Spirito — <foreign xml:lang="kun">Anna sciuca</foreign>; 
                                    Dio fa — <foreign xml:lang="kun">Anna emenena (chemenena)</foreign>; 
                                    Dio fece — <foreign xml:lang="kun">Anna eminchè (chemnichè)</foreign>;
                                    Dio fece il cielo e la terra — <foreign xml:lang="kun">Amma cuiana lagana chemnichè</foreign>; 
                                    Dio porta — <foreign xml:lang="kun">Anna icona (cona) checona</foreign>;</incipit>
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="21v" to="29v"/>
                                <title>Elements of grammar</title>
                                <note>Information on various topics: <foreign xml:lang="it">Numeri cardinali, ordinali</foreign> 
                                    ‘Cardinal numbers, ordinal numbers’; <foreign xml:lang="it">Pronomi</foreign> ‘Pronouns’; 
                                    <foreign xml:lang="it">Preposizioni</foreign> ‘Prepositions’; <foreign xml:lang="it">Avverbi</foreign> ‘Adverbs’; 
                                    <foreign xml:lang="it">Verbo — essere, avere, sapere, amare, parlare, fare, salutare (pregare), stare (sedere-dimorare)</foreign> 
                                    ‘Verbs — to be, to have, to know, to love, to speak, to do, to greet (to pray), to stay (to sit, to dwell)’.</note>
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="30v" to="34v"/>
                                <title>Phrases</title>
                            </msItem>
                            <msItem xml:id="ms_i1.4">
                                <locus from="35r" to="59v"/>
                                <title>Biblical texts and biblical topics</title>
                                <note>Published in 
                                    <bibl><ptr target="bm:ContiRossini1903Cunama"/><citedRange unit="page">208-227</citedRange></bibl>.
                                        </note>
                                <msItem xml:id="ms_i1.4.1">
                                    <locus from="35r" to="45v"/>
                                    <title>Old Testament</title>
                                    <msItem xml:id="ms_i1.4.1.1">
                                        <locus from="35r"/>
                                        <title>Address</title>
                                        <incipit>Allocuzione O Cunāmé sirañgha</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.1.2">
                                        <locus from="36r"/>
                                        <title>The formation of men and women</title>
                                        <incipit xml:lang="it" type="inscriptio">Formazione dell’uomo e della donna</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.1.3">
                                        <locus from="36r"/>
                                        <title>In Paradise</title>
                                        <incipit xml:lang="it">Nel Paradiso</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.1.4">
                                        <locus from="36r"/>
                                        <title>The Jews up to the time of Christ</title>
                                        <incipit xml:lang="it" type="inscriptio">Gli Ebrei fino a Cristo</incipit>
                                    </msItem>
                                </msItem>
                                <msItem xml:id="ms_i1.4.2">
                                    <locus from="44v" to="59v"/><!-- Overlapping with ms_i1.4.1 ? -->
                                    <title>New Testament</title>
                                    <note>Other parts after <ref target="#ms_i1.4.2.4"/> are indicated in 
                                        <bibl><ptr target="bm:Strelcyn1976Catalogue"/><citedRange unit="page">147</citedRange></bibl>.</note>
                                    <msItem xml:id="ms_i1.4.2.1">
                                        <locus from="44v"/>
                                        <title>The Gospel: Zechariah – Elizabeth, John</title>
                                        <incipit xml:lang="it" type="inscriptio">Il Vangelo: Zacaria. – Elizabetta, Giovianni</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.2.2">
                                        <locus from="45r"/>
                                        <title>Gabriel and Mary</title>
                                        <incipit xml:lang="it" type="inscriptio">Gabriele e Maria</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.2.3">
                                        <locus from="45v"/>
                                        <title>The Birth of Jesus</title>
                                        <incipit xml:lang="it">Nascita di <sic>Iesu</sic></incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.2.4">
                                        <locus from="46r"/>
                                        <title>Circumcision – Magi</title>
                                        <incipit xml:lang="it">Circoncisione – Magi</incipit>
                                    </msItem>
                                    <msItem xml:id="ms_i1.4.2.5">
                                        <locus from="59r"/>
                                        <title>Pentecost</title>
                                        <incipit xml:lang="it">Pentecoste</incipit>
                                    </msItem>
                                </msItem>
                            </msItem>
                            <msItem xml:id="ms_i1.5">
                                <locus from="60v" to="74r"/>
                                <title>Small catechism in the Kunama language</title>
                                <note>Indicated with the title ‘Uana. Iccana. Sciucanda na Ocudam.<!-- Are these words Latin, Italian or Kunama? --> 
                                    <foreign xml:lang="it">Catechismo in lingua Cunama, dal piccolo catechismo del 
                                    <persName ref="wd:Q12731432"><roleName type="title">R. P.</roleName> Joseph Deharbe</persName></foreign>’</note>
                                <msItem xml:id="ms_i1.5.1">
                                    <locus from="60v" to="61r"/>
                                    <title>Introduction</title>
                                    <incipit xml:lang="it" type="inscriptio">Introduzione</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.5.2">
                                    <locus from="61v" to="68v"/>
                                    <title>On the truths which everyone ought to know and believe</title>
                                    <note>Divided into ten chapters and followed by a creed.</note>
                                    <incipit xml:lang="it" type="inscriptio">Capo I. Delle verità che da tutti si devono sapere e credere</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.5.3">
                                    <locus from="70v" to="74r"/>
                                    <title>The Ten Commandments</title>
                                    <incipit xml:lang="it" type="inscriptio">Capo II. Comandamenti</incipit>
                                </msItem>
                            </msItem>
                        </msItem>
