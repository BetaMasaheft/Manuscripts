                        <msItem xml:id="ms_i1">
                            <locus from="3r" to="61r"/>
                            <title>Collection of prayers of incense</title>
                            <note>Possibly similar to <ref type="work" corresp="LIT2252salota"/>.</note>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i1.1">
                                <locus from="3r" to="23r"/>
                                <title>Prayer for incense for Sunday</title>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎተ፡ ዕጣን፡ ወበእሁድ፡ ሰንበት፡ ታዓርግ፡ ዕጣነ፡ ወትብል፡ ዘበእንተ፡ መፍትው፡ 
                                    ናዕርፍ፡ ሰንበታተ፡ ወናምጽእ፡ ቃላተ፡ ቅዱሳተ፡ ከመ፡ ንግበር፡ ፈቃዶ፡ ወንዘከር፡ ሕማማቲሁ፡ ዘሐመ፡ ወሞተ፡ በእንቲአነ፡</incipit>    
                            </msItem>
                            <msItem xml:id="ms_i1.2">
                                <locus from="3r" to="23r"/>
                                <title>Prayer for incense for every day</title>
                                <note>Interspersed with psalms, among other prayers.</note>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ንጽሕፍ፡ ጸሎተ፡ ዕጣን፡ ዘወትር፡ ዘያነብቦ፡ ቀሲስ፡ ጊዜ፡ ቦአ፡ ቤተ፡ መቅደስ፡</incipit>    
                            </msItem>
                            <msItem xml:id="ms_i1.3">
                                <locus from="23r" to="24r"/><locus from="32v" to="48v"/>
                                <title>Psalms accompanying the ritual of incense for Sunday</title>
