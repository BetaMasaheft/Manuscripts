                                <msItem xml:id="ms_i1.4.1">
                                    <locus from="25r"/>
                                    <title ref="LIT1828Mahale#ThreeYouths1"/>
                                    <incipit xml:lang="gez" type="inscriptio">ጸሎተ፡ ዳንኤል፡ ነቢይ፡ ወስብሐት፡ ዘእምአዛርያ።</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.4.2">
                                    <locus from="27r"/>
                                    <title ref="LIT1828Mahale#ThreeYouths3"/>
                                    <incipit xml:lang="gez" type="inscriptio">ኀበ፡ ባረኩ፡ አናንያ፡ ወአዛርያ፡ ወሚሳኤል፡ ለእግዚአብሔር።</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.4.3">
                                    <locus from="48v"/>
                                    <title ref="LIT1828Mahale#Manasseh"/>
                                    <incipit xml:lang="gez" type="inscriptio">ጸሎተ፡ ምናሴ፡ ነቢይ።</incipit>
                                </msItem>
                                <msItem xml:id="ms_i1.4.4">
                                    <locus from="50v"/>
                                    <title>Liturgical instruction for the reading of the Magnificat</title>
                                    <note>Liturgical instruction for the reading of the <ref type="work" corresp="LIT1828Mahale#Mary">Magnificat</ref>.</note>
                                </msItem>
                            </msItem>
                            <msItem xml:id="ms_i1.5">
                                <locus from="50v" to="61r"/>
                                <title>Mastabqʷǝʿ</title>
                                <incipit xml:lang="gez">ወይበል፡ ጸሎተ፡ እግዝእትነ፡ ማርያም፡ ወያዕርግ፡ ዕጣነ፡ ፫ ጊዜ፡ ወይዑድ፡ ታቦተ፡ ፫ ጊዜ፡ እንዘ፡ ይብል፡ ንስእለከ፡ እግዚኦ፡ 
                                    ወናስተበቍዓከ፡ ከመ፡ ተዘከራ፡ ለአሐቲ፡ ቅድስት፡ ቤተ፡ ክርስተያን፡</incipit>
                            </msItem>
                        </msItem>
