                    <msPart xml:id="p2">
                        <msIdentifier/>
                        <msContents><summary/>
                            <msItem xml:id="p2_i1">
                                <locus from="11ra" to="78rb"/>
                                <title ref="LIT1960Mashaf" type="incomplete">Fragments of a missal (Maṣḥafa qǝddāse)</title>
                                
                                <msItem xml:id="p2_i1.1">
                                    <locus from="11ra" to="40ra"/>
                                    <title ref="LIT1960Mashaf#SerataQeddase" type="incomplete">Fragments of Śǝrʿāta qǝddāse</title>
                                    <note>Fragments of <ref type="work" corresp="LIT1960Mashaf#SerataQeddase"/> including 
                                        <ref type="work" corresp="LIT1960Mashaf#Chalice"/> and 
                                        <ref type="work" corresp="LIT1960Mashaf#CrossSpoon"/>.
                                        Emperor Mǝnilǝk (on <locus target="#21rb #34rb"/>), 
                                        a patriarch of Alexandria with the name ʾAbbā Yoḥannǝs (sic) (on <locus target="#37ra"/>) and a
                                        metropolitan of Ethiopia with the name ʾAbbā Sinodā (on <locus target="37ra"/>) are mentioned 
                                        in the text. However, no such church dignitaries are attested as contemporaries of 
                                        <persName ref="PRS7006Menilek"/>. Therefore the mentioning of ʾAbbā Yoḥannǝs and  ʾAbbā Sinodā 
                                        may possibly refer to dignitaries of an earlier period (e.g. <persName ref="PRS10393Yohanne"/> and 
                                        <persName ref="PRS8870Sinoda"/>), and may have been copied from an earlier manuscript.</note>
                                    <!-- No joint rule can be inferred for Emperor Menilik, abba Yohannes of Alexandria, and abba Sinodā of Ethiopia -->
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ሚመጠን፡ ጸሎት፡ ላዕለ፡ መንጦላዕት። ሚመጠን፡ ግርምት፡ ወዕፅብት፡ ዛቲ፡ አንተ፡ ላቲ፡
                                        ይወርድ፡ መንፈስ፡ ቅዱስ፡ እመልዕልተ፡ ሰማያት። <gap reason="ellipsis"/><pb n="11va"/><gap reason="ellipsis"/> 
                                        ጸሎ<supplied resp="PRS8999Strelcyn" reason="omitted">ት፡</supplied> ላዕለ፡ መሶብ፡
                                        <gap reason="ellipsis"/><cb n="13rb"/><gap reason="ellipsis"/> 
                                        ጸሎ<supplied resp="PRS8999Strelcyn" reason="omitted">ት፡</supplied> ላዕለ፡ ጽዋዕ፡ 
                                        <gap reason="ellipsis"/><pb n="13va"/><gap reason="ellipsis"/>
                                        ጸሎ<supplied resp="PRS8999Strelcyn" reason="omitted">ት፡</supplied> ላዕለ፡ ዕርፈ፡ መስቀል፡
                                        <gap reason="ellipsis"/><cb n="18rb"/><gap reason="ellipsis"/>
                                        ጸሎ<supplied resp="PRS8999Strelcyn" reason="omitted">ት፡</supplied> ፍትሐት፡ ዘወልድ፡</incipit>
                                </msItem>
                                <msItem xml:id="p2_i1.2">
                                    <locus from="40ra" to="53va"/>
                                    <title ref="LIT1960Mashaf#AnaphoraApostles">Anaphora of the Apostles</title>
                                    <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘቅዱስ፡ አበዊነ፡ ሐዋርያት። ነአኵተከ፡ እግዚኦ፡ በፍቁር፡ ወልድከ፡ እግዚእነ፡ ኢየሱስ፡ ዘበደኃሪ፡ መዋዕል፡ 
                                        ፈኖከ፡ ለነ፡ ወልደከ፡</incipit><!-- Cp. Hammerschmidt, pp. 13-14, 41-43 and 167-170 -->
                                </msItem>
                                <msItem xml:id="p2_i1.3">
                                    <locus from="54rb" to="58rb"/>
                                    <title ref="LIT1960Mashaf#AnaphoraLord"/>
                                    <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘእግዚእነ፡ ወአምላክነ፡ ወመድኃኒነ፡ ኢየሲስ፡ ክርስቶስ፡ ጸሎቱ፡ ወበረከቱ፡ 
                                        <gap reason="ellipsis"/><pb n="54va"/><gap reason="ellipsis"/> ነአኵተከ፡ አምላክ፡ ቅዱስ፡ ፈጻሜ፡ ነፍስነ፡</incipit>
                                </msItem>
                                <msItem xml:id="p2_i1.4">
                                    <locus from="58va" to="74ra"/>
                                    <title ref="LIT1960Mashaf#AnaphoraMary"/>
                                    <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘእግዝእትነ፡ ማርያም፡ ወላዲተ፡ አምላክ፡ ዘደረሰ፡ አባ፡ ሕርያቆስ፡ ጳጳስ፡ ዘሀገረ፡ <sic>ብንኅሳ።</sic>
                                        ጸሎቱ፡ ወበረከቱ፡ የሃሉ፡ <gap reason="ellipsis"/> ጐሥዓ፡ ልብየ፡ ጐሥዓ፡ ልብየ፡ ፫ ጊዜ፤</incipit>
                                </msItem>
                                <msItem xml:id="p2_i1.5">
                                    <locus from="74rb" to="78rb"/>
                                    <title ref="LIT1960Mashaf#AnaphoraDioscorus"/>
                                    <incipit xml:lang="gez">አኰቴተ፡ ቍርባን፡ ዘድዮስ፡ ቆሮስ፤ እምቅድመ፡ ዓለም፡ ወእስከ፡ ለዓለም፡ ሀሎ፡ እግዚአብሔር፡ በመንግሥቱ፡ እግዚአብሔር፡
                                        በትሥልስቱ፡ እግዚአብሔር፡ በመለኮቱ።</incipit><!-- Cp. Hammerschmidt, pp. 18-19, 40 49 and 167-170 -->
                                </msItem>
                            </msItem>
                        </msContents>
