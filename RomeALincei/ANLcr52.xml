                            </objectDesc>  
                            <handDesc>
                                <handNote xml:id="h2" script="Ethiopic"> 
                                    <seg type="script">Nineteenth or twentieth-century script.</seg>
                                    <desc>The name of the copier is <persName ref="PRS15382WaldaIya">Walda ʾIyasus</persName>, which is
                                        mentioned on <locus target="#54"/>). His handwriting here is slightly smaller and more squashed than in 
                                        <ref target="#p1"/>.</desc>
                                    <seg type="ink">Black, red ink, which is lighter than that in <ref target="#p1"/>.</seg>
                                </handNote>
                            </handDesc>
                        </physDesc>
                        <history>
                            <origin>Due to the mentions of <persName ref="PRS7006Menilek"/> in <ref target="#p2_i1.1"/> a production date at
                                <origDate notBefore="1889" notAfter="1913">the end of the nineteenth or beginning of the twentieth century</origDate>
                                can be assumed.
                            </origin><!-- No joint rule can be inferred for Emperor Menilik, abba Yohannes of Alexandria and abba Sinodā of Ethiopia; 
                            probably add another origDate in p2-->
                        </history>
