                                        <measure unit="page" type="blank">6</measure><locus from="1v" to="2v"/><locus from="9v" to="10v"/>
                                        <dimensions type="outer" unit="mm">
                                            <height unit="mm">180</height>
                                            <width unit="mm">130</width>
                                        </dimensions>
                                    </extent>
                                    <collation>Two endleaves (<locus target="#1 #2"/> and one quaternion <locus from="3" to="10"/>.</collation>
                                    <condition key="good"/>
                                </supportDesc> 
                            </objectDesc>  
                            <handDesc>
                                <handNote xml:id="h1" script="Ethiopic"> 
                                    <seg type="script">Nineteenth or twentieth-century script.</seg>
                                    <desc>Written by the same copier as the other part (<persName ref="PRS15382WaldaIya">Walda ʾIyasus</persName>,
                                        who is mentioned on <locus target="#54"/>). However his handwriting is slightly larger and thicker than
                                        <ref target="#h2"/>.</desc>
                                    <seg type="ink">Black, red.</seg>
                                </handNote>
                            </handDesc>
