                    <summary/>
                   <msItem xml:id="ms_i1">
                       <title ref="LIT6386Libanos"/>
                       <textLang mainLang="gez"/>
                       
                       <msItem xml:id="ms_i1.1">
                        <locus from="5ra" to="22ra"/>
                        <title type="complete" ref="LIT1473GadlaL"/>
                       <incipit xml:lang="gez">
                           በስመ፡ <gap reason="ellipsis"/> እግዚአብሔር፡ ሥሉስ፡ ብሑተ፡ ሀልዎ፡ ዘይክል፡ ቀቲል<supplied reason="omitted">፡</supplied>
                           ወአሕይዎ። መኰንነ፡ ጽድቅ፡ ውእቱ፡ ዘእንበለ፡ አድልዎ፡ ወከመ፡ ሐመድ፡ ለጊሜ፡ ዘይዘርዎ፡ ወከመ፡ ፍተታት፡ ውስተ፡ ምድር፡ ለበረድ፡
                           ዘይፌንዎ። <gap reason="ellipsis"/><cb n="b"/><gap reason="ellipsis"/>
                           ድርሳን<supplied reason="omitted">፡</supplied> ዘብፁዕ፡ ወቅዱስ፡ አባ፡ ሊባኖስ<supplied reason="omitted">፡</supplied>
                           ዘደረሰ፡ አባ፡ ኤልያስ፡ ኤጲስ፡ ቆጶስ፡ ዘአኵስም፡ አዕሚሮ፡ ወሃይማኖቶ፡ ወጽንዓ፡ ትዕግሥቱ፡ ዘከመ፡ ገብረ<supplied reason="omitted">፡</supplied>
                           ሎቱ፡ እግዚአብሔር፡ ተአምራተ፡ ወመንክራተ፤
                       </incipit>
                    </msItem>
                       
                    <msItem xml:id="ms_i1.2">
                        <locus from="22ra" to="64ra"/>
                        <title type="complete" ref="LIT4717TaammerLi"/>
                        <note>53 unnumbered miracles.</note>
                        
                        <msItem xml:id="ms_i1.2.1">
                            <locus from="22ra" to="24vb"></locus>
                            <title type="complete" ref="LIT4717TaammerLi#praise"/>
                            <incipit xml:lang="gez">
                                በስመ፡ <gap reason="ellipsis"/> ንዌጥን፡ ጽሒፈ፡ ተአምሪሁ ለአቡነ: ሊባኖስ፡ ለእመ፡ ክህልነ፡ ኅዳጠ፡ ዜንዎ፡ 
                                እምብዙኅ፡ ተአምሪሁ፤ ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ኵልነ፡ ውሉደ፡ ጥ<cb n="b"/>ምቀት፡ ለዓለመ፡ ዓለም፡ አሜን።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2.2">
                            <title type="complete" ref=""/>
                            <incipit xml:lang="gez">
                                ሰላም፡ ለከ፡ ኦቅዱስ፡ ሊባኖስ፡ ፈዋሴ፡ ሥጋ፡ ወነፍስ።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2.3">
                            <locus from="24vb" to="25rb"/>
                            <title type="complete" ref=""/>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ለአቡነ፡ ሊባኖስ፡ <gap reason="ellipsis"/>  ስምዑ፡ አበውየ፡ ወአኃውየ፡ ተአምረ፡ ወመንክረ፡ ዘአርአየነ፡ 
                                እሙነ፡ ዝንቱ፡ አቡነ፡ በሐሊበ፡ ወንጌል፡ ዘተሐጽነ። ጽጌ፡ ቅድስና፡ ዘተከድነ፡ ለምግባረ፡ ጽድቅ፡ <pb
                                    n="25r"/><cb n="a"/><gap reason="ellipsis"/>  ንግባዕኬ፡ ኀበ፡
                                ተአምራ<supplied reason="omitted">ቲ</supplied>ሁ፡ ለቅዱስ፡ ሊባኖስ፡ አሐተ፡ ዕለተ፡ አሰነየ፡ አምዕስተ፡ 
                                ጠሊ፡ ከመ፡ ይግበር፡ ለመልበሱ፤
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2.4">
                            <locus from="25rb" to="26ra"/>
                            <title type="complete">Story of the man who stole from a dignitary</title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ወካእበ፡ ዜነውኒ፡ እለ፡ ርእዩ፡ በአዕይንቲሆሙ፡ መጽአ፡
                                ፩ ብእሲ፡ <sic>እንባ፡</sic> ሰናይት፡ ወተማኅፀነ<sic>ት</sic>፡ ኃበ፡ ቤተ፡ ክርስ<pb
                                    n="25v"/><cb n="a"/>ቲያኑ፡ ለቅዱስ፡ ሊባኖስ፡ ወይቤልዎ፡ መነኮሳት፡ ምንተ፡ ኮንከ። ወይቤሎሙ፡ ምንተ፡ ኮንከ፡
                                ዘትብሉኒ፡ እስመ፡ አስተዋደዩኒ፡ ኃበ፡ መኵንን፡ እንዘ፡ ይብሉ፡ ዝንቱ፡ ብእሲ፡ ሠረቀ፡ ንዋየከ፡ አንሰ፡
                                ኢሠረቁ፤
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.3">
                            <locus from="26ra" to="26va"></locus>
                            <title type="complete">Story of a thief named 'Arga from the land of the Galla who
                                had stolen bees</title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ካዕበ፡ ስምዑ፡ አበውየ፡ ወአኃውየ፡ ተአምሪሁ፡ ለዝአቡነ፡
                                ኮከበ፡ ሮምያ፡ ማኅቶተ፡ ኢትዮጵያ። ወ፩ ዕለተ፡ መጽአ፡ ጕሕልያ፡ ኃበ፡ ቤተ፡ ክርስቲያን፡ ዘተሐንፀት፡ በስሙ፡ 
                                ለቅዱስ፡ ሊባኖስ፡ ዘይብልዋ፡ ዓርጋ፡ ዘምድረ፡ ጋላ፡ ወካዕበ፡ መጽአ፡ ጕሕልያ፡ ካልዕ፡ ወተራከቡ፡ ህየ፡
                                ወሠረቆ<supplied reason="omitted">፡</supplied> ንህበ፡ ለካልዑ፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.4">
                            <locus from="26va" to="27ra"></locus>
                            <title type="complete">On healing of a blind woman</title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ካዕበ፡ ስምዑ፡ ዜና፡ ተአምሪሁ፡ ለዝአቡነ፡ ፀሐይ፡ ዘኢየዓርብ፡
                                ማኅቶት፡ ዘኢይጠፍዕ። ወአሐተ፡ ዕለተ፡ መጽኡ፡ ዕደው፡ ጊዜ፡ ዕርበተ፡ ፀሐይ፡ ወምስሌሆሙ፡ ዓቢይ፡ በግዕ።
                                ወወሀቡ፡ ብፅዓቲሆሙ፡ ለቅዱስ፡ ሊባኖስ፡ ኀበ፡ ቤተ፡ ክርስቲያን፡ ወይቤልዎሙ፡ ለመነኮሳት፡ አምጻዕነ፡ 
                                <cb n="b"/> ምስሌነ፡ ብእሲተ፡ ዕውርተ፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.5">
                            <locus from="27ra" to="27va"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ወአሐተ፡
                                ዕለተ<supplied reason="omitted">፡</supplied> እንዘ፡ ሀሎ፡ ስርናይ፡
                                መልዕልተ<supplied reason="omitted">፡</supplied> ናሕስ፡ ዘቤተ፡ ክርስቲያን፡ ዘአንበርዎ፡ 
                                ወድዮሙ፡ ውስተ፡ ሐስል፡ ከመ፡ ይትዓቀብ፡ በሕየ፡ ወመጽአ፡ ሠራቂ፡ በሌሊት። ወዓርገ፡ መልዕልተ፡ ናሕስ፡ እንዘ፡
                                አልቦ፡ ዘይሬዕዮ። ወመልሐ፡ መጥባሕቶ፡ ወዘበጦ፡ ለውእቱ፡ ሐስል፡ ወነሥአ፡ ምልዓ፡ ከፈር።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.6">
                            <locus from="27va" to="28ra"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ወ<cb n="b"/>ሀሎ፡ ፩ ብእሲ፡ እምኃራ፡ ንጉሥ፡ ዘደወየ፡ 
                                ወጕህቈ፡ እስከ፡ ይትራከብ፡ መንከሱ፡ ምስለ፡ ብረኪሁ። ወአምጽእዎ፡ ጽዒኖሙ፡ ኃበ፡ 
                                መካኑ<supplied reason="omitted">፡</supplied> ለቅዱስ፡ ወሐጸብዎ፡ እማየ፡ ሕይወት፡ 
                                ዘአውጽአ፡ በማዕተቡ። ወአን<surplus>ን</surplus>በርዎ፡ ጸዊሮሙ፡ ኃበ፡ ዝኅሩ፡ ለቅዱስ። ወአሐተ፡ ዕለት፡
                                እንዘ፡ ይትቀነዩ፡ ካሀናተ፡ ሰምዕዎ፡ እንዘ፡ ይትናቀዋ፡ አዕፅምቲሁ፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.7">
                            <locus from="28ra" to="31rb"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> 
                                ወሀለዉ<supplied reason="omitted">፡</supplied> ውስተ፡ ቤተ፡ ክርስቲያኑ፡ 
                                ለቅዱ<supplied reason="omitted">ስ፡</supplied> ሊባኖስ፡ ፯ መስቀላት፡ ዘወርቅ፡ ወዘብሩር፡
                                ዘወሀብዎሙ፡ ቀደምት፡ ነገሥት፤ ወነሥእዎ፡ ሠረቅት፡ ምስለ፡ ብዙኅ፡ ወርቅ። ወሶ<cb n="b"/>በ፡ ርእዩ፡
                                ካህናት፡ ኃዘኑ፡ ፈድፋደ፡ ወነገርዎ፡ ለንቡረ፡ እድ፡ ገብረ፡ ኢየሱስ፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.8">
                            <locus from="31rb" to="31vb"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ካዕበ፡ ይቤሎሙ፡ እለ፡ ርእዩ፡ በአዕይንቲሆሙ፡ ተጋብአ፡
                                አንስት፡ አመ፡ በዓሉ፡ ለቅዱስ፡ ሊባኖስ፡ ከመ፡ ይትሐፀባ፡ እማየ፡ ሕይወት፡ ዘአውጽአ፡ በማዕተቡ። ወበሳኒታ፡ 
                                መጽአ፡ ከመ<supplied reason="omitted">፡</supplied> 
                                <choice><corr>ይቅረባ፡</corr><sic>ይቅርባ፡</sic></choice> ቍርባነ፡
                                ወአውረዱ፡ ሎቱ፡ ታቦተ፡ ወሠርዑ፡ ቍርባነ። ወትቤሎሙ፡ አሐቲ፡ ብእሲት፡ ለካህናት፡
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.9">
                            <locus from="31vb" to="32vb"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ <gap reason="ellipsis"/> ወሀሎ፡ ፩ ብእሲ፡ በሐም፡ ዘኢይክል፡ ነቢበ፡ ወይስዕል፡
                                ኀበ፡ ቅዱስ፡ ሊባኖስ፡ <pb n="32r"/><cb n="a"/> መዓልተ፡ ወሌሊተ። ወአሐተ፡ ዕለተ፡ ሖረ፡ ኀበ፡ ቤተ፡ 
                                ክርስቲያን፡ እንዘ<supplied reason="omitted">፡</supplied> ሐለዉ፡ ካህናት፡ ይትቀነዩ፡
                                ወቦአ፡ ኀቤሆሙ። ወይቤሎሙ፡ ሰላም፡ ለክሙ፡ አንከሩ፡ ወይቤሉ፡ በምንትኑ፡ ግብር፡ ዘተናገርከነ።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.10">
                            <locus from="32vb" to="33rb"/>
                            <title type="complete"></title>
