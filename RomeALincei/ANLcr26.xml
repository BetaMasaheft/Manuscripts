                   <msItem xml:id="ms_i1">
                       <title ref="LIT6386Libanos"/>
                       <textLang mainLang="gez"/>
                       
                       <msItem xml:id="ms_i1.1">
                        <locus from="5ra" to="22ra"/>
                        <title type="complete" ref="LIT1473GadlaL"/>
                       <incipit xml:lang="gez">
                           በስመ፡ <gap reason="ellipsis"/> እግዚአብሔር፡ ሥሉስ፡ ብሑተ፡ ሀልዎ፡ ዘይክል፡ ቀቲል<supplied reason="omitted">፡</supplied>
                           ወአሕይዎ። መኰንነ፡ ጽድቅ፡ ውእቱ፡ ዘእንበለ፡ አድልዎ፡ ወከመ፡ ሐመድ፡ ለጊሜ፡ ዘይዘርዎ፡ ወከመ፡ ፍተታት፡ ውስተ፡ ምድር፡ ለበረድ፡
                           ዘይፌንዎ። <gap reason="ellipsis"/><cb n="b"/><gap reason="ellipsis"/>
                           ድርሳን<supplied reason="omitted">፡</supplied> ዘብፁዕ፡ ወቅዱስ፡ አባ፡ ሊባኖስ<supplied reason="omitted">፡</supplied>
                           ዘደረሰ፡ አባ፡ ኤልያስ፡ ኤጲስ፡ ቆጶስ፡ ዘአኵስም፡ አዕሚሮ፡ ወሃይማኖቶ፡ ወጽንዓ፡ ትዕግሥቱ፡ ዘከመ፡ ገብረ<supplied reason="omitted">፡</supplied>
                           ሎቱ፡ እግዚአብሔር፡ ተአምራተ፡ ወመንክራተ፤
                       </incipit>
                    </msItem>
                       
                    <msItem xml:id="ms_i1.2">
                        <locus from="22ra" to="64ra"/>
                        <title type="complete" ref="LIT4717TaammerLi"/>
                        <note>53 unnumbered miracles.</note>
                        
                        <msItem xml:id="ms_i1.2.1">
                            <locus from="22ra" to="24vb"></locus>
                            <title type="complete" ref="LIT4717TaammerLi#praise"/>
                            <incipit xml:lang="gez">
                                በስመ፡ ንዌጥን፡ ጽሒፈ፡ ተአምሪሁ ART: ሊባኖስ፡ ለእመ፡ ክህልነ፡ ኅዳጠ፡ ዜንዎ፡ እምብዙኅ፡ ተአምሪሁ፡ ጸሎቱ፡ ወበረከቱ፡ የሀሉ፡ ምስለ፡ ኩልነ፡ ውሉዶደ፡ ጥምቀት፡ ለዓለመ፡ ዓለም፡ አሜን።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2.2">
                            <title type="complete" ref=""/>
                            <incipit xml:lang="gez">
                                ሰላም፡ ለከ፡ ኦቅዱስ፡ ሊባኖስ፡ ፈዋሴ፡ ሥጋ፡ ወነፍስ።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i1.2.3">
                            <locus from="24vb" to="25rb"/>
                            <title type="complete" ref=""/>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ለአቡነ፡ ሊባኖስ። ስምዑ፡ አበውየ፡ ወአኃውየ፡ ተአምረ፡ ወመንክረ፡ ዘአርአየነ፡ እሙነ፡ ዝንቱ፡ አቡነ፡ በሐሊበ፡ ወንጌል፡ ዘተሐጽነ። ጽጌ፡ ቅድስና፡ ዘተከድነ፡ ለምግባረ፡ ጽድቅ፡
                                
                                ንግባዕኬ፡ ኀበ፡ ተአምራቱ፡ ለቅዱስ፡ ሊባኖስ፡ አሐተ፡ ዕለተ፡ አሰነየ፡ አምዕስተ፡ ጠሊ፡ ከመ፡ ይግበር፡ ለመልበሱ።
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.2">
                            <locus from="25rb" to="26ra"></locus>
                            <title type="complete">Story of the man who stole from a dignitary</title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ወካእበ፡ ዜነውኒ፡ እለ CAR: በአዕይንቲሆሙ፡ መጽአ፡ ጸብእሲ፡ እንባ፡ ሰናይት፡ ወተማኅፀነት፡ ኀበ፡ ቤተ፡ ክርስቲያኑ፡ ለቅዱስ፡ ሊባኖስ። ወይቤልዎ፡ መነኮሳት፡ ምንተ፡ ኮንከ። ወይቤሎሙ፡ ምንተ፡ ኮንከ፡ ዘትብሉኒ፡ እስመ፡ አስተዋደዩኒ።
                                
                                መዙንን፡ እንዘ፡ ይብሉ፡ ዝንቱ፡ ብአሲ፡ ሠረቀ፡ ንዋየከ፡ አንሰ።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.3">
                            <locus from="26ra" to="26va"></locus>
                            <title type="complete">Story of a thief named 'Arga from the land of the Galla who
                                had stolen bees</title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ካዕበ፡ ስምዑ፡ አበውየ፡ ወአኃውየ፡ ተአምሪሁ፡ ለዝአቡነ፡ ኮከበ፡ ሮምያ፡ ትዮጵያ። ወጸፅለተ፡ መጽአ፡ ጐሕልያ፡ ኀበ፡ ቤተ፡ ክርስቲያን፡ ዘተሐንፀት፡ በስሙ፡ ለቅዱስ፡ ሊባኖስ፡ ዘይብልዋ፡ ዓርጋ፡ ዘምድረ፡ ጋላ። ወካእበ፡ መጽአ፡ ጐሕልያ፡ ካልዕ፡ ወተራከቡ፡ ሀየ፡ ወሠሥረቆ፡ ንህበ፡ ለካልዑ።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.4">
                            <locus from="26va" to="27ra"></locus>
                            <title type="complete">On healing of a blind woman</title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ካዕበ፡ ስምዑ፡ ዜና፡ ተአምሪሁ፡ ለዝአቡነ፡ ፀሐይ፡ ዘኢየዓርብ፡ ማኅቶት፡ ዘኢይጠፍዕ። ወአሐተ፡ ዕለተ፡ መጽኡ፡ ዕደው፡ ጊዜ፡ ዕርበተ፡ ፀሐይ፡ ወምስሌሆሙ፡ ዓቢይ፡ በግዕ። ወወሀቡ፡ ብፅዓቲሆም፡ ለቅዱስ፡ ሊባኖስ፡ ኀበ፡ ቤተ፡ ክርስቲያን። ወይቤልዎሙ፡ ለመነኮሳት። አምጻዕነ፡ ምስሌነ፡ ብእሲተ፡ ዕውርተ።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.5">
                            <locus from="27ra" to="27va"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ... ወአሐተ፡ ዕለተ፡ እንዘ፡ ሀሎ፡ ስርናይ፡ መልዕልተ፡ ናሕስ፡ ዘቤተ፡ ክርስቲያን፡ ናንበርዎ፡ ወድዮሙ፡ ውስተ፡ ሐስል፡ ከመ፡ ይትዓቀብ፡ በሕየ፡ ወመጽአ፡ ሠራቂ፡ በሌሊት። ወዓርገ፡ መልዕልተ፡ ናሕስ፡ እንዘ፡ አልቦ፡ ዘይሬዕዮ። ወመልሐ፡ መጥባሕቶ፡ ወዘበጦ፡ ለውእቱ፡ ወነሥአ፡ ምልዓ፡ ከፈር።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.6">
                            <locus from="27va" to="28ra"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ... ወሀሎ፡ ፳ ብእሲ፡ እምኃራ፡ ንጉሥ፡ ዘደወየ፡ ወጉጐህቄ፡ እስከ፡ ይትራከብ፡ መንከሱ፡ ምስለ፡ ብረኪሁ። ወአምጽእዎ፡ ጽዒኖሙ፡ ኃበ፡ መካኑ፡ ለቅዱስ፡ ወሐጸብዎ፡ እማየ፡ ሕይወት፡ ዘአውጽአ፡ በማዕተቡ። ወአንበርዎ፡ ጸዊሮሙ፡ ኃበ፡ ዝኅሩ፡ ለቅዱስ። ወአሐተ፡ ዕለት፡ እንዘ፡ ይትቀነዩ፡ ካሀናተ፡ ሰምዕዎ፡ እንዘ፡ ይትናቀዋ፡ አዕፅፅምቲሁ።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.7">
                            <locus from="28ra" to="31rb"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ... ወሀለዉ፡ ውስተ፡ ቤተ፡ ክርስቲያኑ፡ ለቅዱስ፡ ሊባኖስ፡ መስቀላት፡ ዘወርቅ፡ ወዘብሩር፡ ዘወሀብዎሙ፡ ቀደምት፡ ነገሥት፡ ወነሥእዎ፡ ሠረቅት፡ ምስለ፡ ብዙኅ፡ ወርቅ። ወሶበ፡ ርእዩ፡ ካህናት፡ ኃዘኑ፡ ፈድፋደ፡ ወነገርዎ፡ ለንቡረ፡ እድ፡ ገብረ፡ አላን።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.8">
                            <locus from="31rb" to="31vb"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ... ርእዩ፡ በአዕይንቲሆሙ፡ ተጋብአ፡ አንስት፡ አመ፡ በዓሉ፡ ለቅዱስ፡ ሊባኖስ፡ ከመ፡ ይትሐፀባ፡ እማየ፡ ሕይወት፡ ዘአውጽአ፡ በማዕተቡ። ወበሳኒታ፡ መጽአ፡ ከመ፡ ይቅረባ፡ ወአውረዱ፡ ሎቱ፡ ታቦተ፡ ወሠርዑ፡ ሞርባነ። ወትቤሎሙ፡ አሐቲ፡ ብእሲት፡ አኑጕት።
                                
                                
                            </incipit>
                        </msItem>
                        
                        <msItem xml:id="ms_i2.9">
                            <locus from="31vb" to="32vb"/>
                            <title type="complete"></title>
                            <incipit xml:lang="gez">
                                ተአምሪሁ፡ ... ወሀሎ፡ አብእሲ፡ በሐም፡ ዘኢይክል፡ ነቢበ፡ ወይስዕል፡ ኃበ፡ ቅዱስ፡ ሊባኖስ። መዓልተ፡ ወሌሊተ። ወአሐተ፡ ዕለተ፡ ሖረ፡ ኃበ፡ ቤተ፡ ክርስቲያን፡ እንዘ፡ ሐለዉ፡ ካህናት፡ ይትቀነዩ፡ ወቦአ፡ ኃቤሆሙ። ወይቤሎሙ፡ ሰላም፡ ለክሙ፡ አንከሩ፡ ወይቤሉ፡ በምንትኑ፡ ግብር፡ ዘተናገርከነ።
                                
                                
                            </incipit>
                        </msItem>
                        
