                        <summary/>
                        <msItem xml:id="ms_i1">
                            <locus from="5ra" to="6rb"/>
                            <title ref="LIT3994Hymn"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሃሌ፡ ሃሌ፡ ሃሌ፡ ሉያ፡ ሃሌ፡ ሃሌ፡ ሉያ፡ እአትብ፡ ወዕት<surplus>ተ</surplus>ነሣእ፡ በስመ፡ <gap reason="ellipsis"/>
                                ፫ አስማተ፡ ነሢእየ፡ እትመረጐዝ፡ እምኒ፡ ወደቁ፡ እትነሣእ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ወእመኒ፡
                                ሖርኩ፡ ውስተ፡ ጽልመት፡ እግዚአብሔር፡ ያበርህ፡ ሊተ፡ እግዚአብሔር፡ ተወከልኩ። ነአኵተከ፡ ወጸሎተ፡ ሃይማኖት። በል። ይትባረክ፡ 
                                እግ<cb n="5rb"/><supplied resp="PRS8999Strelcyn" reason="omitted">ዚአብሔር፡ አምላክ፡</supplied> እስራኤል፡ ዘገብረ፡
                                ዓቢየ፡ ወመንክረ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2">
                            <locus from="6rb" to="7va"/>
                            <title ref="LIT3995Hymn"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ግነዩ፡ ለእግዚአብሔር፡ ወጸውዑ፡ ስሞ፡ ሃሌ፡ ሉያ፡ ወንግርዎሙ፡ ለአሕዛብ፡ ምግባሮ። ግነዩ፡ 
                                ለአግዚአብሔር<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> እስመ፡ ኄር፡ ሃሌ፡ ሉያ፡ እስመ፡ ለዓለም፡ ምሕረት።
                                ግነዩ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i3">
                            <locus from="7va" to="8rb"/>
                            <title ref="LIT4631Praise"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">እዌድሰኪ፡ ኦድንግል፡ ምልዕተ፡ ውዳሴ፡ መጠነ፡ ይ<cb n="7vb"/>ክል፡ አፉየ፡ 
                                አስተበፅዕ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ዕበየኪ፤ ልሳነ፡ ኪሩቤል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <locus from="8rb" to="9ra"/>
                            <title ref="LIT5932PrayerBE"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ተዘከር<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> እግዚኦ፡ ኪዳነ፡ 
                                አግብርቲከ፡ ቅዱሳን፡ ኪ<pb n="8va"/>ዳነ፡ አብርሃም፡ ይስሐቅ፡ ወያዕቆብ፡ ምእመናኒከ፡ <gap reason="ellipsis"/> 
                                ተዘከር<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> እግዚኦ፡ ቅንዓተ፡ ሙሴ፡ ገብርከ፡
                                <gap reason="ellipsis"/> ተዘ<supplied resp="PRS8999Strelcyn" reason="omitted">ከር፡</supplied> እግዚኦ፡ ጽድቆ፡ 
                                ለዳዊት፡ ዘለሊከ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <locus from="9ra" to="10rb"/>
                            <title ref="LIT6281Neihabeya"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ንዒ፡ ኀቤየ፡ ኦድንግል፡ ምስለ፡ ወልድኪ፡ <gap reason="ellipsis"/>
                                <supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied><gap reason="ellipsis"/> ንዒ፡ ኀቤየ፡ ኦድንግል፡ ምስለ፡
                                አዳም፡ ወአቤል፡ <gap reason="ellipsis"/> ንዒ፡ ኀቤየ፡ ኦድንግል፡ ምስለ፡ ሄኖክ፡ ወኖኅ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i6">
                            <locus from="10rb" to="10vb"/>
                            <title ref="LIT3023RepCh303"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><supplied resp="PRS8999Strelcyn" reason="omitted">ተ</supplied>ፈሥሒ፡ 
                                እምልዕ<supplied resp="PRS8999Strelcyn" reason="omitted">ል</supplied>ተ፡ ጸጋ፡ እግዚአብሔር፡ ምስሌኪ፡ ቡርክት፡ አንቲ፡ 
                                ወቡሩክ፡ ፍሬ፡ ከርሥኪ። ተፈሥሒ፡ ኦሙሓዘ፡ ፍሥሐ፡ ቡርክት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i7">
                            <locus from="10vb" to="11va"/>
                            <title ref="LIT6282Nesebbeho"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ንሴብሖ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ለእግዚአብሔር፡
                                ለዘበስብሐተ፡ ቅዱሳን፡ <gap reason="ellipsis"/><supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied>
                                <gap reason="ellipsis"/> ቅዱስ፡ ቅዱስ፡ ቅ<supplied resp="PRS8999Strelcyn" reason="omitted">ዱስ</supplied>፡ 
                                እግዚአብሔር፡ ዘበአርያም፡ <gap reason="ellipsis"/> ቅ<supplied resp="PRS8999Strelcyn" reason="omitted">ዱስ፡</supplied>
                                ቅ<supplied resp="PRS8999Strelcyn" reason="omitted">ዱስ</supplied>፡
                                ቅ<supplied resp="PRS8999Strelcyn" reason="omitted">ዱስ</supplied>፡ እግዚአብሔር፡ ዘበ፫ ግጻዌ፡ ወዘበ፩ ህላዊ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i8">
                            <locus from="11va" to="15vb"/>
                            <title ref="LIT6282Nesebbeho"/>
                            <note>The quoted text is described by Stefan Strelcyn as the beginning of a new text in 
                                <bibl><ptr target="bm:Strelcyn1976Catalogue"/><citedRange unit="page">191</citedRange></bibl>,
                                but in the work description in <ref type="work" corresp="LIT6282Nesebbeho"/>, the following phrase is quoted as the 
                                end of this litany.</note>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><supplied resp="PRS8999Strelcyn" reason="omitted">ገነይነ፡</supplied> ለኪ፡ ኦወለተ፡ ዳዊት፡
                                ክብረ፡ ኵሉ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ዓለም፡ ዳግሚት፡ አርያም፡ 
                                <gap reason="ellipsis"/> <supplied resp="PRS8999Strelcyn" reason="omitted">ገ</supplied>ነይነ፡ ለኪ፡ ኦወለተ፡ ዳዊት፡ 
                                ዳግሚት፡ ሰማይ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <locus from="15vb" to="27vb"/>
                            <title>Liturgical admonitions for the office of midnight and indications of the readings from the Old and the New Testament</title>
                            <textLang mainLang="gez"/>
                            <note>Possibly excerpts from <ref type="work" corresp="LIT1019Actsof"/>.</note>
                            <incipit xml:lang="gez">ወጊዜ፡ መንፈቀ፡ ሌሊት<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ጸለዩ፡ 
                                ጳውሎስ፡ <gap reason="ellipsis"/><pb n="16va"/><gap reason="ellipsis"/> መንፈቀ፡ ሌሊት፡ እትነሣእ፡ በል።
                                <gap reason="ellipsis"/> ዘማቴዎስ፡ <gap reason="ellipsis"/><cb n="18rb"/><gap reason="ellipsis"/> ጳውሎስ፡ ኦሪት፡ 
                                ዘሌዋውያን፡ ወነበቦ፡ እግዚአብሔር፡ ለሙሴ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i10">
                            <locus from="27vb" to="28va"/>
                            <title ref="LIT6287Mahtota"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez"><sic resp="CH">ሳሊ፡</sic> ለነ፡ ማርያም፡ ማኅቶተ፡ ዓለም፡ ስብሐት፡ በአርያም። 
                                <supplied resp="PRS8999Strelcyn" reason="omitted">ሰአሊ፡</supplied> ለነ፡ 
                                ማር<supplied resp="PRS8999Strelcyn" reason="omitted">ያም</supplied>፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i11">
                            <locus from="27vb" to="33rb"/>
                            <title ref="LIT5694LukeSalam"/>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i11.1">
                                <locus from="27vb" to="28va"/>
                                <title>The Annunciation to Mary (Luke 1:26–38)</title>
                                <note>Indicated as ‘Luke 1:16–38’ in <bibl><ptr target="bm:Strelcyn1976Catalogue"/>
                                    <citedRange unit="page">191</citedRange></bibl>, which is probably a mistake for ‘Luke 1:26–38’.</note>
                                <textLang mainLang="gez"/>
                            </msItem>
                            <msItem xml:id="ms_i11.2">
                                <locus from="29rb" to="33rb"/>
                                <title ref="LIT4272Salam"/>
                                <textLang mainLang="gez"/>
                                <incipit xml:lang="gez">ይቤላ፡ መልአክ፡ ሰላም፡ ለኪ፡ ይቤላ፡ ገብርኤል፡ ሰላም፡ ለኪ፡ 
                                    ማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied><gap reason="ellipsis"/><cb n="30rb"/>
                                    <gap reason="ellipsis"/> ሰላም፡ ለኵሎን፡ መልክዕኪ፡ ማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied>
                                    ለዝክረ፡ ስምኪ፡ እም፡ <surplus>እምነ፡</surplus> ጸቃውዕ፡ ጥዑም፡ ማርያም፡ አንቲ፡ ወለተ፡ አዳም፡ ሰፋኒት፡ በርኅበ፡ ዓለም፡ በሰጊድ፡ ሰላም። ለሥእርትኪ፡
                                    ሰላም፡ ዘድላሌሁ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ጸሊም፡</incipit>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i12">
                            <locus from="33rb" to="35va"/>
                            <title ref="LIT3023RepCh303"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ተፈሥሒ፡ ማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ድንግልተ፡ 
                                ሥጋ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ወሕሊና፡ ተፈሥሒ፡ <pb n="33va"/>
                                ማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ወለተ፡ ኢ<add place="below">ያ</add>ቄም፡
                                ወሐና፡ ጳጦስ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i13">
                            <locus from="35va" to="36vb"/>
                            <title ref="LIT3064RepCh344"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">እሴብሕ፡ ጸጋኪ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> እምልዕተ፡ ጸጋ፡
                                ወትጋነይ፡ ለኪ፡ ኦምልዕተ፡ ውዳሴ።</incipit>
                        </msItem>
                        <msItem xml:id="ms_i14">
                            <locus from="36vb" to="37va"/>
                            <title ref="LIT5851Prayer"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሃሌ፡ ሉያ፡ <sic>ነአኵተከ፡</sic> እግዚእ፡ ንሴብሐከ፡ ንባርከከ፡ ስቡሕ፡ ስምከ፡ <gap reason="ellipsis"/> 
                                <pb n="37ra"/> ሃሌሉያ፡ መሐረነ፡ እግዚኦ፡ <gap reason="ellipsis"/><cb n="37rb"/> ሃሌ፡ ሉያ፡ በወልታ፡ ዚአከ፡ ከልለነ፡ 
                                እግዚኦ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ከመ፡ ንኩን፡ ንቁሓነ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i15">
                            <locus from="37va" to="42rb"/>
                            <title ref="LIT7889Prayers"/><!-- Issue #3360  -->
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በ<cb n="37vb"/>ጸሎታ፡ ወበስእለታ፡ ለእግዝእትነ፡ 
                                ማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied>
                                ተ<add place="below">ሣ</add>ሃለነ፡ እግዚኦ። <gap reason="ellipsis"/><pb n="38ra"/><gap reason="ellipsis"/>
                                በጸሎቱ፡ ወበስእለቱ፡ ወበስምዓ፡ ሞቱ፡ ለበርተሎሜዎስ፡ ሐዋርያከ፡ <gap reason="ellipsis"/><cb n="38vb"/><gap reason="ellipsis"/>
                                በጸሎተ፡ ኤዎስጣቴዎስ፡ አቡነ፡ ድንግል፡ <gap reason="ellipsis"/><pb n="39ra"/> በጸሎተ፡ ሐና፡ ወኢያቄም፡ 
                                ዘወለድዋ<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> 
                                ለማርያም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied></incipit>
                        </msItem>
                        <msItem xml:id="ms_i16">
                            <locus from="42rb" to="48va"/>
                            <title ref="LIT1219Bible" type="incomplete">Readings from the Old and New Testament</title>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ዘማርቆስ፡ ወበእንተሰ፡ ለይእቲ፡ ዕለት፡ ወለኪያሃ፡ ሰዓት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i17">
                            <locus from="48va" to="55ra"/>
                            <title>Collection of salām-hymns</title>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i17.1">
                                <locus from="48va" to="49ra"/>
                                <title ref="LIT6558Salam"/>
                                <incipit xml:lang="gez">ሰላም<supplied resp="PRS8999Strelcyn" reason="omitted">፡</supplied> ለኪ፡ ሞገስነ፡ ወክብርነ፡
                                        </incipit>
                            </msItem>
                            <msItem xml:id="ms_i17.2">
                                <locus from="49ra" to="49va"/>
