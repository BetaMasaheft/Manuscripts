                    <msContents>
                        <summary>Protective Prayers</summary>
                        <msItem xml:id="ms_i1">
                            <title ref="LIT1878Marbab"/>
                            <textLang mainLang="gez"/>                            
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> መርበብተ፡ ሰሎሞን፡ ዘረበቦሙ፡ ለአጋንንት፡ ከመ፡ 
                                መርበብተ<supplied reason="omitted">፡</supplied> አሣ፡ ዘማዕከለ፡ ባሕር፡ እንዘ፡ ይብል፡ ሰዳቃኤል፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i2"><!-- Issue #3334 -->
                            <title ref="LIT7865PrSalomon"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ወካዕበ፡ አስማተ፡ ሰሎሞን፡ ጽድርያስ፡ አያስ፡ <gap reason="ellipsis"/> ስሙ፡ ለእግዚአብሔር፡ አሐዘ፡ ሰሎሞን፡ አድኅነኒ፡
                                እምእደዊሆሙ፡ ለነሃብት፡ ወእምአቃብያነ፡ ሥራይ፡ ከማሁ፡ ሠውረኒ፡ ወአድኅነኒ፡ ሊቀ፡ ለገብርከ፡ <gap reason="lost"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i3"><!-- Issue #3335 -->
                            <title ref="LIT7866GodSalomon"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ወእምድኅረ፡ አሐዝዎ፡ ለሶሎሞን፡ ወአንበርዎ፡ ለሰሎሞን፡ እስከ፡ ሠሉስ፡ ዕለት፡ አምሳለ፡ ንውም፡ <gap reason="ellipsis"/>
                                ወአተበ፡ ገጸ፡ ሰሎሞን፡ እንዘ፡ ይብለ፡ በስመ፡ <gap reason="ellipsis"/> አአትብ፡ ገጽየ፡ ወኵለንታየ፡ እምብዝኃ፡ ድንጋፄ፡ ፍጥረቶሙ፡ ለነሃብት፡ ርኩሳን፡
                                ወሥጋየ፡ ወተሠሃለኒ፡ ሊተ፡ ገብርከ፡ <gap reason="lost"/></incipit>
                        </msItem>
                        <msItem xml:id="ms_i4">
                            <title ref="LIT7445PPQahashun">Prayer against Bāryā and Legewon, pleurisy (guśǝmt), Budā, Falāšā, wǝgʾāt and ʾaynat</title>
                            <note>Directed against the demons Bāryā and Legewon, as it is the case in another attestation in
                                <ref type="mss" corresp="BLorient11339"/>, but in addition also against the demon Budā, as well as against various
                                diseases like fǝlṣat (headache), qʷǝrḍat (stomach ache), Magāññā (colic with bad stomach ache caused by the tapeworm),
                                guśǝmt (chronic pleurisy with cough) and wǝgʿāt (rheumatism or stroke), against the Falāšā (Beta ʾƎsrāʾel) and against the
                                Evil Eye.</note>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ቃሐሹን፡ ቃሐሹን፡ ቃሐሹን፡ <gap reason="ellipsis"/> በዘቦቱ፡ ሞኦሙ፡ ለባርያ፡ ወሌጌዎን፡ ለፍልፀት፡ ወለቍርፀት፡
                                ለመጋኛ፡ ወጉሥምት፡ ለቡዳ፡ ወፈላሻ፡ ለውግአት፡ ወለአይነት፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i5">
                            <title>Ṣalotāt baʾǝnta masṭǝma ʾagānǝnt</title><!-- Issue #3336-->
                            <note>Prayers of the type masṭǝma ʾagānǝnt (drowner of demons)</note>
                            <textLang mainLang="gez"/>
                            <msItem xml:id="ms_i5.1">
                                <title ref="LIT7867MastemaYan"/>
                                <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ መስጥመ፡ አጋንንት፡ ያናኤላን፡ ቤሃቄ፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i5.2">
                                <title ref="LIT7868MastemaYas"/>
                                <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ መስጥመ፡ አጋንንት፡ ያሸምክት፡ ያሸምክት፡ ያሸምክት፡ ያሸምክት፡ ያሸምክት፡ ያሸምክት፡ ያሸምክት፡ ያሸምክት፡
                                    የሐል፡ ጥብሐል፡ ጥብሐል፡ ጥብሐል፡ ጥብሐል፡ ጥብሐል፡ ጥብሐል፡ ጥብሐል፡</incipit>
                            </msItem>
                            <msItem xml:id="ms_i5.3">
                                <title ref="LIT7869MasteLayal"/>
                                <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ መስጥመ፡ አጋንንት፡ ለያለፈሄም፡ ቁረጸሼሀ፡</incipit>
                            </msItem>
                        </msItem>
                        <msItem xml:id="ms_i6"><!-- Issue #3338 -->
                            <title ref="LIT7871WegatMetat"/>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ሕማመ፡ ውግዓት፡ ወምትአት፡ አኽላ፡ በላኽላኽ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i7"><!-- Strelcyn: Salām au flanc de Jésus-Christ. Prière contre le point de côté. -->
                            <title>Prayer against a stitch in the side</title>
                            <note>Magic prayer against a stitch in the side, which begins with the 15th stanza of 
                                <ref type="work" corresp="LIT2842RepCh125"/> and possibly resembles <ref type="work" corresp="LIT4625Prayer"/>.</note>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ሰላም፡ ለገቦከ፡ ኵናተ፡ ለንጊኖስ፡ ዘወግዖ፡</incipit><!-- Salām to your flank. The arrow pierced Langinos -->
                        </msItem>
                        <msItem xml:id="ms_i8"><!-- Part of text or decoration? -->
                            <title>Magic glyphs</title>
                            <note><term key="MagicSymbols">Magic glyphs (charaktêres)</term>.</note>
                        </msItem>
                        <msItem xml:id="ms_i9">
                            <title>Prayer against Bāryā and blacksmiths</title>
                            <note>Similar to <ref type="work" corresp="LIT4620Prayer"/>, but also directed to the demon Bāryā.</note>
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎት፡ በእንተ፡ ባርያ፡ ወነሃብተ፡ ሰብእ፡ አላሁማ፡ ወያኑራ፡</incipit>
                        </msItem>
                        <msItem xml:id="ms_i10">
                            <title ref="'LIT5888AsmatPrayer">Prayer against blacksmiths and Budā</title><!-- Strelcyn: Prière contre les forgerons es les buda. (Plural for Budā!)? -->
                            <textLang mainLang="gez"/>
                            <incipit xml:lang="gez">ጸሎት፡ በእንተ፡ ነሃብተ፡ ሰብእ፡ ወቡዳ፡ ጠቢብ፡ ሀሮጉሮፓስ፡ አርከ፡</incipit>
                        </msItem>
