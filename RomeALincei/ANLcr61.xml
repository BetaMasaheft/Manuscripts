                            <msItem xml:id="ms_i2.1">
                                <locus from="42ra" to="49va"/>
                                <title ref="LIT1960Mashaf#AnaphoraLord"/>
                                <incipit xml:lang="gez">አኰቴተ፡ ቁርባን<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied>
                                    ዘእግዚእነ፡ ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ በረከቱ፡ <gap reason="ellipsis"/> ነአኵተከ፡ አምላክ፡ ቅዱስ፡ 
                                    ፈጻሜ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ነፍስነ፡ ወሀቤ፡ ሕይወትነ፡ 
                                    ዘኢይማስን<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> መዝገብ፡ አቡሁ፡ ለዋህድ፡ ወልድከ፡
                                </incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i2.2">
                                <locus from="49vb" to="57rb"/>
                                <title ref="LIT1960Mashaf#SerataQeddase" type="incomplete">Fragments of the Śǝrʿāta qǝddāse</title>
                                <incipit xml:lang="gez">ይካ፡ ነአኵቶ፡ ለገባሬ፡ ሠናያት፡ ላዕሌነ፡ 
                                    እግዚአብሔር<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> መሐሪ፡ አቡሁ፡ 
                                    ለእግዚ<supplied reason="omitted" resp="PRS8999Strelcyn">እ</supplied>ነ፡ አምላ<pb n="50ra"/>ክነ፡
                                    ወመድኃኒነ፡ ኢየሱስ፡ ክርስቶስ፡ እስመ፡ ሰወረነ፡ ወረድዓነ፡ 
                                    ዓቀበነ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ወአቅረበነ፡ <gap reason="ellipsis"/>
                                    ይዲ፡ ጸልዩ፡ ይካ፡ እግዚእ፡ እግዚኦ፡ እግዚአብሔር፡ አኃዜ፡ ኵሉ፡</incipit>
                            </msItem>
                            
                            <msItem xml:id="ms_i2.3">
                                <locus from="57rb" to="63va"/>
                                <title ref="LIT1960Mashaf#SerataQeddaseFethat"/>
                                <incipit xml:lang="gez" type="inscriptio">
                                    ፍትሐ<supplied reason="omitted" resp="PRS8999Strelcyn">ት</supplied>፡ ዘወልድ፡</incipit>
                                <textLang xml:lang="gez"/>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i3">
                            <locus from="73ra" to="88vb"/>
                            <title ref="LIT1959Mashaf"/>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="omitted"/> መጽሐፈ፡ ቄደር፡ ቀዳሜ፡ ሕግ፡ ዘአበው፡ ፫፻፲ወ፰ ርቱዓነ፡ ሃይማኖት፡ 
                                በእንተ፡ ዘድኅፀ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> እምትእዛዘ፡ እግዚአብሔር፡</incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i4">
                            <locus from="88vb" to="92va"/>
                            <title ref="LIT1931Mashaf"/>
                            <note>Indicated as ‘Prayer of penitence’ in <bibl><ptr target="bm:Strelcyn1976Catalogue"/>
                                <citedRange unit="page">172</citedRange></bibl>.</note>
                            <incipit xml:lang="gez">ጸሎተ፡ ንስሐ፡ እግዚእ፡ እግዚኦ፡ አኃዜ፡ ኵሉ፡ ዓለም፡</incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i5">
                            <locus from="92va" to="99vb"/>
                            <title ref="LIT1956Mashaf"/>
                            <incipit xml:lang="am"><foreign xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ናሁ፡ ጸሐፍኩ፡ መጽሐፈ፡ ኑዛዜ፡
                                በዘአአምር<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ኃጢአትየ፡ ዘገበርክዎ፡ ነአኵቶ፡ 
                                ለገባሬ፡ ሠናያት፡ ላዕሌነ፡ በል። <gap reason="ellipsis"/></foreign> ኃጢአት፡ ሥሯ፡ ከብትን፡ መውደድ፡ እግዚአብሔርን፡ መካድ፡ ነው፡
                                ገበርኩ፡ ማለት፡ ነው፡ <pb n="93ra"/> የሚናዝዝ፡ መጽሐፍ፡ አዋቂ፡ ቢሆን፡ ይዞ፡ ያንብብ፡ የማያውቅ፡ ቢሆን፡ መምሕሩ፡ ይዞ፡ ያንብብ፡ የሚናዘዝ፡ 
                                ፍቱኝ፡ ይበል፡ ቄሱን፡ እግዚአብሔር፡ ይፍታ፡</incipit>
                            <textLang xml:lang="am" otherLangs="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i6">
                            <locus from="100ra" to="117va"/>
                            <title ref="LIT1111Anqasa"/>
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> 
                                ተመየጥ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ኀበ፡ ንስሐ፡ ዘተቀድሐ፡ እም፹ወ፩፡ መጻሕፍት፡
                                ዘይሁብ፡ ለቀሲስ፡ ከመ፡ ኃጢአቱ፡ ለሰብእ፡ ጾም፡ ወጸሎት፡ ወብሩረ፡ ወሰጊድ፡ ዘኢተምሕረ፡ ቀሲስ፡</incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i7">
                            <locus from="123ra" to="125va"/>                            
                            <title ref="LIT3131Prayer"/>
                            <incipit xml:lang="gez">አብ፡ ወወልድ፡ ወመንፈስ፡ ቅዱስ፡ ሰዳዲሆሙ፡ ለአጋንንት፡ ስድዶሙ፡ እግዚኦ፡ ለአጋንንት፡ እምየማንነ፡ 
                                ወእምፀጋምነ፡ ወእምዛቲ፡ መካንነ፡ ይርኃቁ፡ እምኔነ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied>
                                    </incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i8">
                            <locus from="125va" to="132va"/>
                            <title ref="LIT1931Mashaf#Blessings"/><!-- Are the other textparts below and above components of LIT1931Mashaf as well? -->
                            <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> ጸሎተ፡ ቡራኬ፡ ዘአቡነ፡ አባ፡ ሳሙኤል፡ ለዘአዕረፈ፡ እኁነ፡ ይምሐሮ፡
                                ወይሣሃሎ፡ እግዚአብሔር፡</incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i9">
                            <locus from="133ra" to="143vb"/>
                            <title ref="LIT4711Mastabqwe"/>
                            <incipit xml:lang="gez">ወካዕበ፡ ናስተበቍዓ፡ ለንግሥተ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ኵልነ፡ 
                                በል። ጸልዩ። ቅድመ፡ ሥዕላ፡ ለቅድስት፡ ድንግል፡ መርዓተ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> አብ፡
                            </incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i10"><!-- cf. Issue #3330 -->
                            <locus from="143vb" to="144va"/>
                            <title ref="LIT7862PrSatan">Wa-bazǝntu ʾasmāt wadqa Diyābǝlos mǝsla śarāwitu</title>
                            <incipit xml:lang="gez">አካስ፡ አሜዕ፡ ሌኪ፡ ኢንክዕ፡ ክቤዕ፡ በርናኬ፡ ኬም፡ <gap reason="ellipsis"/><cb n="144rb"/>
                                <gap reason="ellipsis"/> ወበዝንቱ፡ አስማት፡ ወድቀ፡ ዲያብሎስ፡ ምስለ፡ ሠራዊቱ፡ ተዓጺፎ፡ ጽልመተ፡ ሌሊት፡ ከማሁ፡ አውድቆሙ፡ ለፀርየ፡
                                <supplied reason="omitted" resp="PRS8999Strelcyn">ወ</supplied>ለጸላ<pb n="144va"/>እትየ፡ ሊተ፡ ለገብርከ፡
                                    </incipit>
                            <textLang xml:lang="gez"/>
                        </msItem>
                        
                        <msItem xml:id="ms_i11">
                            <locus from="145ra" to="147vb"/>
                            <title ref="LIT2300Sebhat"/><!-- #3331 -->
                            <textLang xml:lang="gez"/>
                            
                            <msItem xml:id="ms_i11.1">
                                <locus from="145ra" to="147vb"/>
                                <title ref="LIT7863SalamMikael"/>
                                <incipit xml:lang="gez">ሰላም፡ ለከ፡ ሚካኤል፡ መልአክ፡ ምክሩ፡ 
                                    ልዑል<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ኀበ፡ ምዕራፉ፡ በል። ሚካኤል፡ መጋቢ፡ ለነፍሰ፡
                                    ኵሉ፡ ፍጥረት፡ እምህለከ፡ በፀባዖት። ምህላነ፡ ስማዕ፡ በዛቲ፡ ሰዓት፡ ሚካኤል፡ መራሂ፡ 
                                    ለእለ<supplied reason="omitted" resp="PRS8999Strelcyn">፡</supplied> ውስተ፡ ባሕር፡ ወየብስ፡</incipit>
                                <textLang xml:lang="gez"/>
                            </msItem>
                        
                            <msItem xml:id="ms_i11.2">
                                <locus from="147va" to="149vb"/>
                                <title ref="LIT7864HymnGabriel"/>
                                <incipit xml:lang="gez">አስተምህር፡ ለነ፡ ገብርኤል፡ አስተምህር፡ ለነ፡ ገብርኤል፡ ዘአብሰርካ፡ ለድንግል፡ በበምዕራፉ፡ በል። ነዓ፡ ገብርኤል፡
                                    ዘአብሰርካ፡ ለድንግል፡</incipit>
                                <textLang xml:lang="gez"/>
                            </msItem>
                        </msItem>
                        
                        <msItem xml:id="ms_i11.3">
                            <locus from="149vb" to="154rb"/>
                            <title ref="LIT4957SebhataF"/>
                            <note>Shorter version.</note>
                            <incipit xml:lang="gez">ትባርኮ፡ ነፍስየ፡ ለእግዚአብሔር፡ ፫ በል። ሰአል፡ ለነ፡ ጊዮርጊስ፡ ሰአል፡ ለነ፡ ጊዮርጊስ፡ ሰማዕተ፡ ኢየሱስ፡ ክርስቶስ፡ ወነዓ፡
                                ፍቁርየ፡ ዘልዳ፡ ንጉሥ። ነዓ፡ ጊ<pb n="150ra"/>ዮርጊስ፡ ሰማዕተ፡ ኢየሱስ፡ ክርስቶስ፡ ወነዓ፡ ፍቁርየ፡ ዘልዳ፡</incipit>
                            <textLang xml:lang="gez"/>
                            
                            <msItem xml:id="ms_i11.4">
                                <locus from="154va" to="162rb"/>
                                <title ref="LIT1110Anqasa"/><!-- Similar to EMIP00701#ms_i2 -->
