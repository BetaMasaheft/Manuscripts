                           </decoNote>                                  

                               <decoNote type="miniature" xml:id="d3">
                                   <locus target="#4v"/>
                                   <desc>A fine miniature of <ref type="authFile" corresp="AT1031VirginAndChil">the Virgin with Child</ref>, and two angels standing, on a piece of 
                                   modern paper (?) protected by a textile curtains</desc>
                               </decoNote>  
     
                           <decoNote type="Headband" xml:id="d4">    
