                        <handDesc>
                            <handNote xml:id="h1" script="Ethiopic">
                                <date notBefore="1981" notAfter="1982">1981/82.</date>
                                <desc>Irregularly spaced characters; hasty appearance.</desc>
                                <seg type="rubrication">Holy names.</seg>
                            </handNote>
                        </handDesc>

                        <decoDesc>
                            <summary>The manuscript contains a collection of six illuminations painted on singletons and glued to a book. 
                                They were executed by the Ethiopian artists <persName
                                    ref="PRS15506GabraKr">Gabra Krǝstos Solomon</persName> who signed his name at the bottom of the first five paintings
                                together with the date <date notBefore="1981" notAfter="1982">1974 AM (1981/82 CE)</date> in which they were painted. </summary>
                            
                            <decoNote xml:id="d1" type="miniature">
                                <locus target="#1r"/>
                                <desc>An ecclesiastical figure with a book in one hand and a
                                    flywhisk in the other.</desc>
                                <q xml:lang="am">አዛውንቱ፡ መጽሐፍ፡ ሲዳግሙ</q>
                            </decoNote>
                            
                            <decoNote xml:id="d2" type="miniature">
                                <locus target="#2r"/>
                                <desc>King <persName ref="PRS3417David">David</persName> playing the
                                    harp.</desc>
                                <q xml:lang="am">ዳዊት፡ በበገና፡ ድርዳራ፡</q>
                            </decoNote>
                            
                            <decoNote xml:id="d3" type="miniature">
                                <locus target="#3r"/>
                                <desc>Saint <persName ref="PRS10245Yared">Yared</persName>.</desc>
                                <q xml:lang="am">ያሬድ፡ ካህን፡ በዝማሬ፡</q>
                            </decoNote>
                            
                            <decoNote xml:id="d4" type="miniature">
                                <locus target="#4r"/>
                                <desc>A musician playing a flute.</desc>
                                <q xml:lang="am">ባለዋሸንቱ፡ በዋሸንት፡ ጨዋታ ላይ</q>
                            </decoNote>
                            
                            <decoNote xml:id="d5" type="miniature">
                                <locus target="#5r"/>
                                <desc>A priest playing a <hi rendition="simple:italic">kabaro</hi>.</desc>
                                <q xml:lang="am">ካህኑ፡ በከበሮ</q>
                            </decoNote>
                            
                            <decoNote xml:id="d6" type="miniature">
                                <locus target="#6r"/>
                                <desc>A musician playing a <hi rendition="simple:italic">māsinqo</hi>.</desc>
                                <q xml:lang="gez">እዝራ፡ በማሲንቆ</q>
                            </decoNote>
                        </decoDesc>

                        <bindingDesc>
                            <binding contemporary="true non-Ethiopian">
                                <decoNote xml:id="b1">
                                  The book has a modern binding fully covered in marbled paper with nonpareil pattern.
                                  The boards have squares that project beyond the edges of the bookblock.
                                  A paper label on which is printed in green colour ‘<persName
                                      ref="PRS15506GabraKr">Gebre Kristos Salomon</persName>’s paintings’ is pasted on the upper board.
                                </decoNote>
                            </binding>
