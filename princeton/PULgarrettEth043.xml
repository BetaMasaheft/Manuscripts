                    <msPart xml:id="p3">
                        <msIdentifier/>
                        <msContents><summary/>
                            <msItem xml:id="p3_i1">
                                <locus from="1r" to="4r"/>
                                <title>Readings from the Synaxarium</title>
                                <msItem xml:id="p3_i1.1">
                                    <locus from="1r" to="3v"/>
                                    <title type="complete" ref="LIT7717Consecra"/>
                                    <note>To be read on 22 Tāḫśāś.</note>
                                    <incipit xml:lang="gez">በስመ፡ <gap reason="ellipsis"/> አመ፡ ፳ወ፪ ለታሕሣሥ፡ በዛቲ፡ ዕለት፡ ተዝካረ፡ በዓሉ፡ ለመልአክ፡ ክቡር፡ ገብርኤል፡
                                        ሊቀ፡ መላእክት፤ መበስር፡ ወሕንፀተ፡ ቤተ፡ ክርስቲያን፤ በሀገረ፡ ዳኖህ፡ ወአስተርአየ፡ መልአክ፤ ተአምራቲሁ። <gap reason="ellipsis"/> 
                                        እግዚአብሔር፡ ትንብልናሁ፤ የሀሉ፡ ምስለ፡ ፍቁሩ፡ <persName ref="PRS15357GabraYoh" role="owner">ገብረ፡ ዮሐንስ፡</persName>
                                        ለዓለመ፡ ዓለም፡ አሜን። ወበዛቲ፡ ዕለት፡ ካዕበ፡ ተዝካረ፡ በዓል፡ ዓቢይ፡ በዘዜነዋ፡ ገብርኤል፡ መልአክ፡ ክቡር፡ ወአብሰራ፡ ለእግዝእትነ፡ ማርያም።
                                        ወሀሎ፡ ፩ ብእሲ፡ ኤጲስ፡ ቆጶስ፡ ጻድቅ፡ በብሔረ፡ ሮሜ፡ ዘስሙ፡ ደቅስዮስ፡ አስተርአየቶ፡ ሎቱ፡ እግዝእትነ፡ ማርያም፡</incipit>
                                </msItem>
                                <msItem xml:id="p3_i1.2">
                                    <locus from="3v8" to="4r"/>
                                    <title ref="LIT1284Dersan" type="incomplete">Readings of the Dǝrsāna Gabrǝʾel for Tāḫśāś 29</title>
                                    <note>Number <foreign xml:lang="gez">፳ወ፱</foreign> indicated in the left margin.</note>
                                    <msItem xml:id="p3_i1.2.1">
                                        <locus from="3v8" to="4r3"/>
                                        <title type="incomplete" ref="LIT1284Dersan#CommemorativeTahsas"/>
                                        <incipit xml:lang="gez">ወበዛቲ፡ ዕለት፡ ወደይዎሙ፡ ውስተ፡ እቶነ፡ እሳት፡ ለአናንያ፡ <sic>ወአዘርይ፡</sic> ወሚሳኤል፡</incipit>
                                        <explicit xml:lang="gez">ይትመሰል፡ በአርአይኮ፡ እመ፡ ጊዜ፡ ሐወጸ፡ ምድረ። እምነ፡ መላእክት፡ ኵሉ፡ ስነከ፡ አፍቀረ።</explicit>
                                    </msItem>
                                    <msItem xml:id="p3_i1.2.2">
                                        <locus from="4r3" to="4r9"/>
                                        <title ref="LIT4658Salam"/><!-- Issue #3310 -->
                                        <incipit xml:lang="gez">ሰላም፡ ለቤትከ፡ በሀገረ፡ ዳናህ፡ ዘቀደሳ። አርከላዎ<add place="above">ዎ</add>ስ፡ ኤጲስ፡ ቆጶስ፡</incipit>
                                    </msItem>
                                    <msItem xml:id="p3_i1.2.3">
                                        <locus from="4r9" to="4r15"/>
                                        <title ref="LIT7856SalamDaqs"/><!-- Issue #3311 -->
                                        <incipit xml:lang="gez">ሰላም፡ እብል፡ ለደቅስዮስ፡ ባሕርያ። ወኤጲስ፡ ቆጶስ። ለብሔረ፡ ጥልጥልያ።</incipit>
                                    </msItem>
                                </msItem>
                            </msItem>
                            <msItem xml:id="p3_i2">
                                <locus from="4v" to="7v"/>
                                <title ref="LIT4006Taamme"/>
                                <msItem xml:id="p3_i2.1">
                                    <locus from="4v1" to="5r"/>
                                    <title ref="LIT6273MGOldChurch"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ ለብፁዕ፡ ወ<del rend="strikethrough">ብፁዕ</del>ለቅዱስ፡ ኮከበ፡ ክብር፡ ማር፡ ጊዮርጊስ፡ 
                                        <gap reason="ellipsis"/> ወሀለወት፡ አሐቲ፡ ቤተ፡ ክርስቲያን፡ ዘሕንጽት፡ በስመ፡ ሰማዕት፡ ቅዱስ፡ ማር፡ ጊዮርጊስ፡ ወይእቲሰ፡ ቤተ፡ ክርስቲያን፡ በልየት፡
                                        ወማሰነት።</incipit>
                                </msItem>
                                <msItem xml:id="p3_i2.2">
                                    <locus from="5r" to="6v"/>
                                    <title ref="LIT6274MGFireHouse"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ ለብፁዕ፡ ወለቅዱስ፡ ማር፡ ጊዮርጊስ፡ <gap reason="ellipsis"/> 
                                        ወኮነ፡ በ፩ <add place="above">እ</add>መዋዕል። አውዓይ፡ እሳት፡ ቤቶ፡ ለ፩ ብእሲ፡ 
                                        በጎ<del rend="strikethrough">ሮ</del>ሩ፡ ለ፩ መነኮስ።</incipit>
                                </msItem>
                                <msItem xml:id="p3_i2.3">
                                    <locus from="6v" to="7r"/>
                                    <title ref="LIT6300MGPainter"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ ለብፁዕ፡ ወለቅዱስ፡ ጊዮርጊስ፡ ማር፡ ዘልዳ፡ <gap reason="ellipsis"/> ወካዕበ፡ በአሐቲ፡ ዕለት፡ ውስተ፡
                                        ይእቲ፡ ቤተ፡ ክርስቲያን። ዓርገ፡ ዲበ፡ ተስላስ፡ ልዑል፡ ብእሲ፡ መስተገብረ፡ ሥዕል።</incipit>
                                </msItem>
                                <msItem xml:id="p3_i2.4">
                                    <locus from="7r" to="7v"/>
                                    <title ref="LIT7408MGWidow"/>
                                    <incipit xml:lang="gez">ተአምሪሁ፡ ለብፁዕ፡ ወለቅዱስ፡ ማር፡ ጊዮርጊስ፡ <gap reason="ellipsis"/> ወሀለወት፡ አሐቲ፡ መበለት፡ በኀረ፡ ቤተ።
                                        ክርስቲያንኑ፤ ለሰማዕት፤ ወኅሩይ፡ ለብፁዕ፡ ወለቅዱስ፡ ማር፡ ጊዮርጊስ፡ ወመሰወ፡ አንቄ፡ ይርሆ<del rend="expunctuated">ሆ</del>ሀ፡</incipit>
                                </msItem>
                            </msItem>
                            <msItem xml:id="p3_i3">
                                <locus from="7v" to="8v"/>
                                <title ref="LIT3605Miracle"/>
                                <incipit xml:lang="gez">ተአምሪሃ፡ ለእግዝእትነ፡ ቅድስት፡ ድንግል፡ በ፪ ማርያም፡ ወላዲተ፡ አምላክ፡ <gap reason="ellipsis"/> ወሀሎ፡ 
                                    ፩ ብእሲ፡ መስተጋድል፡ ፈድፋደ፡ በከዊነ፡ <sic>ስም፡</sic> በእንተ፡ ስመ፡ ክርስቶስ፡ ዘስሙ፡ ማር፡ ጊዮርጊስ፡ ሐዲስ። ወአሐተ፡ ዕለተ፡ እንዘ፡ ሀሉ፡ ፅዑረ፡ 
                                    ውስተ፡ ኵነኔ፡ ግብተ፡ ኖመ።</incipit>
                            </msItem>
                            <msItem xml:id="p3_i4">
                                <locus from="8v7" to="8v18"/>
                                <title ref="LIT4274AkkonuB"/>
                                <incipit xml:lang="gez">ሶበ፡ ጊዮርጊስ፡ ኖመ፡ እምብዝኃ፡ ኵነኔ፡ ዕፁብ።</incipit>
                                <explicit xml:lang="gez">መልዕልተ፡ ምስሐል፡ ከመ፡ ይጸልል፡ ኪሩብ።</explicit>
                                <explicit xml:lang="gez" type="supplication">ጽልልኒ፡ እግዝእትየ፡ ክንፈኒ፡ ዘላህብ፤ ሃሌ፡ ሉያ፤ በብዝኃ፡ ኂሩትኪ፡ ማርያም፡ አድኅንኒ፡ እመከራ፡
                                    ሥጋ፤ ወነፍሰ፡ ለገብርኪ፡ <persName ref="PRS15357GabraYoh" role="owner">ገብረ፡ ዮሐንስ፡</persName> ለዓለመ፡ ዓለም፡ አሜን፡
                                    ወአሜን፡ ለይኩን፡ ለይኩን። ።</explicit>
                            </msItem>

